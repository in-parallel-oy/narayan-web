<style>
  /* Tax bar animation — starts at 0 width, animates to data-width on reveal */
  .tax-bar {
    width: 0;
    transition: none;
  }

  .tax-tier.is-visible .tax-bar {
    animation: tax-fill 1.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.2s;
  }

  /* Stagger: second tier slightly later, third tier later still */
  .tax-tier:nth-child(2).is-visible .tax-bar { animation-delay: 0.35s; }
  .tax-tier:nth-child(3).is-visible .tax-bar { animation-delay: 0.5s; }

  @keyframes tax-fill {
    from { width: 0; }
    to { width: var(--bar-target); }
  }

  /* Percentage counter fade-in */
  .tax-pct {
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .tax-tier.is-visible .tax-pct {
    opacity: 1;
    transition-delay: 0.6s;
  }
  .tax-tier:nth-child(2).is-visible .tax-pct { transition-delay: 0.75s; }
  .tax-tier:nth-child(3).is-visible .tax-pct { transition-delay: 0.9s; }

  @media (prefers-reduced-motion: reduce) {
    .tax-bar {
      animation: none !important;
      width: var(--bar-target) !important;
    }
    .tax-pct {
      opacity: 1 !important;
      transition: none !important;
    }
  }
</style>

<script>
  // Animate tax bars and percentage counters on scroll
  function initTaxBars() {
    const tiers = document.querySelectorAll('.tax-tier');

    // Set CSS custom properties for target widths
    tiers.forEach(tier => {
      const bar = tier.querySelector('.tax-bar');
      if (bar) {
        const target = bar.getAttribute('data-width');
        bar.style.setProperty('--bar-target', target + '%');
      }
    });

    // Observe each tier independently
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');

          // Animate the percentage counter
          const pct = entry.target.querySelector('.tax-pct');
          if (pct) {
            const target = parseInt(pct.getAttribute('data-target') || '0', 10);
            animateCounter(pct, target);
          }

          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    tiers.forEach(tier => observer.observe(tier));
  }

  function animateCounter(el: Element, target: number) {
    const delay = el.closest('.tax-tier:nth-child(2)') ? 750 :
                  el.closest('.tax-tier:nth-child(3)') ? 900 : 600;

    setTimeout(() => {
      const duration = 800;
      const start = performance.now();

      function tick(now: number) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        // Ease out cubic
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(eased * target);
        (el as HTMLElement).textContent = current + '%';

        if (progress < 1) {
          requestAnimationFrame(tick);
        }
      }

      requestAnimationFrame(tick);
    }, delay);
  }

  // Run on page load and after Astro client-side navigation
  document.addEventListener('astro:page-load', initTaxBars);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTaxBars);
  } else {
    initTaxBars();
  }
</script>

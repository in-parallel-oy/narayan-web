---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import SocialProofBar from '../components/SocialProofBar.astro';
import ProblemSection from '../components/ProblemSection.astro';
import ValuePropSection from '../components/ValuePropSection.astro';
import MeetingMomentsSection from '../components/MeetingMomentsSection.astro';
import ProductLadderSection from '../components/ProductLadderSection.astro';
import ImpactSection from '../components/ImpactSection.astro';
import ExecutionScopesSection from '../components/ExecutionScopesSection.astro';
import TrustSection from '../components/TrustSection.astro';
import WhitePapersSection from '../components/WhitePapersSection.astro';
import TeamSection from '../components/TeamSection.astro';
import BottomCtaSection from '../components/BottomCtaSection.astro';
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "In Parallel",
    "url": "https://www.in-parallel.com",
    "logo": "https://www.in-parallel.com/favicon.png",
    "description": "In Parallel is a free AI note-taker that captures every decision and commitment from your meetings and turns them into a living plan — automatically.",
    "foundingDate": "2023",
    "founders": [{ "@type": "Person", "name": "Christian Persson" }],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Salomonkatu 17 B 4. Krs",
      "addressLocality": "Helsinki",
      "postalCode": "00100",
      "addressCountry": "FI"
    },
    "sameAs": ["https://linkedin.com/company/in-parallel"]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "In Parallel",
    "url": "https://www.in-parallel.com"
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "In Parallel",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Free AI note-taker that joins your meetings, captures decisions and commitments, and updates your plan automatically. Start free, no credit card required.",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR",
      "description": "Free AI note-taker — start capturing today"
    }
  }
];
---

<BaseLayout title="In Parallel — Free AI Note-Taker That Writes Your Plan" jsonLd={jsonLd}>
  <HeroSection
    eyebrow="AI Note-Taker"
    title="The note-taker that"
    rotatingWords={["writes", "updates", "maintains", "rebuilds"]}
    titleLine2=" your plan."
    description="In Parallel joins your meetings, captures every decision and commitment, and turns them into a living plan — <strong class='text-white'>automatically</strong>. Start free. No credit card required."
    primaryCta={{ label: "See how it works", href: "/how-it-works" }}
    secondaryCta={{ label: "Start for free", href: "/waitlist" }}
    image={{ src: "/images/hero/hero-main.png", alt: "In Parallel AI note-taker capturing meeting decisions and updating plans automatically" }}
    videoUrl="https://player.vimeo.com/video/1130202043"
  />

  <SocialProofBar />
  <ProblemSection />

  <div class="shrink-scroll-wrapper">
    <ValuePropSection />
  </div>
  <MeetingMomentsSection />
  <ProductLadderSection />
  <ImpactSection />
  <ExecutionScopesSection />
  <TrustSection />
  <WhitePapersSection />
  <TeamSection />
  <BottomCtaSection />
</BaseLayout>

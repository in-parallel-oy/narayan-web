<style>
  .toc-link {
    display: block;
    font-family: var(--font-display);
    font-size: 0.875rem;
    line-height: 1.25rem;
    color: rgba(192, 195, 198, 0.4);
    padding: 0.3125rem 0 0.3125rem 0.75rem;
    border-left: 2px solid transparent;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }
  .toc-link:hover {
    color: rgba(192, 195, 198, 0.8);
  }
  .toc-link.toc-active {
    color: #ffffff;
    border-left-color: var(--color-ip-lime);
  }
</style>

<script>
  const sections = [...document.querySelectorAll('section[id]')];
  const links    = [...document.querySelectorAll('.toc-link')];

  function updateActive() {
    const scrollY = window.scrollY + 140; // offset for fixed nav + breathing room
    let current = sections[0]?.id ?? '';
    for (const section of sections) {
      if (section.offsetTop <= scrollY) current = section.id;
    }
    links.forEach(link => {
      link.classList.toggle('toc-active', link.getAttribute('href') === '#' + current);
    });
  }

  window.addEventListener('scroll', updateActive, { passive: true });
  updateActive();
</script>

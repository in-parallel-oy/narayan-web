<script>
  const sections = [...document.querySelectorAll('section[id]')];
  const links    = [...document.querySelectorAll('.toc-link')];

  function updateActive() {
    const scrollY = window.scrollY + 140; // offset for fixed nav + breathing room
    let current = sections[0]?.id ?? '';
    for (const section of sections) {
      if (section.offsetTop <= scrollY) current = section.id;
    }
    links.forEach(link => {
      link.classList.toggle('toc-active', link.getAttribute('href') === '#' + current);
    });
  }

  window.addEventListener('scroll', updateActive, { passive: true });
  updateActive();
</script>

<script>
  // ── Easing character demo ──
  const EASE_DURATION = 2100;

  function playEase() {
    const btn = document.getElementById('ease-replay') as HTMLButtonElement;
    const groups = document.querySelectorAll<HTMLElement>('.ease-demo-group');

    // 1. Snap dot back to start instantly (no transition)
    groups.forEach(g => {
      g.classList.add('ease-reset');
      g.classList.remove('playing');
    });

    // 2. Force reflow so the snap is committed
    groups[0]?.getBoundingClientRect();

    // 3. Re-enable transition and animate forward
    groups.forEach(g => g.classList.remove('ease-reset'));
    requestAnimationFrame(() => {
      groups.forEach(g => g.classList.add('playing'));
    });

    btn.disabled = true;
    btn.textContent = 'Playing…';
    setTimeout(() => {
      btn.disabled = false;
      btn.textContent = 'Replay';
    }, EASE_DURATION + 100);
  }
  document.getElementById('ease-replay')?.addEventListener('click', playEase);
  setTimeout(playEase, 500); // auto-play on load

  // ── Scroll reveal controls ──
  const container = document.getElementById('reveal-demo-container') as HTMLElement;

  function getEaseLabel(val: string) {
    if (val.includes('0.16')) return 'spring';
    if (val.includes('0.4')) return 'material';
    if (val === 'ease-out') return 'ease-out';
    return 'linear';
  }

  function updateBadges() {
    const revealDur = (document.getElementById('reveal-dur') as HTMLInputElement).value + 'ms';
    const enterDur  = (document.getElementById('enter-dur') as HTMLInputElement).value + 'ms';
    const easeVal   = (document.getElementById('ease-select') as HTMLSelectElement).value;
    const easeShort = getEaseLabel(easeVal);
    document.getElementById('reveal-dur-badge')!.textContent = `${revealDur} · ${easeShort}`;
    document.getElementById('enter-dur-badge')!.textContent  = `${enterDur} · ${easeShort}`;
    document.getElementById('scale-dur-badge')!.textContent  = `${revealDur} · ${easeShort}`;
    document.getElementById('fade-dur-badge')!.textContent   = `${revealDur} · ${easeShort}`;
  }

  function replayReveal() {
    const boxes = document.querySelectorAll('.reveal-demo-box');
    boxes.forEach(b => b.classList.remove('is-visible'));
    requestAnimationFrame(() => requestAnimationFrame(() => {
      boxes.forEach((b, i) => setTimeout(() => b.classList.add('is-visible'), i * 150));
    }));
  }

  let replayTimer: ReturnType<typeof setTimeout>;
  function debouncedReplay() {
    clearTimeout(replayTimer);
    replayTimer = setTimeout(replayReveal, 300);
  }

  document.getElementById('reveal-dur')?.addEventListener('input', (e) => {
    const val = (e.target as HTMLInputElement).value;
    document.getElementById('reveal-dur-val')!.textContent = val + 'ms';
    container.style.setProperty('--motion-duration-reveal', val + 'ms');
    updateBadges();
    debouncedReplay();
  });

  document.getElementById('enter-dur')?.addEventListener('input', (e) => {
    const val = (e.target as HTMLInputElement).value;
    document.getElementById('enter-dur-val')!.textContent = val + 'ms';
    container.style.setProperty('--motion-duration-enter', val + 'ms');
    updateBadges();
    debouncedReplay();
  });

  document.getElementById('ease-select')?.addEventListener('change', (e) => {
    const val = (e.target as HTMLSelectElement).value;
    document.getElementById('ease-label')!.textContent = getEaseLabel(val);
    container.style.setProperty('--motion-ease-out-expo', val);
    updateBadges();
    replayReveal();
  });

  document.getElementById('reveal-replay')?.addEventListener('click', replayReveal);
</script>

<script>
  // ── Editable type specimens ──
  // Make all font specimen <p> elements contenteditable.
  // Excludes: font-mono labels, hyphens-none section descriptions, tiny meta text.
  document.querySelectorAll('section[id] p').forEach(p => {
    const cl = p.className;
    const isFontSpec = cl.includes('font-display') || cl.includes('font-serif');
    const isMonoLabel = cl.includes('font-mono');
    const isSectionDesc = cl.includes('hyphens-none');
    const isTinyMeta = cl.includes('text-[10px]') || cl.includes('text-[9px]');
    if (isFontSpec && !isMonoLabel && !isSectionDesc && !isTinyMeta) {
      p.contentEditable = 'true';
      (p as HTMLElement).spellcheck = false;
      p.classList.add('type-specimen');
    }
  });
</script>

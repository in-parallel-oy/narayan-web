---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Typography — Dev Reference" navTheme="dark">
  <div class="container-ip py-32">
    <div class="flex gap-16">
      <div class="flex-1 min-w-0 space-y-24">

    <header>
      <p class="font-mono text-xs text-ip-white-muted mb-2">/dev/typography</p>
      <h1 class="font-display text-2xl text-white">Typography Reference</h1>
      <p class="font-display-regular text-ip-white-muted text-sm mt-1">All type styles used across the In Parallel site.</p>
    </header>

    <!-- ── Display Medium ── -->
    <section id="display" class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">font-display — In Parallel Medium</h2>

      <div class="space-y-6">
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-[136px] · 136px · H1 XL display — step +6</p>
          <p class="font-display text-[136px] leading-none tracking-tight">Living execution plan</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-headline-xl · 120px · Hero h1 large — @utility</p>
          <p class="font-display text-headline-xl leading-none tracking-tight">Living execution plan</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-headline / text-8xl · 96px · Hero headline — step +5</p>
          <p class="font-display text-headline leading-none tracking-tight">Living execution plan</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-6xl / text-7xl · 68px · Use-case h1 — step +4</p>
          <p class="font-display text-6xl tracking-tight">Use case for engineering leaders</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-5xl · 48px · Page h1 — step +3</p>
          <p class="font-display text-5xl tracking-tight">In Parallel for Program Managers</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-3xl / text-4xl · 34px · Section heading — step +2</p>
          <p class="font-display text-3xl tracking-tight">The coordination layer for every role</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-xl / text-2xl · 24px · Card title / feature heading — step +1</p>
          <p class="font-display text-xl">Real-time execution visibility</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-base / text-lg / text-emphasis · 17px · Body copy / nav / labels — step 0</p>
          <p class="font-display text-emphasis">Program managers</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-sm · 14px · Footer nav / UI label</p>
          <p class="font-display text-sm">For Engineering Leaders</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-xs · 12px · Meta / copyright</p>
          <p class="font-display text-xs">© 2025 In Parallel Oy. All rights reserved.</p>
        </div>
      </div>
    </section>

    <!-- ── Serif ── -->
    <section id="serif" class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">font-serif — Feature Deck Regular</h2>

      <div class="space-y-6">
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-[125px] · 125px optical (136px) · H1 XL display — step +6</p>
          <p class="font-serif text-[125px] leading-none tracking-tight">Living execution plan</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-headline-xl · 110px optical (120px) · Hero h1 large — @utility</p>
          <p class="font-serif text-headline-xl leading-none tracking-tight">Living execution plan</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-headline / text-8xl · 88px optical (96px) · Hero headline — step +5</p>
          <p class="font-serif text-headline leading-none tracking-tight">Living execution plan</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-6xl / text-7xl · 63px optical (68px) · Use-case h1 — step +4</p>
          <p class="font-serif text-6xl tracking-tight leading-[1.05]">One platform. Every seat.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-5xl · 44px optical (48px) · Page h1 — step +3</p>
          <p class="font-serif text-5xl tracking-tight leading-[1.1]">In Parallel for Program Managers</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-3xl / text-4xl · 31px optical (34px) · Section heading — step +2</p>
          <p class="font-serif text-3xl tracking-tight">The coordination layer for every role</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-xl / text-2xl · 22px optical (24px) · Card title / feature heading — step +1</p>
          <p class="font-serif text-xl">Real-time execution visibility</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-base / text-lg / text-emphasis · 16px optical (17px) · Body copy / nav / labels — step 0</p>
          <p class="font-serif text-emphasis">Program managers</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-sm · 13px optical (14px) · Footer nav / UI label</p>
          <p class="font-serif text-sm">For Engineering Leaders</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-xs · 11px optical (12px) · Meta / copyright</p>
          <p class="font-serif text-xs">© 2025 In Parallel Oy. All rights reserved.</p>
        </div>
      </div>
    </section>

    <!-- ── Line Height Reference ── -->
    <section id="line-height" class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">Line Height — multi-line heading reference</h2>
      <p class="font-display-regular text-sm text-ip-white-muted">Each size shown wrapping to 2–3 lines. Single-line headings may use <code class="font-mono bg-white/5 px-1 rounded">leading-[0.95]</code> to tighten further.</p>

      <div class="space-y-12">

        <div class="border border-ip-border rounded-xl p-6">
          <p class="font-mono text-xs text-ip-white-muted mb-1">text-headline · 96px · hardcoded line-height: <strong class="text-white">1.15</strong></p>
          <p class="font-mono text-xs text-ip-white-muted mb-4">@utility text-headline — this font's cap height requires 1.15 for wrapping headings</p>
          <p class="font-display text-headline tracking-tight">
            The hidden cost that kills execution — and how to eliminate it.
          </p>
        </div>

        <div class="border border-ip-border rounded-xl p-6">
          <p class="font-mono text-xs text-ip-white-muted mb-1">text-8xl / text-9xl · 96–136px · token line-height: <strong class="text-white">1.1</strong></p>
          <p class="font-mono text-xs text-ip-white-muted mb-4">--text-8xl--line-height: 1.1 / --text-9xl--line-height: 1.1 · add md:leading-[1.1] lg:leading-[1.1] for certainty</p>
          <p class="font-display text-9xl tracking-tight">
            We empower organizations and people to do the right things right.
          </p>
        </div>

        <div class="border border-ip-border rounded-xl p-6">
          <p class="font-mono text-xs text-ip-white-muted mb-1">text-6xl / text-7xl · 68px · token line-height: <strong class="text-white">1.1</strong></p>
          <p class="font-mono text-xs text-ip-white-muted mb-4">--text-6xl--line-height: 1.1 · "In Parallel Medium" cap height requires ≥1.1 at this size</p>
          <p class="font-display text-6xl tracking-tight">
            Built by people who've felt this problem firsthand.
          </p>
        </div>

        <div class="border border-ip-border rounded-xl p-6">
          <p class="font-mono text-xs text-ip-white-muted mb-1">text-5xl · 48px · token line-height: <strong class="text-white">1.05</strong></p>
          <p class="font-mono text-xs text-ip-white-muted mb-4">--text-5xl--line-height: 1.05</p>
          <p class="font-display text-5xl tracking-tight">
            The hidden cost that kills execution — and how to eliminate it.
          </p>
        </div>

        <div class="border border-ip-border rounded-xl p-6">
          <p class="font-mono text-xs text-ip-white-muted mb-1">text-3xl / text-4xl · 34px · token line-height: <strong class="text-white">1.1</strong></p>
          <p class="font-mono text-xs text-ip-white-muted mb-4">--text-3xl--line-height: 1.1</p>
          <p class="font-display text-3xl tracking-tight">
            The coordination layer keeps plans and reality in lockstep by turning your existing rhythms into a learning loop.
          </p>
        </div>

        <div class="border-2 border-ip-lime/30 rounded-xl p-6">
          <p class="font-mono text-xs text-ip-white-muted mb-1">leading-[0.95] override · tight single-line only</p>
          <p class="font-mono text-xs text-ip-white-muted mb-4">Use lg:leading-[0.95] (same breakpoint) to override text-headline default. Never use for multi-line headings.</p>
          <p class="font-display text-headline tracking-tight lg:leading-[0.95]">
            Living execution plan
          </p>
        </div>

      </div>
    </section>

    <!-- ── Display Regular ── -->
    <section id="display-regular" class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">font-display-regular — In Parallel Regular</h2>

      <div class="space-y-6">
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-2xl · Body intro / lead</p>
          <p class="font-display-regular text-2xl leading-snug text-ip-white-muted">In Parallel works differently for each role — because coordination looks different from every angle.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-xl · Subtitle / description</p>
          <p class="font-display-regular text-xl leading-relaxed text-ip-white-muted">See how COOs, program managers, engineering leaders, and more use the living execution plan.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-lg · Body large</p>
          <p class="font-display-regular text-lg leading-relaxed text-ip-white-muted">You're accountable for execution across the entire business, but your view depends on what people choose to report.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-base · Body default</p>
          <p class="font-display-regular text-base leading-relaxed text-ip-white-muted">As a COO, you own execution. But the information you rely on is filtered through layers of reporting, curated by the people closest to the work.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-sm · Caption / secondary</p>
          <p class="font-display-regular text-sm leading-relaxed text-ip-white-muted">See the state of every program across your organization without asking for updates.</p>
        </div>
      </div>
    </section>

    <!-- ── Display Bold ── -->
    <section id="display-bold" class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">font-display-bold — In Parallel Bold</h2>

      <div class="space-y-6">
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-3xl · 34px · Strong emphasis</p>
          <p class="font-display-bold text-4xl tracking-tight">Execution health at a glance.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-2xl · Callout</p>
          <p class="font-display-bold text-2xl">6–8 hours saved per week.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-base · Inline emphasis</p>
          <p class="font-display-bold text-base">Cross-team decisions propagate automatically.</p>
        </div>
      </div>
    </section>

    <!-- ── Section Eyebrow ── -->
    <section id="eyebrow" class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">Section eyebrow · .section-eyebrow</h2>

      <div class="space-y-4">
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">Dark background (default)</p>
          <p class="section-eyebrow">Use cases</p>
        </div>
        <div class="p-6 rounded-xl" style="background-color: #F3F5F2;">
          <p class="font-mono text-xs text-ip-navy/40 mb-2">Light background (.section-eyebrow--navy)</p>
          <p class="section-eyebrow section-eyebrow--navy">For engineering leaders</p>
        </div>
      </div>
    </section>

    <!-- ── Arrows from font ── -->
    <section id="arrows" class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">In Parallel font arrows · U+2190 / U+2192</h2>

      <div class="space-y-4">
        {(['text-sm', 'text-base', 'text-lg', 'text-xl', 'text-2xl', 'text-3xl', 'text-4xl', 'text-5xl', 'text-6xl'] as const).map((size) => (
          <div class="flex items-center gap-6">
            <p class="font-mono text-xs text-ip-white-muted w-24">{size}</p>
            <span class={`font-display ${size} leading-none`}>&#x2190;</span>
            <span class={`font-display ${size} leading-none`}>&#x2192;</span>
            <span class={`font-display ${size} leading-none`}>&#x2191;</span>
            <span class={`font-display ${size} leading-none`}>&#x2193;</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Buttons ── -->
    <section id="buttons" class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">Buttons</h2>

      <div class="flex flex-wrap items-center gap-6">
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-3">.btn-primary</p>
          <a href="#" class="btn-primary">
            Book a demo
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-3">.btn-secondary</p>
          <a href="#" class="btn-secondary">
            All use cases
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ── Colors ── -->
    <section id="colors" class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">Color tokens</h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { name: 'ip-navy',         hex: '#001325', bg: 'bg-ip-navy',         border: true },
          { name: 'ip-navy-light',   hex: '#142536', bg: 'bg-ip-navy-light',   border: false },
          { name: 'ip-navy-surface', hex: '#172733', bg: 'bg-ip-navy-surface', border: false },
          { name: 'ip-border',       hex: '#2e3b46', bg: 'bg-ip-border',       border: false },
          { name: 'ip-lime',         hex: '#85ff3b', bg: 'bg-ip-lime',         border: false },
          { name: 'ip-lime-light',   hex: '#befb99', bg: 'bg-ip-lime-light',   border: false },
          { name: 'ip-yellow',       hex: '#ffcc25', bg: 'bg-ip-yellow',       border: false },
          { name: 'ip-orange',       hex: '#ff5f43', bg: 'bg-ip-orange',       border: false },
          { name: 'ip-cyan',         hex: '#30ddff', bg: 'bg-ip-cyan',         border: false },
          { name: 'ip-blue',         hex: '#3049ff', bg: 'bg-ip-blue',         border: false },
          { name: 'ip-white',        hex: '#ffffff', bg: 'bg-white',           border: true  },
          { name: 'ip-white-muted',  hex: '#c0c3c6', bg: 'bg-ip-white-muted', border: false },
        ].map(({ name, hex, bg, border }) => (
          <div>
            <div class={`${bg} h-16 rounded-lg mb-2 ${border ? 'border border-ip-border' : ''}`} />
            <p class="font-mono text-xs text-white">{name}</p>
            <p class="font-mono text-xs text-ip-white-muted">{hex}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Grid Utilities ── -->
    <section id="grid" class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">Grid utilities</h2>

      <!-- Gutter tokens -->
      <div class="space-y-4">
        <p class="font-mono text-xs text-ip-white-muted">Gutter tokens — --grid-gutter-sm / md / lg</p>
        <div class="space-y-3">
          {[
            { name: '--grid-gutter-sm', px: '16px', desc: 'Tight card arrays, micro-spacing' },
            { name: '--grid-gutter-md', px: '24px', desc: 'Standard column gutter = 1 × line-height' },
            { name: '--grid-gutter-lg', px: '64px', desc: 'Section-level spacing, sidebar gaps' },
          ].map(({ name, px, desc }) => (
            <div class="flex items-center gap-6">
              <p class="font-mono text-xs text-white w-48 shrink-0">{name}</p>
              <div class="bg-ip-lime/20 border border-ip-lime/40 rounded" style={`width: ${px}; height: 24px;`} />
              <p class="font-mono text-xs text-ip-white-muted">{px} — {desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- grid-manuscript -->
      <div class="space-y-3">
        <p class="font-mono text-xs text-ip-white-muted">.grid-manuscript — centered 65ch reading column (Bringhurst §2.1.2)</p>
        <div class="grid-manuscript border border-ip-border rounded-xl overflow-hidden">
          <div class="bg-ip-navy-light p-6 rounded-xl">
            <p class="font-mono text-xs text-ip-lime mb-3">min(65ch, 100%)</p>
            <p class="font-display-regular text-base text-ip-white-muted leading-relaxed">
              In Parallel gives every team member a single place to see what's happening, why it matters, and what to do next — without asking for status updates. The coordination overhead that once consumed 40% of manager time simply disappears.
            </p>
            <p class="font-display-regular text-base text-ip-white-muted leading-relaxed mt-4">
              Use this grid for long-form prose: insight articles, legal pages, vision documents. It enforces Bringhurst's 45–75 character measure rule automatically.
            </p>
          </div>
        </div>
      </div>

      <!-- grid-sidebar -->
      <div class="space-y-3">
        <p class="font-mono text-xs text-ip-white-muted">.grid-sidebar — narrow nav/TOC pane + wide main content (stacks on mobile)</p>
        <div class="grid-sidebar border border-ip-border rounded-xl p-6">
          <div class="shrink-0 w-48 space-y-2">
            <p class="font-mono text-xs text-ip-lime mb-3">sidebar pane</p>
            <p class="font-display text-sm text-ip-white-muted">Introduction</p>
            <p class="font-display text-sm text-ip-white-muted">The problem</p>
            <p class="font-display text-sm text-ip-white-muted">Our approach</p>
            <p class="font-display text-sm text-ip-white-muted">Results</p>
          </div>
          <div class="flex-1 space-y-3">
            <p class="font-mono text-xs text-ip-lime mb-3">main content</p>
            <p class="font-display-regular text-base text-ip-white-muted leading-relaxed">40% of manager time goes to coordination — not the actual work. We've done the research to prove it, and built the product to fix it.</p>
            <p class="font-display-regular text-base text-ip-white-muted leading-relaxed">This layout replaces the repeated <code class="font-mono text-ip-lime text-xs">flex flex-col lg:flex-row gap-12 lg:gap-16 items-start</code> pattern across 10+ page files.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Bento Grid ── -->
    <section id="bento" class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">Bento grid · .grid-bento + .bento-cell</h2>

      <!-- Token reference -->
      <div class="space-y-2">
        <p class="font-mono text-xs text-ip-white-muted">Tokens</p>
        <div class="overflow-x-auto">
          <table class="font-mono text-xs w-full border-collapse">
            <thead>
              <tr class="text-ip-white-muted border-b border-ip-border">
                <th class="text-left py-2 pr-8">Token</th>
                <th class="text-left py-2 pr-8">Value</th>
                <th class="text-left py-2">At viewport</th>
              </tr>
            </thead>
            <tbody class="text-ip-white-muted">
              <tr class="border-b border-ip-border/40">
                <td class="py-2 pr-8 text-white">--bento-radius</td>
                <td class="py-2 pr-8">1rem (16px)</td>
                <td class="py-2">All — 4 × grid-step</td>
              </tr>
              <tr class="border-b border-ip-border/40">
                <td class="py-2 pr-8 text-white">--bento-row-height</td>
                <td class="py-2 pr-8">clamp(64px, 8vw, 96px)</td>
                <td class="py-2">96px ≥1200px · 76px @950px · 64px ≤800px</td>
              </tr>
              <tr class="border-b border-ip-border/40">
                <td class="py-2 pr-8 text-white">gap</td>
                <td class="py-2 pr-8">--grid-gutter-md (24px)</td>
                <td class="py-2">Consistent with column grid</td>
              </tr>
              <tr>
                <td class="py-2 pr-8 text-white">columns</td>
                <td class="py-2 pr-8">12 / 8 / 4</td>
                <td class="py-2">lg (1024+) / md (768–1023) / sm (&lt;768)</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Cell variant swatches -->
      <div class="space-y-3">
        <p class="font-mono text-xs text-ip-white-muted">Cell surface variants — all share same radius and gap</p>
        <div class="grid-bento">
          <div class="bento-cell bento-cell--pad bento-cell--center col-span-2 row-span-2">
            <p class="font-mono text-xs text-ip-white-muted mb-1">(default)</p>
            <p class="font-display text-sm text-white">navy-light</p>
          </div>
          <div class="bento-cell bento-cell--surface bento-cell--pad bento-cell--center col-span-2 row-span-2">
            <p class="font-mono text-xs text-ip-white-muted mb-1">--surface</p>

---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Typography — Dev Reference" navTheme="dark">
  <div class="container-ip py-32 space-y-24">

    <header>
      <p class="font-mono text-xs text-ip-white-muted mb-2">/dev/typography</p>
      <h1 class="font-display text-2xl text-white">Typography Reference</h1>
      <p class="font-display-regular text-ip-white-muted text-sm mt-1">All type styles used across the In Parallel site.</p>
    </header>

    <!-- ── Serif ── -->
    <section class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">font-serif — Feature Deck Regular</h2>

      <div class="space-y-6">
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-8xl · 96px · Hero display</p>
          <p class="font-serif text-8xl tracking-tight leading-[1.05]">Living execution plan</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-7xl · 72px · Page hero</p>
          <p class="font-serif text-7xl tracking-tight leading-[1.05]">One platform. Every seat.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-6xl · 60px · Section CTA</p>
          <p class="font-serif text-6xl tracking-tight leading-[1.1]">Lead from reality, not reports.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-5xl · 48px · Pull quote</p>
          <p class="font-serif text-5xl tracking-tight leading-[1.15]">"Stop running the business from a dashboard that's already out of date."</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-4xl · 36px · Sub-heading</p>
          <p class="font-serif text-4xl tracking-tight">See it for your role.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-3xl · 30px · Card heading</p>
          <p class="font-serif text-3xl tracking-tight">What actually happened in your meetings.</p>
        </div>
      </div>
    </section>

    <!-- ── Display Medium ── -->
    <section class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">font-display — In Parallel Medium</h2>

      <div class="space-y-6">
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-[104px] · 104px · H1 XL</p>
          <p class="font-display text-[104px] leading-none tracking-tight">Living execution plan</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-6xl · 60px · Use-case h1</p>
          <p class="font-display text-6xl tracking-tight">Use case for engineering leaders</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-5xl · 48px · Page h1</p>
          <p class="font-display text-5xl tracking-tight">In Parallel for Program Managers</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-4xl · 36px · Section heading</p>
          <p class="font-display text-4xl tracking-tight">The coordination layer for every role</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-3xl · 30px · Sub-section heading</p>
          <p class="font-display text-3xl tracking-tight">Your dashboard is already out of date.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-2xl · 24px · Card title</p>
          <p class="font-display text-2xl">Also explore</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-xl · 20px · Feature heading</p>
          <p class="font-display text-xl">Real-time execution visibility</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-emphasis · 17px · Nav / label · Body emphasis</p>
          <p class="font-display text-emphasis">Program managers</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-sm · 14px · Footer nav / UI label</p>
          <p class="font-display text-sm">For Engineering Leaders</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-xs · 12px · Meta / copyright</p>
          <p class="font-display text-xs">© 2025 In Parallel Oy. All rights reserved.</p>
        </div>
      </div>
    </section>

    <!-- ── Display Regular ── -->
    <section class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">font-display-regular — In Parallel Regular</h2>

      <div class="space-y-6">
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-2xl · Body intro / lead</p>
          <p class="font-display-regular text-2xl leading-snug text-ip-white-muted">In Parallel works differently for each role — because coordination looks different from every angle.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-xl · Subtitle / description</p>
          <p class="font-display-regular text-xl leading-relaxed text-ip-white-muted">See how COOs, program managers, engineering leaders, and more use the living execution plan.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-lg · Body large</p>
          <p class="font-display-regular text-lg leading-relaxed text-ip-white-muted">You're accountable for execution across the entire business, but your view depends on what people choose to report.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-base · Body default</p>
          <p class="font-display-regular text-base leading-relaxed text-ip-white-muted">As a COO, you own execution. But the information you rely on is filtered through layers of reporting, curated by the people closest to the work.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-sm · Caption / secondary</p>
          <p class="font-display-regular text-sm leading-relaxed text-ip-white-muted">See the state of every program across your organization without asking for updates.</p>
        </div>
      </div>
    </section>

    <!-- ── Display Bold ── -->
    <section class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">font-display-bold — In Parallel Bold</h2>

      <div class="space-y-6">
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-4xl · Strong emphasis</p>
          <p class="font-display-bold text-4xl tracking-tight">Execution health at a glance.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-2xl · Callout</p>
          <p class="font-display-bold text-2xl">6–8 hours saved per week.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">text-base · Inline emphasis</p>
          <p class="font-display-bold text-base">Cross-team decisions propagate automatically.</p>
        </div>
      </div>
    </section>

    <!-- ── Section Eyebrow ── -->
    <section class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">Section eyebrow · .section-eyebrow</h2>

      <div class="space-y-4">
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-2">Dark background (default)</p>
          <p class="section-eyebrow">Use cases</p>
        </div>
        <div class="p-6 rounded-xl" style="background-color: #F3F5F2;">
          <p class="font-mono text-xs text-ip-navy/40 mb-2">Light background (.section-eyebrow--navy)</p>
          <p class="section-eyebrow section-eyebrow--navy">For engineering leaders</p>
        </div>
      </div>
    </section>

    <!-- ── Arrows from font ── -->
    <section class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">In Parallel font arrows · U+2190 / U+2192</h2>

      <div class="space-y-4">
        {(['text-sm', 'text-base', 'text-lg', 'text-xl', 'text-2xl', 'text-3xl', 'text-4xl', 'text-5xl', 'text-6xl'] as const).map((size) => (
          <div class="flex items-center gap-6">
            <p class="font-mono text-xs text-ip-white-muted w-24">{size}</p>
            <span class={`font-display ${size} leading-none`}>&#x2190;</span>
            <span class={`font-display ${size} leading-none`}>&#x2192;</span>
            <span class={`font-display ${size} leading-none`}>&#x2191;</span>
            <span class={`font-display ${size} leading-none`}>&#x2193;</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Buttons ── -->
    <section class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">Buttons</h2>

      <div class="flex flex-wrap items-center gap-6">
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-3">.btn-primary</p>
          <a href="#" class="btn-primary">
            Book a demo
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div>
          <p class="font-mono text-xs text-ip-white-muted mb-3">.btn-secondary</p>
          <a href="#" class="btn-secondary">
            All use cases
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ── Colors ── -->
    <section class="space-y-8">
      <h2 class="font-mono text-xs text-ip-white-muted uppercase tracking-widest border-b border-ip-border pb-3">Color tokens</h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { name: 'ip-navy',         hex: '#001325', bg: 'bg-ip-navy',         border: true },
          { name: 'ip-navy-light',   hex: '#142536', bg: 'bg-ip-navy-light',   border: false },
          { name: 'ip-navy-surface', hex: '#172733', bg: 'bg-ip-navy-surface', border: false },
          { name: 'ip-border',       hex: '#2e3b46', bg: 'bg-ip-border',       border: false },
          { name: 'ip-lime',         hex: '#85ff3b', bg: 'bg-ip-lime',         border: false },
          { name: 'ip-lime-light',   hex: '#befb99', bg: 'bg-ip-lime-light',   border: false },
          { name: 'ip-yellow',       hex: '#ffcc25', bg: 'bg-ip-yellow',       border: false },
          { name: 'ip-orange',       hex: '#ff5f43', bg: 'bg-ip-orange',       border: false },
          { name: 'ip-cyan',         hex: '#30ddff', bg: 'bg-ip-cyan',         border: false },
          { name: 'ip-blue',         hex: '#3049ff', bg: 'bg-ip-blue',         border: false },
          { name: 'ip-white',        hex: '#ffffff', bg: 'bg-white',           border: true  },
          { name: 'ip-white-muted',  hex: '#c0c3c6', bg: 'bg-ip-white-muted', border: false },
        ].map(({ name, hex, bg, border }) => (
          <div>
            <div class={`${bg} h-16 rounded-lg mb-2 ${border ? 'border border-ip-border' : ''}`} />
            <p class="font-mono text-xs text-white">{name}</p>
            <p class="font-mono text-xs text-ip-white-muted">{hex}</p>
          </div>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>

---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Security — In Parallel",
  "description": "Enterprise-grade security: ISO 27001, ISO 42001, SOC 2 Type II, GDPR compliant. EU data sovereignty.",
  "url": "https://www.in-parallel.com/security"
};
---

<BaseLayout title="Security - In Parallel" description="Enterprise-grade security and compliance." jsonLd={jsonLd}>
  <section class="pt-32 pb-20 md:pt-44 md:pb-32">
    <div class="container-ip">
      <h1 class="font-serif text-5xl md:text-7xl tracking-tight mb-8">Security</h1>
      <div class="max-w-3xl">
        <p class="text-ip-lime text-xl font-display mb-6">
          EU data sovereignty. Enterprise-grade security. No compromises.
        </p>
        <p class="text-ip-white-muted text-lg leading-relaxed mb-6 text-left max-w-[65ch]">
          In Parallel is built and hosted in the EU. Your data stays within European borders — under your control and governed by European data protection law. No models are trained with your company information.
        </p>
        <p class="text-ip-white-muted text-lg leading-relaxed mb-12 text-left max-w-[65ch]">
          We meet the highest enterprise security standards: SSO/SAML/SCIM, RBAC, full audit logs, EU data residency, and DPIA documentation out of the box.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-ip-navy-surface rounded-xl p-6 card-elevated">
            <h3 class="font-display text-lg mb-2">EU Data Sovereignty</h3>
            <p class="text-ip-white-muted text-sm">Hosted in the EU. Your data never leaves European infrastructure without your explicit consent.</p>
          </div>
          <div class="bg-ip-navy-surface rounded-xl p-6 card-elevated">
            <h3 class="font-display text-lg mb-2">ISO 27001</h3>
            <p class="text-ip-white-muted text-sm">Information security management certified.</p>
          </div>
          <div class="bg-ip-navy-surface rounded-xl p-6 card-elevated">
            <h3 class="font-display text-lg mb-2">ISO 42001</h3>
            <p class="text-ip-white-muted text-sm">AI management system certified.</p>
          </div>
          <div class="bg-ip-navy-surface rounded-xl p-6 card-elevated">
            <h3 class="font-display text-lg mb-2">SOC 2 Type II</h3>
            <p class="text-ip-white-muted text-sm">Audited and attested security controls.</p>
          </div>
          <div class="bg-ip-navy-surface rounded-xl p-6 card-elevated">
            <h3 class="font-display text-lg mb-2">GDPR Compliant</h3>
            <p class="text-ip-white-muted text-sm">Full compliance with EU data protection regulations.</p>
          </div>
        </div>

        <!-- More information -->
        <div class="mt-16 pt-12 border-t border-ip-border">
          <h2 class="font-display text-2xl mb-4">More information</h2>
          <p class="text-ip-white-muted text-base leading-relaxed mb-8">
            For detailed security documentation, compliance certificates, and our data processing policies, visit our trust portal. Our white papers cover AI governance, data sovereignty, and enterprise security architecture in depth.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="https://trust.in-parallel.com" target="_blank" rel="noopener" class="btn-primary">
              Trust portal
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
            <a href="/white-papers" class="btn-secondary">
              White papers
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Security - In Parallel" description="Enterprise-grade security and compliance.">
  <section class="pt-32 pb-20 md:pt-44 md:pb-32">
    <div class="container-ip">
      <h1 class="font-serif text-5xl md:text-7xl tracking-tight mb-8">Security</h1>
      <div class="max-w-3xl">
        <p class="text-ip-white-muted text-lg leading-relaxed mb-6">
          In Parallel is built for enterprise trust. Your data stays where it is — no models are trained with your company information.
        </p>
        <p class="text-ip-white-muted text-lg leading-relaxed mb-12">
          We meet enterprise-grade standards: SSO/SAML/SCIM, RBAC, full audit logs, data residency options, and DPIA documentation out of the box.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 card-elevated">
            <h3 class="font-display text-lg mb-2">ISO 27001</h3>
            <p class="text-ip-white-muted text-sm">Information security management certified.</p>
          </div>
          <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 card-elevated">
            <h3 class="font-display text-lg mb-2">ISO 42001</h3>
            <p class="text-ip-white-muted text-sm">AI management system certified.</p>
          </div>
          <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 card-elevated">
            <h3 class="font-display text-lg mb-2">SOC 2 Type II</h3>
            <p class="text-ip-white-muted text-sm">Audited and attested security controls.</p>
          </div>
          <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 card-elevated">
            <h3 class="font-display text-lg mb-2">GDPR Compliant</h3>
            <p class="text-ip-white-muted text-sm">Full compliance with EU data protection regulations.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import HowItWorksSection from '../components/HowItWorksSection.astro';
import IntegrationsSection from '../components/IntegrationsSection.astro';
import BottomCtaSection from '../components/BottomCtaSection.astro';
---

<BaseLayout
  navTheme="light"
  title="How It Works — In Parallel"
  description="See how In Parallel joins your meetings, captures decisions, and updates your plan automatically. Before, during, and after every meeting."
>
  <!-- Page hero -->
  <section class="pt-32 pb-12 md:pt-44 md:pb-20 bg-white text-ip-navy">
    <div class="container-ip text-center">
      <p class="section-eyebrow section-eyebrow--navy mb-4">How it works</p>
      <h1 class="font-serif text-5xl md:text-7xl tracking-tight mb-6 text-ip-navy">
        It listens. It captures.<br class="hidden md:block" /> It updates.
      </h1>
      <p class="text-ip-navy/60 text-lg max-w-2xl mx-auto">
        In Parallel joins your meetings as a silent note-taker, captures every decision and commitment, and updates your plan and tools — automatically.
      </p>
    </div>
  </section>

  <HowItWorksSection />
  <IntegrationsSection />
  <BottomCtaSection />
</BaseLayout>

---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Careers - In Parallel" description="Join the team building the future of execution intelligence.">
  <section class="pt-32 pb-20 md:pt-44 md:pb-32">
    <div class="container-ip">
      <h1 class="font-serif text-5xl md:text-7xl tracking-tight mb-8">Careers</h1>
      <div class="max-w-3xl">
        <p class="text-ip-white-muted text-lg leading-relaxed mb-12 text-left max-w-[65ch]">
          We're building the next generation of enterprise software from Helsinki, Finland. If you're excited about AI, execution intelligence, and enterprise-scale challenges — we'd love to hear from you.
        </p>

        <!-- Open positions placeholder -->
        <div class="space-y-4">
          <p class="text-ip-white-muted text-base">
            No open positions at the moment. Send your application to
            <a href="mailto:info@in-parallel.com" class="text-ip-lime hover:underline">info@in-parallel.com</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

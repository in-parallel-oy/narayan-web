---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Use - In Parallel" description="Terms of use for the In Parallel website.">
  <section class="pt-32 pb-20 md:pt-44 md:pb-32">
    <div class="container-ip max-w-3xl">
      <h1 class="font-display text-4xl md:text-5xl tracking-tight mb-12">Terms of Use</h1>
      <div class="prose prose-invert prose-lg max-w-none prose-headings:font-display">
        <p>Terms of use content to be migrated from Framer.</p>
      </div>
    </div>
  </section>
</BaseLayout>

---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Lost in Translation - In Parallel" description="The page you're looking for doesn't exist.">
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden">

    <!-- Ambient glow -->
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] rounded-full bg-white/[0.012] blur-[180px] pointer-events-none"></div>

    <!-- Floating broken grid lines -->
    <div class="error-lines absolute inset-0 pointer-events-none" aria-hidden="true">
      <svg class="w-full h-full" viewBox="0 0 1440 900" fill="none" preserveAspectRatio="xMidYMid slice">
        <!-- Drifting horizontal lines — broken connections -->
        <line x1="0" y1="280" x2="420" y2="280" stroke="white" stroke-opacity="0.04" stroke-width="1" class="error-line error-line-1" />
        <line x1="520" y1="280" x2="1440" y2="280" stroke="white" stroke-opacity="0.025" stroke-width="1" class="error-line error-line-2" />
        <line x1="0" y1="620" x2="680" y2="620" stroke="white" stroke-opacity="0.03" stroke-width="1" class="error-line error-line-3" />
        <line x1="780" y1="620" x2="1440" y2="620" stroke="white" stroke-opacity="0.02" stroke-width="1" class="error-line error-line-4" />

        <!-- Vertical broken line -->
        <line x1="720" y1="0" x2="720" y2="340" stroke="white" stroke-opacity="0.025" stroke-width="1" class="error-line error-line-5" />
        <line x1="720" y1="560" x2="720" y2="900" stroke="white" stroke-opacity="0.02" stroke-width="1" class="error-line error-line-6" />

        <!-- Small disconnected nodes -->
        <circle cx="420" cy="280" r="3" fill="white" fill-opacity="0.06" class="error-node error-node-1" />
        <circle cx="520" cy="280" r="3" fill="white" fill-opacity="0.04" class="error-node error-node-2" />
        <circle cx="680" cy="620" r="3" fill="white" fill-opacity="0.05" class="error-node error-node-3" />
        <circle cx="780" cy="620" r="3" fill="white" fill-opacity="0.03" class="error-node error-node-4" />
        <circle cx="720" cy="340" r="3" fill="white" fill-opacity="0.05" class="error-node error-node-5" />
        <circle cx="720" cy="560" r="3" fill="white" fill-opacity="0.04" class="error-node error-node-6" />
      </svg>
    </div>

    <div class="container-ip relative z-10">
      <!-- Ghost 404 -->
      <p
        class="error-ghost font-serif text-[12rem] md:text-[20rem] lg:text-[28rem] leading-[0.75] tracking-tighter text-white/[0.025] select-none text-center pointer-events-none"
        aria-hidden="true"
      >404</p>

      <!-- Content — overlays the ghost -->
      <div class="text-center -mt-28 md:-mt-44 lg:-mt-64">
        <p class="text-white/30 text-xs font-display uppercase tracking-[0.2em] mb-6 scroll-reveal">Signal lost</p>

        <h1 class="scroll-reveal">
          <span class="block font-serif text-5xl md:text-7xl lg:text-8xl tracking-tight leading-[0.9] text-white">
            This page drifted
          </span>
          <span class="block font-serif text-5xl md:text-7xl lg:text-8xl tracking-tight leading-[0.9] text-white/15 mt-1">
            off the plan.
          </span>
        </h1>

        <p class="text-white/35 text-base md:text-lg max-w-md mx-auto mt-8 mb-12 scroll-reveal leading-relaxed">
          The link you followed no longer exists&mdash;or never did. Let's get you back on track.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 scroll-reveal">
          <a href="/" class="btn-primary">
            Back to home
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/insight" class="btn-secondary">
            Read our insights
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Subtle drift animation on the broken grid lines */
  .error-line-1 { animation: drift-left 12s ease-in-out infinite alternate; }
  .error-line-2 { animation: drift-right 14s ease-in-out infinite alternate; }
  .error-line-3 { animation: drift-left 16s ease-in-out infinite alternate; }
  .error-line-4 { animation: drift-right 11s ease-in-out infinite alternate; }
  .error-line-5 { animation: drift-up 13s ease-in-out infinite alternate; }
  .error-line-6 { animation: drift-down 15s ease-in-out infinite alternate; }

  /* Nodes pulse gently */
  .error-node { animation: pulse-node 4s ease-in-out infinite; }
  .error-node-2 { animation-delay: 0.7s; }
  .error-node-3 { animation-delay: 1.4s; }
  .error-node-4 { animation-delay: 2.1s; }
  .error-node-5 { animation-delay: 0.5s; }
  .error-node-6 { animation-delay: 1.8s; }

  /* Ghost number subtle float */
  .error-ghost {
    animation: ghost-float 8s ease-in-out infinite alternate;
  }

  @keyframes drift-left {
    from { transform: translateX(0); }
    to { transform: translateX(-20px); }
  }

  @keyframes drift-right {
    from { transform: translateX(0); }
    to { transform: translateX(20px); }
  }

  @keyframes drift-up {
    from { transform: translateY(0); }
    to { transform: translateY(-15px); }
  }

  @keyframes drift-down {
    from { transform: translateY(0); }
    to { transform: translateY(15px); }
  }

  @keyframes pulse-node {
    0%, 100% { opacity: 1; r: 3; }
    50% { opacity: 0.4; r: 5; }
  }

  @keyframes ghost-float {
    from { transform: translateY(0); }
    to { transform: translateY(-12px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .error-line,
    .error-node,
    .error-ghost {
      animation: none;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found - In Parallel">
  <section class="pt-32 pb-20 md:pt-44 md:pb-32">
    <div class="container-ip text-center">
      <h1 class="font-serif text-7xl md:text-9xl tracking-tight mb-4 text-ip-white-muted">404</h1>
      <p class="text-ip-white-muted text-lg mb-8">This page doesn't exist.</p>
      <a href="/" class="btn-lime">
        Go home
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>

---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';

const roles = [
  {
    name: "COO / Operations Leader",
    benefit: "Real-time execution visibility across the entire business \u2014 without chasing updates.",
    href: "/use-case/coo",
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M3 3v18h18"/><path d="M7 16l4-8 4 4 5-9"/></svg>`,
  },
  {
    name: "Program Manager",
    benefit: "Cross-team decisions propagate automatically. No more telephone game.",
    href: "/use-case/program-manager",
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4M2 12h4m12 0h4m-3.5-6.5l-2.8 2.8m-5.4 5.4l-2.8 2.8m0-11l2.8 2.8m5.4 5.4l2.8 2.8"/></svg>`,
  },
  {
    name: "Project Manager",
    benefit: "Meeting decisions update your plan. Connected tools stay in sync. No double-entry.",
    href: "/use-case/project-manager",
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>`,
  },
  {
    name: "Engineering Leader",
    benefit: "See what\u2019s actually happening across squads without micromanaging.",
    href: "/use-case/engineering-leader",
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
  },
  {
    name: "Team Lead",
    benefit: "Your standups and 1:1s update the plan. Less alignment overhead, more team time.",
    href: "/use-case/team-lead",
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>`,
  },
  {
    name: "Account Executive / Sales Leader",
    benefit: "Keep complex accounts aligned from opportunity to renewal. Never lose a deal to internal misalignment.",
    href: "/use-case/account-executive",
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M12 8c-2.2 0-4 1.8-4 4s1.8 4 4 4 4-1.8 4-4-1.8-4-4-4z"/><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32l1.41-1.41"/></svg>`,
  },
  {
    name: "Strategy / PMO",
    benefit: "Strategic goals connected to operational execution in real time.",
    href: "/use-case/strategy",
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><circle cx="12" cy="12" r="10"/><path d="M16.24 7.76l-2.12 6.36-6.36 2.12 2.12-6.36 6.36-2.12z"/></svg>`,
  },
];
---

<BaseLayout
  title="Use Cases \u2014 In Parallel for Every Role"
  description="In Parallel works differently for each role \u2014 because coordination looks different from every angle. See how COOs, program managers, engineering leaders, and more use the living execution plan."
>
  <!-- Hero -->
  <section class="pt-32 pb-16 md:pt-44 md:pb-24">
    <div class="container-ip text-center">
      <p class="section-eyebrow mb-4 scroll-reveal">Use cases</p>
      <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl tracking-tight leading-[1.05] mb-8 scroll-reveal">
        One platform.<br />Every seat at the table.
      </h1>
      <p class="text-ip-white-muted text-xl md:text-2xl max-w-2xl mx-auto font-display-regular leading-snug scroll-reveal">
        In Parallel works differently for each role &mdash; because coordination looks different from every angle.
      </p>
    </div>
  </section>

  <!-- Role Grid -->
  <section class="py-20 md:py-32 bg-ip-navy">
    <div class="container-ip">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {roles.map((role) => (
          <a
            href={role.href}
            class="group bg-ip-navy-surface border border-ip-border rounded-xl p-6 hover:border-ip-lime/40 transition-colors scroll-reveal"
          >
            <div class="text-ip-lime/60 mb-4" set:html={role.svg} />
            <h2 class="font-display text-xl mb-2 text-white group-hover:text-ip-lime transition-colors">
              {role.name}
            </h2>
            <p class="text-ip-white-muted text-sm leading-relaxed mb-4">
              {role.benefit}
            </p>
            <span class="inline-flex items-center gap-1.5 text-ip-lime text-sm font-display">
              Learn more
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Value Prop -->
  <section class="py-20 md:py-32 bg-ip-navy-light min-h-[80vh] flex items-center">
    <div class="container-ip text-center scroll-reveal">
      <h2 class="font-display text-3xl md:text-5xl tracking-tight mb-6">
        The coordination layer for every role
      </h2>
      <p class="text-ip-white-muted text-lg leading-relaxed mb-6">
        In Parallel joins your meetings, captures decisions and action items, updates your living execution plan, and syncs with the tools you already use. No manual status updates. No information loss between layers.
      </p>
      <p class="text-ip-white-muted text-lg leading-relaxed">
        The result: every role sees the same reality, always current, always connected to what was actually decided.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-32 min-h-[80vh] flex items-center bg-ip-navy">
    <div class="container-ip text-center scroll-reveal">
      <h2 class="font-serif text-3xl md:text-6xl tracking-tight mb-6">
        See it for your role.
      </h2>
      <p class="text-ip-white-muted text-lg max-w-2xl mx-auto mb-10">
        30-minute demo tailored to your workflow. We'll show you how your meetings become a living plan.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/demo" class="btn-primary">
          Book a demo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/#how-it-works" class="btn-secondary">
          See how it works
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Book a Demo - In Parallel" description="See In Parallel in action. Book a personalized demo.">
  <section class="pt-32 pb-20 md:pt-44 md:pb-32">
    <div class="container-ip text-center">
      <h1 class="font-serif text-5xl md:text-7xl tracking-tight mb-8">Book a demo</h1>
      <p class="text-ip-white-muted text-lg max-w-2xl mx-auto mb-12">
        See how In Parallel can transform your team's execution intelligence.
      </p>

      <div class="max-w-4xl mx-auto rounded-xl overflow-hidden border border-ip-border">
        <iframe
          src="https://collaborate.in-parallel.com/demo"
          class="w-full border-0"
          style="min-height: 700px;"
          title="Book a demo with In Parallel"
          loading="lazy"
          allow="clipboard-write"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>

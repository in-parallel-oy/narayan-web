---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import BottomCtaSection from '../components/BottomCtaSection.astro';

const valueProps = [
  {
    number: '01',
    title: 'Shared memory across meetings',
    description: 'Copilot or ChatGPT summarises one meeting. In Parallel connects every meeting into a living plan \u2014 decisions, risks, ownership, and timelines accumulate automatically.',
  },
  {
    number: '02',
    title: 'Automatic plan updates',
    description: 'Copilot helps you draft a status update. ChatGPT formats your slides. In Parallel eliminates the need for either \u2014 the plan updates itself from every conversation.',
  },
  {
    number: '03',
    title: 'Cross-team visibility',
    description: 'Each person\u2019s Copilot, ChatGPT, Gemini, or Claude sees only their own context. In Parallel gives everyone a single source of truth \u2014 what\u2019s on track, what drifted, what needs attention.',
  },
  {
    number: '04',
    title: 'Richer answers from your AI tools',
    description: 'In Parallel feeds your programme data into Copilot, Gemini, and Claude via MCP \u2014 the open protocol that connects AI to live context \u2014 so questions get answered from what actually happened, not from memory.',
  },
];

const withoutItems = [
  'Individual meeting summaries',
  'Manual plan updates',
  'Context resets every meeting',
  'Decisions scattered across docs',
  'No drift detection',
];

const withItems = [
  'Connected meeting memory',
  'Plan writes itself',
  'Context builds across meetings',
  'Single source of truth',
  'Automatic risk & drift alerts',
];

const superpowers = [
  {
    tool: 'Microsoft Copilot',
    superpower: 'Writes context-aware documents',
    useCase: '\u201CGenerate a QBR deck with actual delivery status, risk items, and commitment history from the last 6 weeks.\u201D',
  },
  {
    tool: 'ChatGPT',
    superpower: 'Answers questions about your programme',
    useCase: '\u201CWhich workstreams have the most overdue commitments, and who owns them?\u201D',
  },
  {
    tool: 'Claude',
    superpower: 'Analyses patterns across meetings',
    useCase: '\u201CCompare what was promised in steering vs. what actually happened in sprint reviews this quarter.\u201D',
  },
  {
    tool: 'Microsoft Copilot',
    superpower: 'Drafts stakeholder comms',
    useCase: '\u201CWrite an executive summary email for the sponsor \u2014 include only items that changed since last week.\u201D',
  },
  {
    tool: 'Google Gemini',
    superpower: 'Connects your calendar to context',
    useCase: '\u201CPull up everything agreed about the platform migration before my 2pm with the CTO \u2014 what\u2019s on track and what\u2019s slipping.\u201D',
  },
  {
    tool: 'ChatGPT',
    superpower: 'Prepares meeting briefs',
    useCase: '\u201CBrief me for tomorrow\u2019s steering committee: open risks, stalled decisions, and topics carried over from last meeting.\u201D',
  },
];

const quotes = [
  {
    text: 'We already had Copilot rolling out to 200 people. In\u00A0Parallel was the piece that turned 200 people moving fast into 200 people moving in the same direction.',
    author: 'Programme Director',
    company: 'Enterprise customer',
  },
  {
    text: 'Our PMs were using ChatGPT to write status updates from memory. Now it pulls from what actually happened in the meetings. Night and day.',
    author: 'VP of Delivery',
    company: 'SaaS scale-up',
  },
  {
    text: 'Claude is brilliant at analysis \u2014 but only if you feed it the right context. In\u00A0Parallel does that automatically after every meeting.',
    author: 'Head of Strategy',
    company: 'Consulting firm',
  },
  {
    text: 'We stopped building slides manually. Copilot generates the QBR deck from In\u00A0Parallel data and it\u2019s more accurate than what we wrote by hand.',
    author: 'Delivery Lead',
    company: 'Professional services',
  },
  {
    text: 'Gemini already knew my calendar. Once In\u00A0Parallel fed it the meeting context, it started prepping me for calls I hadn\u2019t even thought about yet.',
    author: 'Chief of Staff',
    company: 'Google Workspace customer',
  },
  {
    text: 'The combination of In\u00A0Parallel plus ChatGPT replaced our weekly \u201Cwhat happened last week\u201D meeting entirely. That\u2019s 45 minutes back for 12 people.',
    author: 'COO',
    company: 'Series B fintech',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Better with AI — In Parallel',
    description: 'In Parallel works alongside Microsoft Copilot, ChatGPT, Gemini, and Claude to solve the coordination gap between highly productive individuals.',
  url: 'https://www.in-parallel.com/better-with-ai',
};
---

<BaseLayout
  navTheme="light"
  title="Better with AI — In Parallel"
  description="Your team already uses Copilot, ChatGPT, Gemini, and Claude. In Parallel is the coordination layer that makes those tools work across the whole team."
  jsonLd={jsonLd}
>

  <!-- Hero — light -->
  <section class="pt-32 pb-4 md:pt-44 md:pb-6 bg-white text-ip-navy">
    <div class="container-ip max-w-5xl">
      <div class="text-center relative z-10">
        <p class="section-eyebrow section-eyebrow--navy mb-4 scroll-reveal">Align your AI stack with the work</p>
        <h1 class="font-serif text-6xl md:text-8xl tracking-tight mb-6 text-ip-navy scroll-reveal">
          Your team already has AI.<br class="hidden md:block" />
          Now make your team aligned.
        </h1>
        <p class="text-ip-navy/60 text-lg leading-relaxed max-w-[52ch] mx-auto mb-10 scroll-reveal">
          Most teams already use Microsoft Copilot, ChatGPT, Gemini, or Claude. They make individuals faster. In&nbsp;Parallel aligns the whole team.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 scroll-reveal">
          <a href="/waitlist" class="btn-primary btn-primary--navy">
            Start for free
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/demo" class="btn-secondary btn-secondary--navy">
            Book a demo
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <div class="relative mt-4 scroll-reveal-hero" data-parallax="0.1" style="will-change: transform;">
        <img
          src="/images/generated/strategy-workshop/strategy-workshop-2-light.png"
          alt="Strategy workshop — team collaborating at a whiteboard"
          width="1200"
          height="675"
          class="w-full rounded-xl"
        />
      </div>
    </div>
  </section>

  <!-- The productivity paradox — dark -->
  <section class="py-20 md:py-32 bg-ip-navy" data-parallax="0.05" style="will-change: transform;">
    <div class="container-ip max-w-5xl">
      <div class="text-center mb-16">
        <p class="section-eyebrow mb-4 scroll-reveal">Why it breaks</p>
        <h2 class="font-display text-3xl md:text-6xl tracking-tight mb-8 scroll-reveal">
          More productivity. More chaos.
        </h2>
        <p class="text-ip-white-muted text-lg leading-relaxed max-w-[52ch] mx-auto scroll-reveal">
          Every AI tool makes the individual faster. None of them make the team more coordinated.
        </p>
      </div>

      <div class="grid-bento scroll-reveal">

        <!-- Large stat card -->
        <div class="bento-cell bento-cell--glow bento-cell--pad bento-cell--bottom col-span-4 md:col-span-8 lg:col-span-6 row-span-4 lg:row-span-5">
          <p class="font-display text-8xl leading-none text-ip-lime mb-3">78%</p>
          <p class="font-display text-2xl md:text-3xl text-white mb-2">of employees bring their own AI tools to work.</p>
          <p class="text-ip-white-muted text-sm leading-tight">Microsoft found that individual tools make people faster — but fail to deliver team‑ and organisation‑wide benefits entirely. Everyone moves. Nobody&nbsp;aligns.</p>
          <p class="font-mono text-[10px] text-ip-white-muted/40 tracking-wide uppercase mt-4">Microsoft Work Trend Index 2024</p>
        </div>

        <!-- Everyone drafts faster -->
        <div class="bento-cell bento-cell--surface bento-cell--pad bento-cell--top col-span-4 md:col-span-8 lg:col-span-6 row-span-3">
          <h3 class="font-display text-3xl mb-3">Everyone drafts faster</h3>
          <p class="text-ip-white-muted text-sm leading-tight mt-auto max-w-sm">The draft goes out. But the context behind it — who agreed, what was left open, what changed last week — stays in the room it was made in. Nobody else knows.</p>
        </div>

        <!-- Everyone summarises meetings -->
        <div class="bento-cell bento-cell--pad bento-cell--top col-span-4 md:col-span-4 lg:col-span-3 row-span-2">
          <h3 class="font-display text-lg leading-tight mb-3">Everyone summarises meetings</h3>
          <p class="text-ip-white-muted text-sm leading-tight mt-auto">The summary arrives ten minutes after the call. You skim it, mark it read, and open the same plan you had before. Nobody updates it. Nobody knows who's supposed to.</p>
        </div>

        <!-- Everyone has an assistant -->
        <div class="bento-cell bento-cell--surface bento-cell--pad bento-cell--top col-span-4 md:col-span-4 lg:col-span-3 row-span-2">
          <h3 class="font-display text-lg mb-3">Everyone has an assistant</h3>
          <p class="text-ip-white-muted text-sm leading-tight mt-auto">Your Copilot knows your calendar. ChatGPT knows your emails. Gemini knows your Drive. None of them know what was agreed in the meeting you weren't in — or what it means for the work you're doing now.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- The coordination layer — 4 numbered value props — dark alternate -->
  <section class="py-20 md:py-32 bg-ip-navy-light">
    <div class="container-ip max-w-5xl">
      <div class="text-center mb-16">
        <p class="section-eyebrow mb-4 scroll-reveal">The fix</p>
        <h2 class="font-display text-3xl md:text-6xl tracking-tight mb-8 scroll-reveal">
          In Parallel connects what AI creates.
        </h2>
      </div>

      <div class="grid-bento scroll-reveal">
        {valueProps.map((prop) => (
          <div class="bento-cell bento-cell--surface bento-cell--pad bento-cell--top col-span-4 md:col-span-4 lg:col-span-6 row-span-3">
            <p class="font-mono text-xs text-ip-white-muted/40 tracking-wide uppercase mb-3 select-none">{prop.number}</p>
            <h3 class="font-display text-lg md:text-xl">{prop.title}</h3>
            <p class="text-ip-white-muted text-sm leading-tight mt-auto">{prop.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Side-by-side: Without vs With — light -->
  <section class="py-20 md:py-32 bg-white text-ip-navy">
    <div class="container-ip max-w-5xl">
      <div class="text-center mb-16">
        <p class="section-eyebrow section-eyebrow--navy mb-4 scroll-reveal">Side by side</p>
        <h2 class="font-display text-3xl md:text-6xl tracking-tight mb-8 text-ip-navy scroll-reveal">
          Fast alone.<br class="hidden md:block" /> Aligned together.
        </h2>
      </div>

      <div class="grid-bento scroll-reveal">
        <!-- Without -->
        <div class="bento-cell bento-cell--pad bento-cell--top col-span-4 md:col-span-4 lg:col-span-6 row-span-4">
          <p class="font-display text-sm uppercase tracking-widest text-ip-white-muted/40 mb-6">Copilot, ChatGPT, Gemini & Claude alone</p>
          <ul class="space-y-4 mt-auto">
            {withoutItems.map((item) => (
              <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-tight">
                <svg class="w-4 h-4 text-ip-white-muted/30 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 12H4"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- With -->
        <div class="bento-cell bento-cell--surface bento-cell--pad bento-cell--top col-span-4 md:col-span-4 lg:col-span-6 row-span-4">
          <p class="font-display text-sm uppercase tracking-widest text-ip-lime mb-6">Copilot, ChatGPT, Gemini & Claude + In Parallel</p>
          <ul class="space-y-4 mt-auto">
            {withItems.map((item) => (
              <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-tight">
                <svg class="w-4 h-4 text-ip-lime mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Superpowers table — dark alternate -->
  <section class="py-20 md:py-32 bg-ip-navy-light">
    <div class="container-ip max-w-5xl">
      <div class="text-center mb-16">
        <p class="section-eyebrow mb-4 scroll-reveal">AI superpowers</p>
        <h2 class="font-display text-3xl md:text-6xl tracking-tight mb-8 scroll-reveal">
          What your AI tools can do<br class="hidden md:block" /> with In&nbsp;Parallel context.
        </h2>
        <p class="text-ip-white-muted text-lg leading-relaxed max-w-[52ch] mx-auto scroll-reveal">
          When Copilot, ChatGPT, Gemini, and Claude can see your programme's actual execution data, they can answer questions you've never been able to ask before.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 scroll-reveal">
        {superpowers.map((item) => (
          <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6">
            <h3 class="font-display text-lg mb-3">{item.superpower}</h3>
            <p class="text-ip-white-muted text-sm leading-tight italic">{item.useCase}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quotes marquee — dark -->
  <section class="py-20 md:py-32 bg-ip-navy overflow-hidden">
    <div class="quote-marquee" aria-label="Customer quotes">
      <div class="quote-marquee-track">
        {[...quotes, ...quotes].map((q) => (
          <blockquote class="quote-marquee-card">
            <p class="font-serif text-xl md:text-2xl leading-snug tracking-tight mb-4">
              &ldquo;{q.text}&rdquo;
            </p>
            <footer class="text-ip-white-muted text-sm">
              &mdash; {q.author}, {q.company}
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <BottomCtaSection />

</BaseLayout>

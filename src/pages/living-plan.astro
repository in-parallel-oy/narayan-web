---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Living Plan — In Parallel",
  "description": "Turn meeting signals into a continuously updated execution plan. Auto-updates, drift detection, priority recalculation.",
  "url": "https://www.in-parallel.com/living-plan"
};
---

<BaseLayout
  navTheme="light"
  title="Living Plan — In Parallel"
  description="Turn meeting signals into a continuously updated execution plan. Auto-updates, drift detection, priority recalculation. From €69/scope/month."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="pt-32 pb-16 md:pt-44 md:pb-24 bg-white text-ip-navy">
    <div class="container-ip max-w-5xl">
      <div class="text-center mb-16">
        <p class="section-eyebrow section-eyebrow--navy mb-4">Living Plan</p>
        <h1 class="font-serif text-5xl md:text-7xl tracking-tight mb-6 text-ip-navy">
          A plan that writes itself.
        </h1>
        <p class="text-ip-navy/60 text-lg max-w-[52ch] mx-auto mb-8">
          The Living Plan takes what the free AI notetaker captures and turns it into an execution plan that stays current &mdash; automatically.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/demo" class="btn-primary btn-primary--navy">
            Book a demo
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/pricing" class="btn-secondary btn-secondary--navy">
            See pricing
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

    </div>

    <div class="container-ip mt-0 px-0 md:px-6 lg:px-8">
      <img
        src="/images/generated/living-plan-meeting/living-plan-meeting-03.png"
        alt="Two colleagues reviewing sticky notes and plans on a wall"
        class="w-full md:rounded-xl"
        width="1280"
        height="720"
        loading="eager"
      />
    </div>
  </section>

  <!-- Why not just use a notetaker or PM tool -->
  <section class="py-20 md:py-32 bg-ip-navy-light text-white">
    <div class="container-ip max-w-5xl">
      <div class="text-center mb-16">
        <p class="section-eyebrow mb-4">vs. your current stack</p>
        <h2 class="font-display text-3xl md:text-6xl tracking-tight mb-6">
          Why your PM tool won't do this.
        </h2>
        <p class="text-ip-white-muted text-lg max-w-[52ch] mx-auto">
          Jira, Asana, and Monday track tasks. AI notetakers capture meetings. Neither connects the two &mdash; or keeps the plan current without someone doing it manually.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Current vs. stale -->
        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 card-elevated">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-ip-lime/10 border border-ip-lime/20 flex items-center justify-center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-ip-lime"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            </div>
            <h3 class="font-display text-lg">Always current vs. always stale</h3>
          </div>
          <p class="text-ip-white-muted text-sm leading-relaxed mb-4">
            PM tools show you the plan someone last updated. The Living Plan reflects what was actually decided this week &mdash; because it updated itself after every meeting.
          </p>
          <div class="grid grid-cols-2 gap-4 text-xs">
            <div class="bg-white/5 rounded-lg p-3">
              <p class="text-white/30 mb-1">Jira / Asana / Monday</p>
              <p class="text-ip-white-muted">Accurate on the day it was updated. Stale by Friday.</p>
            </div>
            <div class="bg-ip-lime/5 border border-ip-lime/10 rounded-lg p-3">
              <p class="text-ip-lime/60 mb-1">Living Plan</p>
              <p class="text-ip-white-muted">Updates after every meeting. Always reflects what was actually decided.</p>
            </div>
          </div>
        </div>

        <!-- Connected vs. siloed -->
        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 card-elevated">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-ip-cyan/10 border border-ip-cyan/20 flex items-center justify-center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-ip-cyan"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
            </div>
            <h3 class="font-display text-lg">Connected vs. siloed</h3>
          </div>
          <p class="text-ip-white-muted text-sm leading-relaxed mb-4">
            Meeting notes live in one place. The plan lives in another. Someone has to bridge the gap &mdash; or it doesn't get bridged at all. The Living Plan bridges them. No one has to do it manually.
          </p>
          <div class="grid grid-cols-2 gap-4 text-xs">
            <div class="bg-white/5 rounded-lg p-3">
              <p class="text-white/30 mb-1">AI notetaker alone</p>
              <p class="text-ip-white-muted">A summary in a doc. No connection to the plan that needs updating.</p>
            </div>
            <div class="bg-ip-cyan/5 border border-ip-cyan/10 rounded-lg p-3">
              <p class="text-ip-cyan/60 mb-1">Living Plan</p>
              <p class="text-ip-white-muted">Meeting signals flow directly into the plan. Nothing falls through the gap.</p>
            </div>
          </div>
        </div>

        <!-- Proactive vs. reactive -->
        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 card-elevated">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-orange-400/10 border border-orange-400/20 flex items-center justify-center">

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { sanityClient, urlFor } from '../../lib/sanity';
import { toHTML } from '@portabletext/to-html';

export const prerender = true;

export async function getStaticPaths() {
  const episodes = await sanityClient.fetch(`
    *[_type == "episode" && status == "published"] { slug }
  `);
  return episodes.map((ep: any) => ({
    params: { slug: ep.slug.current },
  }));
}

const { slug } = Astro.params;

const [episode, allEpisodes] = await Promise.all([
  sanityClient.fetch(
    `*[_type == "episode" && slug.current == $slug][0] {
      _id,
      title,
      slug,
      episodeNumber,
      season,
      publishDate,
      description,
      themes,
      duration,
      hookQuestion,
      keyTopics,
      body,
      guest,
      "hostName": host->name,
      "hostRole": host->role,
      "hostPhoto": host->photo,
      "hostLinkedin": host->linkedin,
      youtubeUrl,
      spotifyUrl,
      applePodcastsUrl,
      coverImage,
      thumbnailImage,
      status,
      featured,
      transcript
    }`,
    { slug }
  ),
  sanityClient.fetch(
    `*[_type == "episode" && status == "published" && slug.current != $slug] | order(publishDate desc) {
      _id,
      title,
      slug,
      episodeNumber,
      season,
      publishDate,
      description,
      themes,
      duration,
      coverImage,
      "guestName": guest.name
    }`,
    { slug }
  ),
]);

if (!episode) {
  return Astro.redirect('/404');
}

// ── YouTube URL → embed URL helper ──
function youtubeEmbedUrl(url: string): string | null {
  if (!url) return null;
  // Already an embed URL
  if (url.includes('/embed/')) return url;
  // Standard watch URL: youtube.com/watch?v=VIDEO_ID
  const watchMatch = url.match(/[?&]v=([^&]+)/);
  if (watchMatch) return `https://www.youtube.com/embed/${watchMatch[1]}`;
  // Short URL: youtu.be/VIDEO_ID
  const shortMatch = url.match(/youtu\.be\/([^?&]+)/);
  if (shortMatch) return `https://www.youtube.com/embed/${shortMatch[1]}`;
  // Shorts URL: youtube.com/shorts/VIDEO_ID
  const shortsMatch = url.match(/\/shorts\/([^?&]+)/);
  if (shortsMatch) return `https://www.youtube.com/embed/${shortsMatch[1]}`;
  return null;
}

// ── Portable Text → HTML (with heading IDs for TOC) ──
let headingIndex = 0;
const tocItems: { id: string; text: string; level: number }[] = [];

function stripHtml(html: string): string {
  return html
    .replace(/<[^>]*>/g, '')
    .replace(/&#x27;/g, "'")
    .replace(/&#x2019;/g, "\u2019")
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#(\d+);/g, (_, n) => String.fromCharCode(Number(n)))
    .replace(/&#x([0-9a-fA-F]+);/g, (_, h) => String.fromCharCode(parseInt(h, 16)));
}

const portableTextComponents = {
  block: {
    h2: ({ children }: { children: string }) => {
      const id = `section-${headingIndex++}`;
      tocItems.push({ id, text: stripHtml(children), level: 2 });
      return `<h2 id="${id}">${children}</h2>`;
    },
    h3: ({ children }: { children: string }) => {
      const id = `section-${headingIndex++}`;
      tocItems.push({ id, text: stripHtml(children), level: 3 });
      return `<h3 id="${id}">${children}</h3>`;
    },
  },
  types: {
    image: ({ value }: { value: any }) => {
      const src = urlFor(value).width(800).url();
      const alt = value.alt || '';
      const caption = value.caption || '';
      const figcaption = caption ? `<figcaption>${caption}</figcaption>` : '';
      return `<figure><img src="${src}" alt="${alt}" />${figcaption}</figure>`;
    },
    youtube: ({ value }: { value: any }) => {
      const embedUrl = youtubeEmbedUrl(value.url || '');
      if (!embedUrl) return '';
      return `<div class="aspect-video my-8"><iframe src="${embedUrl}" class="w-full h-full rounded-lg" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>`;
    },
  },
};

const bodyHtml = episode.body ? toHTML(episode.body, { components: portableTextComponents }) : '';
const transcriptHtml = episode.transcript ? toHTML(episode.transcript, { components: portableTextComponents }) : '';

// ── Image URLs ──
const ogImage = episode.thumbnailImage
  ? urlFor(episode.thumbnailImage).width(1200).height(630).url()
  : episode.coverImage
    ? urlFor(episode.coverImage).width(1200).height(630).url()
    : undefined;

const guestPhotoUrl = episode.guest?.photo ? urlFor(episode.guest.photo).width(160).height(160).url() : null;
const guestPhotoLargeUrl = episode.guest?.photo ? urlFor(episode.guest.photo).width(400).height(400).url() : null;
const hostPhotoUrl = episode.hostPhoto ? urlFor(episode.hostPhoto).width(64).height(64).url() : null;
const coverImageUrl = episode.coverImage ? urlFor(episode.coverImage).width(1200).height(680).url() : null;

const embedUrl = episode.youtubeUrl ? youtubeEmbedUrl(episode.youtubeUrl) : null;

// ── Episode label ──
const epLabel = episode.season && episode.episodeNumber
  ? `S${episode.season} E${episode.episodeNumber}`
  : episode.episodeNumber
    ? `E${episode.episodeNumber}`
    : '';

// ── Related episodes (ranked by theme overlap, then date) ──
const episodeThemes = episode.themes || [];
const relatedEpisodes = allEpisodes
  .map((ep: any) => {
    const overlap = (ep.themes || []).filter((t: string) => episodeThemes.includes(t)).length;
    return { ...ep, _overlap: overlap };
  })
  .sort((a: any, b: any) => {
    if (b._overlap !== a._overlap) return b._overlap - a._overlap;
    return new Date(b.publishDate || 0).getTime() - new Date(a.publishDate || 0).getTime();
  })
  .slice(0, 6);

// ── JSON-LD ──
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "PodcastEpisode",
    "name": episode.title,
    "description": episode.description || '',
    ...(episode.episodeNumber && { "episodeNumber": episode.episodeNumber }),
    ...(episode.publishDate && { "datePublished": episode.publishDate }),
    ...(ogImage && { "image": ogImage }),
    ...(episode.duration && { "timeRequired": `PT${episode.duration}M` }),
    "url": `https://www.in-parallel.com/podcast/${episode.slug.current}`,
    ...(episode.guest?.name && {
      "actor": {
        "@type": "Person",
        "name": episode.guest.name,
        ...(episode.guest.role && { "jobTitle": episode.guest.role }),
        ...(episode.guest.company && {
          "worksFor": { "@type": "Organization", "name": episode.guest.company }
        }),
      }
    }),
    "partOfSeason": {
      "@type": "PodcastSeason",
      "seasonNumber": episode.season || 1,
      "partOfSeries": {
        "@type": "PodcastSeries",
        "name": "The Coordination Tax",
        "url": "https://www.in-parallel.com/podcast",
        "author": {
          "@type": "Organization",
          "name": "In Parallel",
          "url": "https://www.in-parallel.com"
        }
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.in-parallel.com" },
      { "@type": "ListItem", "position": 2, "name": "Podcast", "item": "https://www.in-parallel.com/podcast" },
      { "@type": "ListItem", "position": 3, "name": episode.title }
    ]
  }
];
---

<BaseLayout
  title={`${episode.title} — The Coordination Tax`}
  description={episode.description}
  ogType="article"
  publishedTime={episode.publishDate}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <article class="episode-article">

    <!-- ══════════════════════════════════════════════════
         Section 1 — Episode Header
         ══════════════════════════════════════════════════ -->
    <header class="pt-32 pb-8 md:pt-44 md:pb-12">
      <div class="container-ip max-w-5xl">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-ip-white-muted mb-10" aria-label="Breadcrumb">
          <a href="/podcast" class="hover:text-white no-underline transition-colors">Podcast</a>
          <span class="opacity-40">→</span>
          <span class="text-white/80 font-display truncate max-w-[400px]">{episode.title}</span>
        </nav>

        <!-- Theme badges -->
        {episodeThemes.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-6">
            {episodeThemes.map((theme: string) => (
              <span class="inline-block bg-ip-lime/10 text-ip-lime text-xs font-display px-3 py-1 rounded-full">{theme}</span>
            ))}
          </div>
        )}

        <!-- Episode number -->
        {epLabel && (
          <p class="font-mono text-ip-lime text-sm mb-4">{epLabel}</p>
        )}

        <!-- Title -->
        <h1 class="font-display text-3xl md:text-6xl lg:text-7xl tracking-tight leading-[1.05] mb-6 text-white">{episode.title}</h1>

        <!-- Hook question -->
        {episode.hookQuestion && (
          <p class="text-xl md:text-2xl text-ip-lime leading-relaxed max-w-3xl italic mb-6">{episode.hookQuestion}</p>
        )}

        <!-- Duration + date -->
        <div class="flex items-center gap-4 font-mono text-sm text-ip-white-muted">
          {episode.duration && (
            <span>{episode.duration} min</span>
          )}
          {episode.duration && episode.publishDate && (
            <span class="opacity-40">&middot;</span>
          )}
          {episode.publishDate && (
            <time>
              {new Date(episode.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          )}
        </div>
      </div>
    </header>

    <!-- ══════════════════════════════════════════════════
         Section 2 — Video / Cover Image
         ══════════════════════════════════════════════════ -->
    <div class="container-ip max-w-5xl mb-12">
      {embedUrl ? (
        <div>
          <div class="aspect-video rounded-xl overflow-hidden">
            <iframe
              src={embedUrl}
              class="w-full h-full"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>

          {/* Listen-on links */}
          {(episode.spotifyUrl || episode.applePodcastsUrl) && (
            <div class="flex items-center gap-4 mt-6">
              <span class="text-xs font-mono text-ip-white-muted uppercase tracking-wider">Listen on</span>
              {episode.spotifyUrl && (
                <a href={episode.spotifyUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-ip-white-muted hover:text-white no-underline transition-colors">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                  Spotify
                </a>
              )}
              {episode.applePodcastsUrl && (
                <a href={episode.applePodcastsUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-ip-white-muted hover:text-white no-underline transition-colors">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M5.34 0A5.328 5.328 0 000 5.34v13.32A5.328 5.328 0 005.34 24h13.32A5.328 5.328 0 0024 18.66V5.34A5.328 5.328 0 0018.66 0H5.34zm6.525 2.568c2.336 0 4.448.902 6.056 2.587 1.224 1.272 1.912 2.619 2.264 4.392.12.48-.12.912-.6 1.032-.48.072-.912-.168-1.032-.648-.264-1.344-.816-2.424-1.776-3.432-1.32-1.392-2.928-2.063-4.912-2.063-1.992 0-3.6.671-4.92 2.063-.96 1.008-1.512 2.088-1.776 3.432-.12.48-.552.72-1.032.648-.48-.12-.72-.552-.6-1.032.36-1.773 1.04-3.12 2.264-4.392 1.608-1.685 3.72-2.587 6.064-2.587zm.048 4.032c1.464 0 2.76.528 3.816 1.608.744.744 1.2 1.584 1.416 2.64.072.48-.192.912-.672 1.008-.48.072-.888-.216-.984-.696-.144-.72-.456-1.272-.984-1.824-.72-.744-1.608-1.104-2.592-1.104-.984 0-1.872.36-2.592 1.104-.528.552-.84 1.104-.984 1.824-.096.48-.504.768-.984.696-.48-.096-.744-.528-.672-1.008.216-1.056.672-1.896 1.416-2.64 1.056-1.08 2.352-1.608 3.816-1.608zm-.024 4.512c1.2 0 2.208.984 2.208 2.208 0 .672-.312 1.296-.792 1.704v.024l.48 3.24c.072.48-.264.888-.744.96h-2.304c-.48-.072-.816-.48-.744-.96l.48-3.24v-.024c-.48-.408-.792-1.032-.792-1.704 0-1.224 1.008-2.208 2.208-2.208z"/></svg>
                  Apple Podcasts
                </a>
              )}
            </div>
          )}
        </div>
      ) : coverImageUrl ? (
        <div class="max-h-[680px] overflow-hidden rounded-xl">
          <img
            src={coverImageUrl}
            alt={episode.coverImage?.alt || episode.title}
            class="w-full h-full object-cover"
          />
        </div>
      ) : null}
    </div>

    <!-- ══════════════════════════════════════════════════
         Section 3 — Two-column body: sidebar + content
         ══════════════════════════════════════════════════ -->
    <div class="container-ip max-w-5xl">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">

        <!-- Left sidebar (sticky) -->
        <aside class="lg:w-72 flex-shrink-0">
          <div class="lg:sticky lg:top-28 space-y-8 mb-[10em]">

            <!-- Published date -->
            {episode.publishDate && (
              <div class="flex items-baseline gap-4">
                <span class="text-sm text-ip-white-muted font-display">Published</span>
                <time class="text-sm text-white">
                  {new Date(episode.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
            )}

            <!-- Guest card -->
            {episode.guest?.name && (
              <div class="flex items-start gap-4">
                {guestPhotoUrl ? (
                  <img src={guestPhotoUrl} alt={episode.guest.name} class="w-14 h-14 rounded-full object-cover flex-shrink-0" />
                ) : (
                  <div class="w-14 h-14 rounded-full bg-ip-lime/10 flex items-center justify-center flex-shrink-0 text-ip-lime font-display text-sm">
                    {episode.guest.name.split(' ').map((n: string) => n[0]).join('')}
                  </div>
                )}
                <div class="space-y-0.5">
                  <p class="text-xs font-mono text-ip-white-muted uppercase tracking-wider">Guest</p>
                  <p class="font-display text-sm text-white">{episode.guest.name}</p>
                  {(episode.guest.role || episode.guest.company) && (
                    <p class="text-sm text-ip-white-muted">
                      {episode.guest.role}{episode.guest.role && episode.guest.company ? ', ' : ''}{episode.guest.company}
                    </p>
                  )}
                  <div class="flex items-center gap-3 pt-1">
                    {episode.guest.linkedin && (
                      <a href={episode.guest.linkedin} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-sm text-ip-white-muted hover:text-white no-underline transition-colors">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                        LinkedIn
                      </a>
                    )}
                    {episode.guest.website && (
                      <a href={episode.guest.website} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-sm text-ip-white-muted hover:text-white no-underline transition-colors">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                        Website
                      </a>
                    )}
                  </div>
                </div>
              </div>
            )}

            <!-- Host card -->
            {episode.hostName && (
              <div class="flex items-start gap-3">
                {hostPhotoUrl ? (
                  <img src={hostPhotoUrl} alt={episode.hostName} class="w-10 h-10 rounded-full object-cover flex-shrink-0" />
                ) : (
                  <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0 text-white/40 font-display text-xs">
                    {episode.hostName.split(' ').map((n: string) => n[0]).join('')}
                  </div>
                )}
                <div class="space-y-0.5">
                  <p class="text-xs font-mono text-ip-white-muted uppercase tracking-wider">Host</p>
                  <p class="font-display text-sm text-white">{episode.hostName}</p>
                  {episode.hostRole && (
                    <p class="text-sm text-ip-white-muted">{episode.hostRole}</p>
                  )}
                  {episode.hostLinkedin && (
                    <a href={episode.hostLinkedin} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-sm text-ip-white-muted hover:text-white no-underline transition-colors pt-0.5">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                      LinkedIn
                    </a>
                  )}
                </div>
              </div>
            )}

            <!-- Table of Contents -->
            {tocItems.length > 0 && (
              <div>
                <p class="text-sm font-display text-ip-white-muted mb-3">Contents</p>
                <nav class="episode-toc-nav space-y-1">
                  {tocItems.map((item) => (
                    <a
                      href={`#${item.id}`}
                      class:list={[
                        "block no-underline transition-colors leading-snug text-sm",
                        item.level === 2 ? "text-white/70 hover:text-white" : "text-white/40 hover:text-white/70 pl-3",
                      ]}
                    >
                      {item.text}
                    </a>
                  ))}
                </nav>
              </div>
            )}
          </div>
        </aside>

        <!-- Right: episode content -->
        <div class="flex-1 min-w-0 pb-20 md:pb-32">

          <!-- Key Topics box -->
          {episode.keyTopics && episode.keyTopics.length > 0 && (
            <div class="bg-ip-navy-surface rounded-xl p-6 md:p-8 mb-10">
              <h2 class="font-display text-lg text-white mb-4">Key Topics</h2>
              <ul class="space-y-2">
                {episode.keyTopics.map((topic: string) => (
                  <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
                    <span class="text-ip-lime mt-0.5 flex-shrink-0">&#x2022;</span>
                    {topic}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Show notes body -->
          {bodyHtml && (
            <div class="episode-prose
              prose prose-lg prose-invert max-w-2xl
              prose-headings:font-display prose-headings:font-normal prose-headings:tracking-tight prose-headings:text-white
              prose-h2:text-3xl prose-h2:md:text-3xl prose-h2:leading-none prose-h2:mt-14 prose-h2:mb-6
              prose-h3:text-2xl prose-h3:leading-[1.0] prose-h3:mt-10 prose-h3:mb-4
              prose-p:text-white/80 prose-p:leading-relaxed prose-p:text-lg
              prose-a:text-ip-lime prose-a:underline prose-a:decoration-ip-lime/30 hover:prose-a:decoration-ip-lime
              prose-strong:text-white prose-strong:font-display-bold
              prose-em:text-white/90
              prose-li:text-white/80 prose-li:text-lg
              prose-blockquote:border-ip-lime/30 prose-blockquote:text-white/70 prose-blockquote:not-italic
              prose-figure:my-10 prose-img:rounded-lg
              prose-hr:border-white/10
            " set:html={bodyHtml} />
          )}

          <!-- Transcript (collapsible) -->
          {transcriptHtml && (
            <details class="mt-12 border border-white/10 rounded-xl overflow-hidden">
              <summary class="flex items-center gap-3 cursor-pointer px-6 py-4 bg-ip-navy-surface hover:bg-ip-navy-surface/80 transition-colors text-white font-display text-lg select-none">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform details-open:rotate-90 flex-shrink-0"><path d="M9 18l6-6-6-6"/></svg>
                Full Transcript
              </summary>
              <div class="episode-prose
                prose prose-base prose-invert max-w-none px-6 py-8
                prose-headings:font-display prose-headings:font-normal prose-headings:text-white
                prose-p:text-white/70 prose-p:leading-relaxed
                prose-strong:text-white prose-strong:font-display-bold
              " set:html={transcriptHtml} />
            </details>
          )}

          <!-- Email capture -->
          <div class="mt-16">
            <EmailCapture
              source="podcast-episode"
              heading="Don't miss the next conversation"
              description="We'll email you when new episodes drop. Conversations about coordination, execution, and the hidden costs of misalignment."
              buttonText="Subscribe"
              theme="dark"
            />
          </div>

          <!-- Bottom nav -->
          <div class="mt-10 pt-10 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-6">
            <a href="/podcast" class="text-ip-white-muted hover:text-white text-sm no-underline transition-colors flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
              Back to all episodes
            </a>
            <a href="/demo" class="btn-primary">
              Book a demo
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </article>

  <!-- ══════════════════════════════════════════════════
       Section 4 — About the Guest
       ══════════════════════════════════════════════════ -->
  {episode.guest?.name && episode.guest?.bio && (
    <section class="py-20 md:py-32 bg-ip-navy-light">
      <div class="container-ip max-w-5xl">
        <p class="section-eyebrow mb-4">About the guest</p>
        <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-start">
          {guestPhotoLargeUrl && (
            <img
              src={guestPhotoLargeUrl}
              alt={episode.guest.name}
              class="w-32 h-32 md:w-40 md:h-40 rounded-2xl object-cover flex-shrink-0"
            />
          )}
          <div>
            <h2 class="font-display text-2xl md:text-3xl text-white mb-2">{episode.guest.name}</h2>
            {(episode.guest.role || episode.guest.company) && (
              <p class="text-ip-lime font-display text-lg mb-4">
                {episode.guest.role}{episode.guest.role && episode.guest.company ? ', ' : ''}{episode.guest.company}
              </p>
            )}
            <p class="text-ip-white-muted text-lg leading-relaxed mb-6">{episode.guest.bio}</p>
            <div class="flex items-center gap-4">
              {episode.guest.linkedin && (
                <a href={episode.guest.linkedin} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-ip-white-muted hover:text-white no-underline transition-colors">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  LinkedIn
                </a>
              )}
              {episode.guest.website && (
                <a href={episode.guest.website} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-ip-white-muted hover:text-white no-underline transition-colors">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                  Website
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════════════════════
       Section 5 — Related Episodes
       ══════════════════════════════════════════════════ -->
  {relatedEpisodes.length > 0 && (
    <section class="py-20 md:py-32">
      <div class="container-ip max-w-5xl">
        <h2 class="font-display text-3xl md:text-5xl tracking-tight text-white mb-12">More episodes</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-10">
          {relatedEpisodes.map((rel: any) => (
            <a
              href={`/podcast/${rel.slug.current}`}
              class="group block no-underline rounded-xl -mx-4 px-4 py-4 hover:bg-ip-navy-surface"
              style="transition: background-color var(--motion-duration-smooth, 300ms) var(--motion-ease-out, ease-out)"
            >
              {rel.coverImage && (
                <div class="aspect-video rounded-lg overflow-hidden mb-4">
                  <img
                    src={urlFor(rel.coverImage).width(600).height(340).url()}
                    alt={rel.coverImage.alt || rel.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
              )}
              <div class="flex items-center gap-2 mb-2">
                {rel.season && rel.episodeNumber && (
                  <span class="font-mono text-ip-lime text-xs">S{rel.season}E{rel.episodeNumber}</span>
                )}
                {rel.themes && rel.themes.length > 0 && (
                  <span class="inline-block bg-ip-lime/10 text-ip-lime text-xs font-display px-2 py-0.5 rounded-full">{rel.themes[0]}</span>
                )}
              </div>
              <h3 class="font-display text-xl tracking-tight text-white group-hover:text-ip-lime transition-colors mb-2 leading-[1.0]">{rel.title}</h3>
              {rel.guestName && (
                <p class="text-ip-white-muted text-sm mb-1">with {rel.guestName}</p>
              )}
              {rel.description && (
                <p class="text-white/50 text-sm line-clamp-2 leading-relaxed">{rel.description}</p>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<script>
  // TOC active section highlighting
  const tocLinks = document.querySelectorAll('.episode-toc-nav a');
  const headings = document.querySelectorAll('.episode-prose h2, .episode-prose h3');

  if (tocLinks.length > 0 && headings.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => link.classList.remove('active'));
            const activeLink = document.querySelector(`.episode-toc-nav a[href="#${entry.target.id}"]`);
            if (activeLink) activeLink.classList.add('active');
          }
        });
      },
      { rootMargin: '-20% 0px -60% 0px' }
    );

    headings.forEach((h) => observer.observe(h));
  }
</script>

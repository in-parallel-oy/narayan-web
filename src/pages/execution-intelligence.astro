---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';

const modules = [
  {
    id: 'context-platform',
    number: '3.1',
    name: 'MCP Context Platform',
    tagline: 'APIs for AI agents',
    description: 'Turn In Parallel from a tool into infrastructure. The MCP Context Platform exposes structured execution context &mdash; decisions, priorities, ownership, risks &mdash; as APIs that any AI agent or LLM can consume.',
    capabilities: [
      'Structured context APIs for LLMs and agents',
      'Real-time execution state as a service',
      'Feed meeting intelligence into Copilot, Gemini, or custom agents',
      'Transform captured signals into programmable data',
    ],
    impact: 'Your AI tools get real context — what was decided, who owns it, and what changed — instead of working from a blank slate.',
    color: 'text-ip-lime',
    colorMuted: 'text-ip-lime/60',
  },
  {
    id: 'stakeholder-comms',
    number: '3.2',
    name: 'Stakeholder Communication Intelligence',
    tagline: 'Auto-generated, audience-tailored reporting',
    description: 'Stakeholders get what they need &mdash; without anyone writing a status report. Updates are generated from meeting signals and tailored to each audience.',
    capabilities: [
      'Auto-generate progress reports from meeting signals',
      'Tailor messaging to audience (board, team lead, PM)',
      'Continuous stakeholder updates without manual effort',
      'Exception-based reporting: only surface what changed',
    ],
    impact: 'Status meetings become unnecessary. Stakeholders stay informed without anyone spending time on update decks.',
    color: 'text-ip-cyan',
    colorMuted: 'text-ip-cyan/60',
  },
  {
    id: 'meeting-intelligence',
    number: '3.3',
    name: 'Meeting Intelligence',
    tagline: 'Real-time context surfacing',
    description: 'During the meeting, it surfaces context from past discussions, flags conflicts with prior decisions, and alerts when someone critical to the topic isn&rsquo;t in the room.',
    capabilities: [
      'In-meeting context from related past discussions',
      'Conflict detection: new proposals vs. prior decisions',
      'Missing-person alerts for critical decision topics',
      'Cross-meeting pattern recognition',
    ],
    impact: 'Meetings get smarter in real time. Old decisions stay settled. Teams build on them instead of re-litigating them.',
    color: 'text-ip-periwinkle',
    colorMuted: 'text-ip-periwinkle/60',
  },
  {
    id: 'continuous-intelligence',
    number: '3.4',
    name: 'Continuous Intelligence',
    tagline: 'Behavioral execution metrics',
    description: 'Measure how fast decisions get made, whether commitments follow through, and how quickly risks get resolved. Not at the quarterly review &mdash; continuously.',
    capabilities: [
      'Decision velocity — time from discussion to resolution',
      'Commitment follow-through rate by team and individual',
      'Risk resolution time — flagged to resolved',
      'Meeting effectiveness scoring',
    ],
    impact: 'Leadership sees execution health in real time, not through quarterly reviews. Problems surface before they compound.',
    color: 'text-amber-400',
    colorMuted: 'text-amber-400/60',
  },
  {
    id: 'risk-compliance',
    number: '3.5',
    name: 'Risk & Compliance Intelligence',
    tagline: 'Regulatory risk flags and audit trails',
    description: 'Flag discussions that touch regulatory requirements, maintain audit trails of decisions, and track compliance commitments across the organization.',
    capabilities: [
      'Regulatory risk flags from meeting discussions',
      'Decision provenance and audit trails',
      'Compliance commitment tracking',
      'Cross-organizational risk pattern detection',
    ],
    impact: 'Compliance stops being an afterthought. Audit trails are automatic. Regulatory risks surface when they&rsquo;re still cheap to address.',
    color: 'text-rose-400',
    colorMuted: 'text-rose-400/60',
  },
];
---

<BaseLayout
  navTheme="light"
  title="Execution Intelligence — In Parallel"
  description="Five intelligence modules that turn meeting signals into organizational insight. MCP Context Platform, Stakeholder Comms, Meeting Intelligence, Continuous Intelligence, and Risk & Compliance."
>
  <!-- Hero -->
  <section class="pt-32 pb-16 md:pt-44 md:pb-24 bg-white text-ip-navy">
    <div class="container-ip max-w-5xl">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 mb-4">
          <p class="section-eyebrow section-eyebrow--navy">The missing coordination layer from work</p>
          <span class="bg-ip-cyan text-ip-navy text-xs font-display px-3 py-1 rounded-full">Coming soon</span>
        </div>
        <h1 class="font-serif text-5xl md:text-7xl tracking-tight mb-6 text-ip-navy">
          Execution Intelligence.
        </h1>
        <p class="text-ip-navy/60 text-lg max-w-[52ch] mx-auto">
          Five modules that turn meeting signals into organizational intelligence &mdash; building up context across every conversation, not just summarizing each one.
        </p>
      </div>

    </div>

    <div class="container-ip mt-0 px-0 md:px-6 lg:px-8">
      <img
        src="/images/generated/execution-intelligence/execution-intelligence-1-light.png"
        alt="Team collaborating around a table reviewing project plans"
        class="w-full md:rounded-xl"
        width="1280"
        height="720"
        loading="eager"
      />
    </div>
  </section>

  <!-- Why not Copilot / Gemini -->
  <section class="py-20 md:py-32 bg-ip-navy text-white">
    <div class="container-ip max-w-5xl">
      <div class="text-center mb-16">
        <p class="section-eyebrow mb-4">The differentiation</p>
        <h2 class="font-serif text-4xl md:text-6xl tracking-tight mb-6">
          Why Copilot and Gemini can't do this.
        </h2>
        <p class="text-ip-white-muted text-lg max-w-[52ch] mx-auto">
          Generic AI assistants summarize one meeting at a time. In Parallel builds a persistent memory across every meeting &mdash; and turns that memory into intelligence.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
        <!-- Memory vs Moments -->
        <div class="bg-ip-navy-surface border border-white/10 rounded-xl p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-ip-lime/10 border border-ip-lime/20 flex items-center justify-center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-ip-lime"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="font-display text-lg">Memory vs. moments</h3>
          </div>
          <p class="text-ip-white-muted text-sm leading-relaxed mb-4">
            Copilot forgets the moment the meeting ends. In Parallel remembers every decision, every commitment, every priority shift &mdash; and connects them across weeks and months.
          </p>
          <div class="grid grid-cols-2 gap-4 text-xs">
            <div class="bg-white/5 rounded-lg p-3">
              <p class="text-white/30 mb-1">Generic AI</p>
              <p class="text-ip-white-muted">Single-meeting summary. Context dies when the tab closes.</p>
            </div>
            <div class="bg-ip-lime/5 border border-ip-lime/10 rounded-lg p-3">
              <p class="text-ip-lime/60 mb-1">In Parallel</p>
              <p class="text-ip-white-muted">Persistent memory. Every meeting adds to a growing execution context.</p>
            </div>
          </div>
        </div>

        <!-- Graph vs List -->
        <div class="bg-ip-navy-surface border border-white/10 rounded-xl p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-ip-cyan/10 border border-ip-cyan/20 flex items-center justify-center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-ip-cyan"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4M2 12h4m12 0h4m-3.5-6.5l-2.8 2.8m-5.4 5.4l-2.8 2.8m0-11l2.8 2.8m5.4 5.4l2.8 2.8"/></svg>
            </div>
            <h3 class="font-display text-lg">Graph vs. list</h3>
          </div>
          <p class="text-ip-white-muted text-sm leading-relaxed mb-4">
            Copilot gives you a list of bullet points. In Parallel builds a connected graph of decisions, ownership, dependencies, and risks &mdash; so every signal has context.
          </p>
          <div class="grid grid-cols-2 gap-4 text-xs">
            <div class="bg-white/5 rounded-lg p-3">
              <p class="text-white/30 mb-1">Generic AI</p>
              <p class="text-ip-white-muted">Flat text. Action items with no relationships or history.</p>
            </div>
            <div class="bg-ip-cyan/5 border border-ip-cyan/10 rounded-lg p-3">
              <p class="text-ip-cyan/60 mb-1">In Parallel</p>
              <p class="text-ip-white-muted">Connected graph. Decisions link to owners, risks, commitments, and outcomes.</p>
            </div>
          </div>
        </div>

        <!-- Intelligence vs Information -->
        <div class="bg-ip-navy-surface border border-white/10 rounded-xl p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-ip-periwinkle/10 border border-ip-periwinkle/20 flex items-center justify-center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-ip-periwinkle"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
            </div>
            <h3 class="font-display text-lg">Intelligence vs. information</h3>
          </div>
          <p class="text-ip-white-muted text-sm leading-relaxed mb-4">
            Copilot describes what happened. In Parallel predicts what will happen &mdash; flagging drift, stalled commitments, and emerging risks before they become problems.
          </p>
          <div class="grid grid-cols-2 gap-4 text-xs">
            <div class="bg-white/5 rounded-lg p-3">
              <p class="text-white/30 mb-1">Generic AI</p>
              <p class="text-ip-white-muted">Descriptive. Tells you what was said. You figure out what it means.</p>
            </div>
            <div class="bg-ip-periwinkle/5 border border-ip-periwinkle/10 rounded-lg p-3">
              <p class="text-ip-periwinkle/60 mb-1">In Parallel</p>
              <p class="text-ip-white-muted">Predictive. Flags what's drifting, stalling, or at risk before you ask.</p>
            </div>
          </div>
        </div>

        <!-- Compounding vs Static -->
        <div class="bg-ip-navy-surface border border-white/10 rounded-xl p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-amber-400/10 border border-amber-400/20 flex items-center justify-center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-amber-400"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <h3 class="font-display text-lg">Compounding vs. static</h3>
          </div>
          <p class="text-ip-white-muted text-sm leading-relaxed mb-4">
            Every meeting Copilot summarizes starts from zero. Every meeting In Parallel processes adds to a growing intelligence layer that gets smarter with each conversation.
          </p>
          <div class="grid grid-cols-2 gap-4 text-xs">
            <div class="bg-white/5 rounded-lg p-3">
              <p class="text-white/30 mb-1">Generic AI</p>
              <p class="text-ip-white-muted">Stateless. Meeting 100 is no smarter than meeting 1.</p>
            </div>
            <div class="bg-amber-400/5 border border-amber-400/10 rounded-lg p-3">
              <p class="text-amber-400/60 mb-1">In Parallel</p>
              <p class="text-ip-white-muted">Compounding. Every meeting makes the system more valuable.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- What this means for your team -->
      <div class="relative rounded-2xl overflow-hidden">
        <!-- Background image -->
        <div class="absolute inset-0">
          <img
            src="https://e-i.work/images/use-cases/engineering-leader.jpg"
            alt=""
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <!-- Dark overlay with gradient -->
          <div class="absolute inset-0 bg-gradient-to-r from-ip-navy/95 via-ip-navy/85 to-ip-navy/70"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-ip-navy/90 via-transparent to-ip-navy/60"></div>
        </div>

        <!-- Content -->
        <div class="relative z-10 p-8 md:p-14 lg:p-16">
          <div class="max-w-2xl">
            <p class="text-ip-lime text-xs font-display uppercase tracking-[0.2em] mb-4">What this means for your team</p>
            <h3 class="font-serif text-3xl md:text-4xl tracking-tight leading-tight text-white mb-10">
              Intelligence that compounds<br class="hidden md:block" />
              <span class="text-white/40">with every meeting.</span>
            </h3>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div class="group">
                <div class="flex items-center gap-3 mb-2">
                  <div class="w-8 h-8 rounded-lg bg-ip-lime/10 border border-ip-lime/20 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-ip-lime" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                  <h4 class="font-display text-sm text-white">No more status meetings</h4>
                </div>
                <p class="text-white/50 text-sm leading-relaxed pl-11">Stakeholders get tailored updates automatically &mdash; from the meetings that already happened.</p>
              </div>

              <div class="group">
                <div class="flex items-center gap-3 mb-2">
                  <div class="w-8 h-8 rounded-lg bg-ip-lime/10 border border-ip-lime/20 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-ip-lime" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                  <h4 class="font-display text-sm text-white">Problems surface early</h4>
                </div>
                <p class="text-white/50 text-sm leading-relaxed pl-11">Drift, stalled commitments, and forgotten risks are flagged before they compound.</p>
              </div>

              <div class="group">
                <div class="flex items-center gap-3 mb-2">
                  <div class="w-8 h-8 rounded-lg bg-ip-lime/10 border border-ip-lime/20 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-ip-lime" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                  <h4 class="font-display text-sm text-white">Your AI tools get context</h4>
                </div>
                <p class="text-white/50 text-sm leading-relaxed pl-11">Feed real execution data into Copilot, Gemini, or your own agents via structured APIs.</p>
              </div>

              <div class="group">
                <div class="flex items-center gap-3 mb-2">
                  <div class="w-8 h-8 rounded-lg bg-ip-lime/10 border border-ip-lime/20 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-ip-lime" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                  <h4 class="font-display text-sm text-white">Execution health at a glance</h4>
                </div>
                <p class="text-white/50 text-sm leading-relaxed pl-11">Decision velocity, commitment follow-through, and meeting effectiveness &mdash; measured continuously.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The 5 Modules -->
  <section class="py-20 md:py-32 bg-white text-ip-navy">
    <div class="container-ip max-w-5xl">
      <div class="text-center mb-16">
        <p class="section-eyebrow section-eyebrow--navy mb-4">Explore the five modules</p>
        <h2 class="font-serif text-4xl md:text-6xl tracking-tight mb-6 text-ip-navy">
          From signals to intelligence.
        </h2>
        <p class="text-ip-navy/60 text-lg max-w-[52ch] mx-auto">
          Each module takes what your meetings capture and turns it into something specific you can act on.
        </p>
      </div>

      <div class="space-y-6">
        {modules.map((mod) => (
          <div id={mod.id} class="border border-ip-navy/10 rounded-xl p-8 md:p-10 bg-white hover:border-ip-navy/20 transition-colors">
            <div class="flex flex-col md:flex-row md:items-start gap-6">
              <div class="flex-shrink-0">
                <span class={`font-serif text-3xl ${mod.color}`}>{mod.number}</span>
              </div>
              <div class="flex-1">
                <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
                  <h3 class="font-display text-xl text-ip-navy">{mod.name}</h3>
                  <span class="text-ip-navy/30 text-sm hidden sm:inline">&middot;</span>
                  <span class="text-ip-navy/40 text-sm">{mod.tagline}</span>
                </div>
                <p class="text-ip-navy/60 text-sm leading-relaxed mb-4" set:html={mod.description} />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <p class="font-display text-xs uppercase tracking-widest text-ip-navy/30 mb-3">Capabilities</p>
                    <ul class="space-y-2">
                      {mod.capabilities.map((cap) => (
                        <li class="flex items-start gap-2 text-ip-navy/50 text-xs">
                          <svg class={`w-3 h-3 ${mod.color} mt-0.5 flex-shrink-0`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
                          {cap}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div>
                    <p class="font-display text-xs uppercase tracking-widest text-ip-navy/30 mb-3">Impact</p>
                    <p class="text-ip-navy/60 text-sm leading-relaxed">{mod.impact}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 md:py-24 bg-ip-navy text-white">
    <div class="container-ip text-center">
      <h2 class="font-serif text-3xl md:text-5xl tracking-tight mb-4">Execution Intelligence is in early access.</h2>
      <p class="text-white/60 text-lg mb-8 max-w-[52ch] mx-auto">We&rsquo;re working with a small number of teams. Request a demo to see where things stand.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/demo" class="btn-primary">
          Request a private demo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/waitlist" class="btn-secondary">
          Start free with the notetaker
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

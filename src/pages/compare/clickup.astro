---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';

const faqItems = [
  {
    question: "Does In Parallel replace ClickUp for project management?",
    answer: "No. In Parallel is not a project management tool -- it is a coordination layer. It works alongside your existing PM tools (including ClickUp, Jira, Linear, and Asana) by syncing meeting decisions and execution plan updates bidirectionally. You keep ClickUp for task management; In Parallel ensures it stays current."
  },
  {
    question: "ClickUp has an AI Notetaker. How is In Parallel different?",
    answer: "ClickUp's AI Notetaker transcribes meetings and creates tasks within ClickUp. In Parallel does more: it understands the context of your execution plan and automatically updates goals, ownership, timelines, and status across all connected tools -- not just one. It is the difference between creating a task and updating a plan."
  },
  {
    question: "Can I use In Parallel and ClickUp together?",
    answer: "Yes. In Parallel integrates with project management tools to create a bidirectional sync between your meetings and your execution tools. Decisions from meetings flow into your tools, and progress in your tools flows back into the living execution plan."
  },
  {
    question: "Is In Parallel better for larger organizations than ClickUp?",
    answer: "In Parallel is designed for organizations where cross-team coordination is the bottleneck -- typically 50+ people or multiple teams working toward shared goals. ClickUp is a strong all-in-one PM tool for teams. In Parallel adds the coordination layer that connects teams, meetings, and tools into a single execution picture."
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "In Parallel vs ClickUp — Project Management vs Execution Intelligence",
    "description": "Compare In Parallel and ClickUp. ClickUp adds meeting transcription to PM. In Parallel adds intelligent execution management to your meetings and existing PM tools.",
    "url": "https://www.in-parallel.com/compare/clickup"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  }
];
---

<BaseLayout
  title="In Parallel vs ClickUp — Project Management vs Execution Intelligence"
  description="Compare In Parallel and ClickUp. ClickUp adds meeting transcription to PM. In Parallel adds intelligent execution management to your meetings and existing PM tools."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="pt-32 pb-16 md:pt-44 md:pb-24">
    <div class="container-ip max-w-4xl text-center">
      <a href="/compare" class="text-ip-white-muted text-sm font-display hover:text-ip-lime transition-colors inline-flex items-center gap-1 mb-6 scroll-reveal">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        All comparisons
      </a>
      <p class="text-ip-lime text-base mb-4 font-display scroll-reveal">Compare</p>
      <h1 class="font-serif text-5xl md:text-7xl tracking-tight leading-[1.05] mb-8 scroll-reveal">
        In Parallel vs ClickUp
      </h1>
      <p class="text-ip-white-muted text-lg md:text-xl max-w-2xl mx-auto scroll-reveal">
        ClickUp adds meeting transcription to project management. In Parallel adds intelligent execution management to your meetings and existing PM tools.
      </p>
    </div>
  </section>

  <!-- Quick Comparison Table -->
  <section class="pb-20 md:pb-32">
    <div class="container-ip max-w-4xl">
      <div class="scroll-reveal">
        <div class="bg-ip-navy-surface border border-ip-border rounded-xl overflow-hidden">
          <div class="grid grid-cols-3 border-b border-ip-border">
            <div class="p-4 md:p-6">
              <span class="text-ip-white-muted text-sm font-display">Capability</span>
            </div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border">
              <span class="font-display text-sm">In Parallel</span>
            </div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border">
              <span class="font-display text-sm text-ip-white-muted">ClickUp</span>
            </div>
          </div>
          <div class="grid grid-cols-3 border-b border-ip-border">
            <div class="p-4 md:p-6 text-sm text-ip-white-muted">Meeting capture</div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border"><span class="text-ip-lime text-sm">Yes</span></div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border"><span class="text-ip-lime text-sm">Yes (AI Notetaker)</span></div>
          </div>
          <div class="grid grid-cols-3 border-b border-ip-border">
            <div class="p-4 md:p-6 text-sm text-ip-white-muted">Living Execution Plan</div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border"><span class="text-ip-lime text-sm">Yes</span></div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border"><span class="text-ip-white-muted/50 text-sm">No (task boards)</span></div>
          </div>
          <div class="grid grid-cols-3 border-b border-ip-border">
            <div class="p-4 md:p-6 text-sm text-ip-white-muted">Cross-tool sync</div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border"><span class="text-ip-lime text-sm">Jira, Linear, Asana, Slack+</span></div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border"><span class="text-ip-white-muted text-sm">ClickUp-only</span></div>
          </div>
          <div class="grid grid-cols-3 border-b border-ip-border">
            <div class="p-4 md:p-6 text-sm text-ip-white-muted">Status automation</div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border"><span class="text-ip-lime text-sm">From meetings</span></div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border"><span class="text-ip-white-muted text-sm">Rule-based automations</span></div>
          </div>
          <div class="grid grid-cols-3 border-b border-ip-border">
            <div class="p-4 md:p-6 text-sm text-ip-white-muted">Approach</div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border"><span class="text-sm">Coordination layer</span></div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border"><span class="text-ip-white-muted text-sm">All-in-one PM</span></div>
          </div>
          <div class="grid grid-cols-3">
            <div class="p-4 md:p-6 text-sm text-ip-white-muted">Target user</div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border"><span class="text-sm">Managers & executives</span></div>
            <div class="p-4 md:p-6 text-center border-l border-ip-border"><span class="text-ip-white-muted text-sm">Teams of all sizes</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Differences -->
  <section class="py-20 md:py-32 bg-ip-navy-light">
    <div class="container-ip max-w-3xl">
      <div class="text-center mb-16">
        <p class="text-ip-lime text-base mb-4 font-display scroll-reveal">Key differences</p>
        <h2 class="font-display text-4xl md:text-5xl tracking-tight scroll-reveal">All-in-one PM vs coordination intelligence</h2>
      </div>

      <div class="space-y-16">
        <div class="scroll-reveal">
          <h3 class="font-display text-xl mb-3">Replace your tools vs connect your tools</h3>
          <p class="text-ip-white-muted text-lg leading-relaxed">
            ClickUp wants to replace all your tools with one platform -- tasks, docs, goals, chat, and now meeting transcription. In Parallel takes the opposite approach: keep the tools your teams already use and add a coordination layer that connects them through a living execution plan. No migration required.
          </p>
        </div>

        <div class="scroll-reveal">
          <h3 class="font-display text-xl mb-3">Task creation vs plan intelligence</h3>
          <p class="text-ip-white-muted text-lg leading-relaxed">
            ClickUp's AI Notetaker can transcribe meetings and create tasks within ClickUp. In Parallel understands the full context of your execution plan -- goals, dependencies, ownership, and timelines -- and updates all of it from meeting conversations. When a priority shifts in a meeting, the entire plan reflects it, across all connected tools.
          </p>
        </div>

        <div class="scroll-reveal">
          <h3 class="font-display text-xl mb-3">Platform dependency vs tool freedom</h3>
          <p class="text-ip-white-muted text-lg leading-relaxed">
            ClickUp's meeting features only work within ClickUp. If your engineering team uses Jira and your product team uses something else, ClickUp's meeting intelligence stays siloed. In Parallel syncs across all your tools, so decisions flow to wherever work actually happens.
          </p>
        </div>

        <div class="scroll-reveal">
          <h3 class="font-display text-xl mb-3">Bottom-up task management vs top-down execution visibility</h3>
          <p class="text-ip-white-muted text-lg leading-relaxed">
            ClickUp excels at granular task management -- lists, boards, timelines, and Gantt charts. In Parallel focuses on the execution picture that managers and executives need: are we on track? What changed? What decisions were made? This is the layer between strategy and task-level work that most organizations are missing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- When to choose -->
  <section class="py-20 md:py-32">
    <div class="container-ip max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-8 scroll-reveal">
          <h3 class="font-display text-xl mb-4">When to choose ClickUp</h3>
          <ul class="space-y-3 text-ip-white-muted text-base leading-relaxed">
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block w-1.5 h-1.5 rounded-full bg-ip-white-muted/50 flex-shrink-0"></span>
              You want to consolidate all work management into a single platform
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block w-1.5 h-1.5 rounded-full bg-ip-white-muted/50 flex-shrink-0"></span>
              Your team needs detailed task management with boards, lists, and Gantt charts
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block w-1.5 h-1.5 rounded-full bg-ip-white-muted/50 flex-shrink-0"></span>
              You are a small-to-medium team that can standardize on one tool
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block w-1.5 h-1.5 rounded-full bg-ip-white-muted/50 flex-shrink-0"></span>
              Meeting transcription within your PM tool is sufficient for your needs
            </li>
          </ul>
        </div>
        <div class="bg-ip-navy-surface border border-ip-lime/30 rounded-xl p-8 scroll-reveal">
          <h3 class="font-display text-xl mb-4 text-ip-lime">When to choose In Parallel</h3>
          <ul class="space-y-3 text-ip-white-muted text-base leading-relaxed">
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block w-1.5 h-1.5 rounded-full bg-ip-lime flex-shrink-0"></span>
              Your teams use different tools and you need a layer that connects them
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block w-1.5 h-1.5 rounded-full bg-ip-lime flex-shrink-0"></span>
              Meeting decisions need to update your execution plan automatically
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block w-1.5 h-1.5 rounded-full bg-ip-lime flex-shrink-0"></span>
              Managers spend hours on status updates and tool reconciliation
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block w-1.5 h-1.5 rounded-full bg-ip-lime flex-shrink-0"></span>
              You need execution visibility at the organizational level, not just the task level
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 md:py-32 bg-ip-navy-light">
    <div class="container-ip max-w-3xl">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl md:text-5xl tracking-tight scroll-reveal">Frequently asked questions</h2>
      </div>
      <div class="space-y-8">
        {faqItems.map((item) => (
          <div class="scroll-reveal">
            <h3 class="font-display text-lg mb-3">{item.question}</h3>
            <p class="text-ip-white-muted text-base leading-relaxed">{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-32">
    <div class="container-ip text-center">
      <h2 class="font-serif text-4xl md:text-6xl tracking-tight mb-6 scroll-reveal">
        Add intelligence to your execution.
      </h2>
      <p class="text-ip-white-muted text-lg max-w-2xl mx-auto mb-10 scroll-reveal">
        See how In Parallel connects your meetings and tools into a living execution plan. 30-minute demo.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 scroll-reveal">
        <a href="/demo" class="btn-lime">
          Book a demo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/compare" class="btn-outline">
          See all comparisons
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import CompareNav from '../../components/CompareNav.astro';

const faqItems = [
  {
    question: "Can In Parallel handle stand-ups and sprint ceremonies like Spinach?",
    answer: "Yes. In Parallel joins any meeting -- stand-ups, sprint planning, retros, or leadership syncs -- and captures decisions, action items, and ownership changes. But unlike Spinach, it does not stop at ceremony facilitation. It maps every outcome onto a living execution plan and syncs it to your project tools."
  },
  {
    question: "Is Spinach better for agile teams?",
    answer: "Spinach is specifically designed for agile ceremonies in small engineering teams. If your only need is better stand-up facilitation with Jira ticket summaries, Spinach is purpose-built for that. In Parallel is designed for broader organizational coordination -- including agile teams, but also product, leadership, and cross-functional meetings."
  },
  {
    question: "Does In Parallel work with Jira and Linear like Spinach does?",
    answer: "Yes. In Parallel offers bidirectional sync with Jira, Linear, Asana, and Slack. Decisions from meetings update your tickets and plans automatically, and progress in your tools flows back into the execution plan. Spinach primarily summarizes existing Jira tickets during stand-ups."
  },
  {
    question: "Can I use In Parallel for just my engineering team?",
    answer: "You can, but In Parallel becomes more valuable as more teams connect to it. It is designed for organizations where coordination across teams is the bottleneck. If your need is limited to engineering stand-ups, Spinach may be a lighter-weight option. If you need cross-team execution coordination, In Parallel is the better fit."
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "In Parallel vs Spinach — Sprint Ceremonies vs Organization-Wide Coordination",
    "description": "Compare In Parallel and Spinach. Spinach is an AI scrum master for stand-ups. In Parallel is a coordination layer for the entire organization.",
    "url": "https://www.in-parallel.com/compare/spinach"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  }
];
---

<BaseLayout
  title="In Parallel vs Spinach — Sprint Ceremonies vs Organization-Wide Coordination"
  description="Compare In Parallel and Spinach. Spinach is an AI scrum master for stand-ups. In Parallel is a coordination layer for the entire organization."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="pt-32 pb-20 md:pt-44 md:pb-32 min-h-[80vh] flex items-center text-ip-navy" style="background-color: #F3F5F2;">
    <div class="container-ip">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">
        <div class="lg:w-[380px] flex-shrink-0">
          <p class="section-eyebrow section-eyebrow--navy mb-2 scroll-reveal">Compare to</p>
          <h1 class="font-display text-6xl md:text-7xl tracking-tight leading-[1.1] mb-4 scroll-reveal">
            Spinach
          </h1>
          <p class="font-display text-lg md:text-xl text-ip-navy/60 scroll-reveal">
            Instead of running smarter stand-ups, In Parallel connects every stand-up to the execution plan.
          </p>
          <p class="font-display text-lg md:text-xl text-ip-navy/60 mt-3 scroll-reveal">
            Where Spinach works for agile teams in sprints, In Parallel coordinates the whole organization.
          </p>
        </div>
        <div class="flex-1 min-w-0">
          <div class="bg-white border border-ip-navy/15 rounded-xl overflow-hidden">
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6"><span class="text-ip-navy/40 text-sm font-display">Capability</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="font-display text-sm">In Parallel</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="font-display text-sm text-ip-navy/40">Spinach</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Meeting types</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">All meeting types</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/50 text-sm">Sprint ceremonies</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Living Execution Plan</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Yes</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/30 text-sm">No</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Tool sync</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Bidirectional</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/50 text-sm">Reads Jira tickets</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Status automation</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Yes</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/30 text-sm">No</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Scope</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Organization-wide</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/50 text-sm">Single team</span></div>
            </div>
            <div class="grid grid-cols-3">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Target user</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-sm">Managers & executives</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/50 text-sm">Scrum teams</span></div>
            </div>
          </div>
        </div>
      </div>
      <CompareNav current="spinach" theme="light" compact={true} />
    </div>
  </section>

  <!-- Key Differences -->
  <section class="py-20 md:py-32 bg-ip-navy-light">
    <div class="container-ip max-w-5xl">
      <div class="text-center mb-16">
        <p class="section-eyebrow mb-4 scroll-reveal">What are the key differences?</p>
        <h2 class="font-display text-3xl md:text-5xl tracking-tight scroll-reveal">One team's ceremonies vs the whole organization</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 scroll-reveal flex flex-col">
          <h3 class="font-display text-base mb-3">Sprint ceremonies vs all meetings</h3>
          <p class="text-ip-white-muted text-sm leading-relaxed">
            Spinach is built for agile ceremonies -- stand-ups, sprint planning, retrospectives. It facilitates those specific meeting types and summarizes Jira ticket status. In Parallel joins any meeting type -- from team stand-ups to leadership syncs to cross-functional planning sessions -- and captures execution-relevant decisions from all of them.
          </p>
        </div>

        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 scroll-reveal flex flex-col">
          <h3 class="font-display text-base mb-3">Ticket summaries vs execution plan updates</h3>
          <p class="text-ip-white-muted text-sm leading-relaxed">
            Spinach reads your Jira tickets and provides summaries during stand-ups. In Parallel writes back to your tools. When a decision changes ownership, shifts a timeline, or reprioritizes work, In Parallel updates Jira, Linear, Asana, and Slack automatically. The flow is bidirectional, not read-only.
          </p>
        </div>

        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 scroll-reveal flex flex-col">
          <h3 class="font-display text-base mb-3">Team-level facilitation vs organizational coordination</h3>
          <p class="text-ip-white-muted text-sm leading-relaxed">
            Spinach operates at the team level -- one scrum team's ceremonies. In Parallel operates at the organizational level. It connects decisions across teams, projects, and leadership layers into a single living execution plan. When Product reprioritizes a feature in a planning meeting, Engineering and Sales see the change immediately.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- When to choose -->
  <section class="py-20 md:py-32 bg-ip-navy">
    <div class="container-ip max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-ip-navy-surface rounded-xl p-8 scroll-reveal flex flex-col justify-between min-h-[480px]">
          <h3 class="font-display text-xl mb-4 text-ip-white-muted">When to choose Spinach</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full border border-ip-white-muted/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-white-muted/40"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </span>
              You need a lightweight AI facilitator for agile stand-ups
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full border border-ip-white-muted/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-white-muted/40"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </span>
              Your team wants Jira ticket summaries during ceremonies
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full border border-ip-white-muted/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-white-muted/40"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </span>
              You work within a single scrum team and don't need cross-team coordination
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full border border-ip-white-muted/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-white-muted/40"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </span>
              Sprint ceremony facilitation is the specific problem you are solving
            </li>
          </ul>
        </div>
        <div class="bg-ip-lime/5 border-2 border-ip-lime rounded-xl p-8 scroll-reveal flex flex-col justify-between min-h-[480px]">
          <h3 class="font-display text-xl mb-4 text-ip-lime">When to choose In Parallel</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full bg-ip-lime/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-lime"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              You need coordination across multiple teams, not just one scrum team
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full bg-ip-lime/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-lime"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              Meeting decisions should automatically update your project tools and execution plan
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full bg-ip-lime/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-lime"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              You have leadership, product, and cross-functional meetings -- not just stand-ups
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full bg-ip-lime/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-lime"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              Managers need a living execution plan, not just meeting summaries
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 md:py-32 bg-ip-navy-light">
    <div class="container-ip max-w-3xl">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-5xl tracking-tight scroll-reveal">Frequently asked questions</h2>
      </div>
      <div class="space-y-8">
        {faqItems.map((item) => (
          <div class="scroll-reveal">
            <h3 class="font-display text-lg mb-3">{item.question}</h3>
            <p class="text-ip-white-muted text-base leading-relaxed">{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-32 bg-ip-navy">
    <div class="container-ip text-center">
      <h2 class="font-serif text-3xl md:text-6xl tracking-tight mb-6 scroll-reveal">
        Coordinate the whole organization.
      </h2>
      <p class="text-ip-white-muted text-lg max-w-2xl mx-auto mb-10 scroll-reveal">
        See how In Parallel goes beyond sprint ceremonies to coordinate execution across your entire organization. 30-minute demo.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 scroll-reveal">
        <a href="/demo" class="btn-primary">
          Book a demo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/compare" class="btn-secondary">
          See all comparisons
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
  <CompareNav current="spinach" />
</BaseLayout>

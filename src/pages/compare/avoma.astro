---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import CompareNav from '../../components/CompareNav.astro';
import { getCompetitor } from '../../data/competitors';

const competitor = getCompetitor('avoma')!;

const faqItems = [
  {
    question: "Can In Parallel replace Avoma for meeting intelligence?",
    answer: "It depends on your use case. Avoma is built for revenue teams — call recording, deal intelligence, and coaching. In Parallel is built for execution coordination — turning meeting decisions into an auto-updating plan across teams and tools. If your primary need is sales intelligence, Avoma is the better fit. If you need organizational coordination, choose In Parallel."
  },
  {
    question: "How do the AI capabilities compare?",
    answer: "Avoma uses AI for conversation intelligence — topic tracking, talk-time analysis, scoring, and coaching insights. In Parallel uses AI for execution intelligence — extracting decisions, ownership changes, and risks, then mapping them onto your execution plan. Different AI for different outcomes."
  },
  {
    question: "Does In Parallel work for revenue teams?",
    answer: "In Parallel integrates with Salesforce and HubSpot and can capture customer-facing meetings. But its primary strength is cross-functional coordination — connecting meeting outcomes from sales, product, engineering, and leadership into a shared execution plan. For deep revenue intelligence, Avoma is more focused."
  },
  {
    question: "How does pricing compare?",
    answer: "Avoma charges per user with tiered plans starting around $19/user/month. In Parallel's AI notetaker is free forever. The Living Plan starts at €69 per execution scope per month. Most teams see payback within the first week from saved coordination time."
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "In Parallel vs Avoma — Revenue Intelligence vs Execution Intelligence",
    "description": "Compare In Parallel and Avoma. Avoma focuses on revenue intelligence. In Parallel turns meeting signals into a living execution plan for your entire organization.",
    "url": "https://www.in-parallel.com/compare/avoma"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  }
];
---

<BaseLayout
  title="In Parallel vs Avoma — Revenue Intelligence vs Execution Intelligence"
  description="Compare In Parallel and Avoma. Avoma focuses on revenue intelligence. In Parallel turns meeting signals into a living execution plan for your entire organization."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="pt-32 pb-20 md:pt-44 md:pb-32 min-h-[80vh] flex items-center text-ip-navy" style="background-color: #F3F5F2;">
    <div class="container-ip">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">
        <div class="lg:w-[380px] flex-shrink-0">
          <p class="section-eyebrow section-eyebrow--navy mb-4 scroll-reveal">Compare to</p>
          <div class="flex items-center gap-4 mb-4 scroll-reveal">
            <div class="w-12 h-12 flex-shrink-0 flex items-center justify-center overflow-hidden" style={`background: ${competitor.logoBg}; border-radius: 22%;`}>
              {competitor.logoSvg ? (
                <Fragment set:html={competitor.logoSvg} />
              ) : (
                <img src={`https://www.google.com/s2/favicons?domain=${competitor.domain}&sz=128`} alt={`${competitor.name} logo`} class="w-full h-full object-cover" loading="eager" />
              )}
            </div>
            <h1 class="font-display text-6xl md:text-7xl tracking-tight leading-[1.1]">
            Avoma
          </h1>
          </div>
          <p class="font-display text-lg md:text-xl text-ip-navy/60 scroll-reveal">
            Instead of revenue intelligence for sales calls, In Parallel is execution intelligence for the whole organization.
          </p>
          <p class="font-display text-lg md:text-xl text-ip-navy/60 mt-3 scroll-reveal">
            Where Avoma tells you what was said to prospects, In Parallel tells you whether decisions are being followed across teams.
          </p>
        </div>
        <div class="flex-1 min-w-0">
          <div class="overflow-x-auto -mx-4 sm:mx-0 px-4 sm:px-0">
          <div class="bg-white border border-ip-navy/15 rounded-xl overflow-hidden min-w-[480px]">
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6"><span class="text-ip-navy/40 text-sm font-display">Capability</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="font-display text-sm">In Parallel</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="font-display text-sm text-ip-navy/40">Avoma</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Meeting capture</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Yes</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Yes</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Living Execution Plan</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Yes</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/30 text-sm">No</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Revenue intelligence</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/50 text-sm">CRM integration</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Yes (strong)</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">PM tool sync</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Bidirectional</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/30 text-sm">No</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Cross-meeting intelligence</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Yes</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/50 text-sm">Deal-focused</span></div>
            </div>
            <div class="grid grid-cols-3">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Target user</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-sm">Managers & leaders</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/50 text-sm">Revenue teams</span></div>
            </div>
          </div>
          </div>
        </div>
      </div>
      <CompareNav current="avoma" theme="light" compact={true} />
    </div>
  </section>

  <!-- Key Differences -->
  <section class="py-20 md:py-32 bg-ip-navy-light">
    <div class="container-ip max-w-5xl">
      <div class="text-center mb-16">
        <p class="section-eyebrow mb-4 scroll-reveal">What are the key differences?</p>
        <h2 class="font-display text-3xl md:text-5xl tracking-tight scroll-reveal">Revenue intelligence vs execution intelligence.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 scroll-reveal flex flex-col">
          <h3 class="font-display text-base mb-3">Deal tracking vs plan coordination</h3>
          <p class="text-ip-white-muted text-sm leading-relaxed">
            Avoma tracks conversations through a revenue lens — deal stages, buyer signals, win/loss patterns, coaching opportunities. In Parallel tracks conversations through an execution lens — decisions, ownership, timelines, risks, and commitments. One optimizes your pipeline. The other coordinates your entire organization.
          </p>
        </div>

        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 scroll-reveal flex flex-col">
          <h3 class="font-display text-base mb-3">Conversation analytics vs execution state</h3>
          <p class="text-ip-white-muted text-sm leading-relaxed">
            Avoma gives you conversation analytics — talk-time ratios, topic tracking, sentiment scoring. In Parallel gives you execution state — a living picture of what's on track, what's drifting, who owns what, and where commitments have stalled. One helps you analyze calls. The other keeps your plan current.
          </p>
        </div>

        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 scroll-reveal flex flex-col">
          <h3 class="font-display text-base mb-3">Sales-first vs coordination-first</h3>
          <p class="text-ip-white-muted text-sm leading-relaxed">
            Avoma is built around the sales cycle — discovery calls, demos, negotiations. In Parallel is built around the execution cycle — planning meetings, standups, steering committees, cross-team syncs. Different meetings. Different intelligence. Choose based on which cycle drives your outcomes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- When to choose -->
  <section class="py-20 md:py-32">
    <div class="container-ip max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-ip-navy-surface rounded-xl p-8 scroll-reveal flex flex-col justify-between min-h-0 sm:min-h-[480px]">
          <h3 class="font-display text-xl mb-4 text-ip-white-muted">When to choose Avoma</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full border border-ip-white-muted/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-white-muted/40"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </span>
              Your primary need is revenue intelligence and deal tracking
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full border border-ip-white-muted/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-white-muted/40"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </span>
              You need conversation analytics for sales coaching
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full border border-ip-white-muted/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-white-muted/40"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </span>
              Most of your meetings are customer-facing sales calls
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full border border-ip-white-muted/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-white-muted/40"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </span>
              You want automated CRM updates from call insights
            </li>
          </ul>
        </div>
        <div class="bg-ip-lime/5 border-2 border-ip-lime rounded-xl p-8 scroll-reveal flex flex-col justify-between min-h-0 sm:min-h-[480px]">
          <h3 class="font-display text-xl mb-4 text-ip-lime">When to choose In Parallel</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full bg-ip-lime/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-lime"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              You need meetings to automatically update your execution plan
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full bg-ip-lime/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-lime"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              Your bottleneck is cross-team coordination, not sales performance
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full bg-ip-lime/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-lime"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              You want bidirectional sync with PM tools (Jira, Linear, Asana)
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full bg-ip-lime/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-lime"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              Managers spend hours reconciling meeting outcomes across tools and teams
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 md:py-32 bg-ip-navy-light">
    <div class="container-ip max-w-3xl">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-5xl tracking-tight scroll-reveal">Frequently asked questions</h2>
      </div>
      <div class="space-y-8">
        {faqItems.map((item) => (
          <div class="scroll-reveal">
            <h3 class="font-display text-lg mb-3">{item.question}</h3>
            <p class="text-ip-white-muted text-base leading-relaxed">{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-32">
    <div class="container-ip text-center">
      <h2 class="font-serif text-3xl md:text-6xl tracking-tight mb-6 scroll-reveal">
        Go beyond revenue intelligence.
      </h2>
      <p class="text-ip-white-muted text-lg max-w-2xl mx-auto mb-10 scroll-reveal">
        Start free with the AI notetaker. See how In Parallel turns meetings into organizational execution. 30-minute demo.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 scroll-reveal">
        <a href="/demo" class="btn-primary">
          Book a demo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/compare" class="btn-secondary">
          See all comparisons
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
  <CompareNav current="avoma" />
</BaseLayout>

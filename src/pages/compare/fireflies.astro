---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import CompareNav from '../../components/CompareNav.astro';

const faqItems = [
  {
    question: "Can In Parallel replace Fireflies.ai for meeting transcription?",
    answer: "Yes. In Parallel captures meeting conversations, decisions, and action items automatically. While Fireflies focuses on producing searchable transcripts, In Parallel goes further by using meeting intelligence to update your living execution plan and sync changes to your project tools."
  },
  {
    question: "Does In Parallel offer the same transcription quality as Fireflies?",
    answer: "In Parallel captures meeting content with a focus on extracting decisions, ownership changes, and action items -- the elements that matter for execution. If your primary need is verbatim transcripts for compliance or legal purposes, Fireflies may be a better fit. If your goal is turning meeting conversations into execution, In Parallel is purpose-built for that."
  },
  {
    question: "How does In Parallel's tool integration differ from Fireflies?",
    answer: "Fireflies can create Jira tickets or push action items to project tools. In Parallel offers bidirectional sync -- changes from meetings flow into tools like Jira, Linear, Asana, and Slack, and changes in those tools flow back into the execution plan. This keeps everything in sync automatically."
  },
  {
    question: "Is In Parallel suitable for large organizations with many meetings?",
    answer: "In Parallel is built for organizations where coordination across teams is the bottleneck. The more meetings and teams connected to the system, the more valuable it becomes -- because every meeting updates the same shared execution plan. This is where Fireflies' per-meeting approach reaches its limits."
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "In Parallel vs Fireflies — Transcripts vs Coordination Intelligence",
    "description": "Compare In Parallel and Fireflies.ai. Fireflies gives you transcripts and action items. In Parallel understands your execution plan and updates it from every meeting.",
    "url": "https://www.in-parallel.com/compare/fireflies"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  }
];
---

<BaseLayout
  title="In Parallel vs Fireflies — Transcripts vs Coordination Intelligence"
  description="Compare In Parallel and Fireflies.ai. Fireflies gives you transcripts and action items. In Parallel understands your execution plan and updates it from every meeting."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="pt-32 pb-20 md:pt-44 md:pb-32 min-h-[80vh] flex items-center text-ip-navy" style="background-color: #F3F5F2;">
    <div class="container-ip">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">
        <div class="lg:w-[380px] flex-shrink-0">
          <p class="section-eyebrow section-eyebrow--navy mb-2 scroll-reveal">Compare to</p>
          <h1 class="font-display text-6xl md:text-7xl tracking-tight leading-[1.1] mb-4 scroll-reveal">
            Fireflies
          </h1>
          <p class="font-display text-lg md:text-xl text-ip-navy/60 scroll-reveal">
            Instead of transcribing your meetings, In Parallel turns them into execution.
          </p>
          <p class="font-display text-lg md:text-xl text-ip-navy/60 mt-3 scroll-reveal">
            Where Fireflies gives you a searchable record, In Parallel gives you the next version of your plan.
          </p>
        </div>
        <div class="flex-1 min-w-0">
          <div class="overflow-x-auto -mx-4 sm:mx-0 px-4 sm:px-0">
          <div class="bg-white border border-ip-navy/15 rounded-xl overflow-hidden min-w-[480px]">
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6"><span class="text-ip-navy/40 text-sm font-display">Capability</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="font-display text-sm">In Parallel</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="font-display text-sm text-ip-navy/40">Fireflies</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Meeting capture</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Yes</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Yes (strong)</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Living Execution Plan</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Yes</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/30 text-sm">No</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Tool sync</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Bidirectional</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/50 text-sm">Creates tickets</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Status automation</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Yes</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/30 text-sm">No</span></div>
            </div>
            <div class="grid grid-cols-3 border-b border-ip-navy/10">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Strategic alignment</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy font-medium text-sm">Yes</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/30 text-sm">No</span></div>
            </div>
            <div class="grid grid-cols-3">
              <div class="p-4 md:p-6 text-sm text-ip-navy/50">Target user</div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-sm">Managers & leaders</span></div>
              <div class="p-4 md:p-6 text-center border-l border-ip-navy/10"><span class="text-ip-navy/50 text-sm">Anyone in meetings</span></div>
            </div>
          </div>
          </div>
        </div>
      </div>
      <CompareNav current="fireflies" theme="light" compact={true} />
    </div>
  </section>

  <!-- Key Differences -->
  <section class="py-20 md:py-32 bg-ip-navy-light">
    <div class="container-ip max-w-5xl">
      <div class="text-center mb-16">
        <p class="section-eyebrow mb-4 scroll-reveal">What are the key differences?</p>
        <h2 class="font-display text-3xl md:text-5xl tracking-tight scroll-reveal">Transcripts capture the past. Coordination shapes the future.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 scroll-reveal flex flex-col">
          <h3 class="font-display text-base mb-3">Transcript vs execution context</h3>
          <p class="text-ip-white-muted text-sm leading-relaxed">
            Fireflies produces a searchable, timestamped transcript of every meeting. It is excellent at capturing what was said. In Parallel captures what matters for execution -- decisions, ownership changes, timeline shifts, and blocked items -- and maps them directly onto your execution plan.
          </p>
        </div>

        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 scroll-reveal flex flex-col">
          <h3 class="font-display text-base mb-3">Ticket creation vs plan-aware sync</h3>
          <p class="text-ip-white-muted text-sm leading-relaxed">
            Fireflies can create Jira tickets from action items. But creating a ticket is not the same as updating a plan. In Parallel understands the structure of your execution plan and updates goals, milestones, ownership, and status across your connected tools -- bidirectionally.
          </p>
        </div>

        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 scroll-reveal flex flex-col">
          <h3 class="font-display text-base mb-3">Meeting memory vs organizational awareness</h3>
          <p class="text-ip-white-muted text-sm leading-relaxed">
            Fireflies gives you a record of past meetings that you can search. In Parallel gives you a living picture of your current execution state -- one that updates itself from every meeting and reflects reality across teams and projects. One helps you remember. The other helps you deliver.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- When to choose -->
  <section class="py-20 md:py-32 bg-ip-navy">
    <div class="container-ip max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-ip-navy-surface rounded-xl p-8 scroll-reveal flex flex-col justify-between min-h-0 sm:min-h-[480px]">
          <h3 class="font-display text-xl mb-4 text-ip-white-muted">When to choose Fireflies</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full border border-ip-white-muted/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-white-muted/40"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </span>
              You need high-quality verbatim transcripts for compliance or documentation
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full border border-ip-white-muted/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-white-muted/40"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </span>
              Your main need is searchable meeting archives
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full border border-ip-white-muted/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-white-muted/40"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </span>
              You want a lightweight AI notetaker for any meeting participant
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full border border-ip-white-muted/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-white-muted/40"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </span>
              Execution plan management is handled by a separate workflow
            </li>
          </ul>
        </div>
        <div class="bg-ip-lime/5 border-2 border-ip-lime rounded-xl p-8 scroll-reveal flex flex-col justify-between min-h-0 sm:min-h-[480px]">
          <h3 class="font-display text-xl mb-4 text-ip-lime">When to choose In Parallel</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full bg-ip-lime/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-lime"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              You need meeting conversations to automatically update your execution plan
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full bg-ip-lime/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-lime"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              Managers are spending hours manually reconciling meeting outcomes with project tools
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full bg-ip-lime/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-lime"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              You need bidirectional sync between meetings and Jira, Linear, Asana, or Slack
            </li>
            <li class="flex items-start gap-3 text-ip-white-muted text-sm leading-relaxed">
              <span class="mt-0.5 w-5 h-5 rounded-full bg-ip-lime/20 flex items-center justify-center flex-shrink-0">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-ip-lime"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              Your organization needs a coordination layer, not just a transcription tool
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 md:py-32 bg-ip-navy-light">
    <div class="container-ip max-w-3xl">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-5xl tracking-tight scroll-reveal">Frequently asked questions</h2>
      </div>
      <div class="space-y-8">
        {faqItems.map((item) => (
          <div class="scroll-reveal">
            <h3 class="font-display text-lg mb-3">{item.question}</h3>
            <p class="text-ip-white-muted text-base leading-relaxed">{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-32 bg-ip-navy">
    <div class="container-ip text-center">
      <h2 class="font-serif text-3xl md:text-6xl tracking-tight mb-6 scroll-reveal">
        Go beyond transcripts.
      </h2>
      <p class="text-ip-white-muted text-lg max-w-2xl mx-auto mb-10 scroll-reveal">
        See how In Parallel turns meeting conversations into execution. 30-minute demo.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 scroll-reveal">
        <a href="/demo" class="btn-primary">
          Book a demo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/compare" class="btn-secondary">
          See all comparisons
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
  <CompareNav current="fireflies" />
</BaseLayout>

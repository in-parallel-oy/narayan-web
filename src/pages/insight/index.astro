---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { sanityClient, urlFor } from '../../lib/sanity';

const insights = await sanityClient.fetch(`
  *[_type == "insight"] | order(date desc) {
    _id,
    title,
    slug,
    description,
    date,
    category,
    image,
    "authorName": author->name,
    "authorPhoto": author->photo
  }
`);

const featured = insights.length > 0 ? insights[0] : null;
const remaining = insights.length > 1 ? insights.slice(1) : [];
---

<BaseLayout title="Between the Lines — In Parallel" description="Articles and insights on execution intelligence, team management, and enterprise AI." navTheme="light">

  <!-- Hero -->
  <section class="pt-36 pb-12 md:pt-48 md:pb-16 text-ip-navy" style="background-color: #F3F5F2;">
    <div class="container-ip max-w-5xl">
      <p class="section-eyebrow section-eyebrow--navy mb-4 scroll-reveal">Our insights</p>
      <h1 class="scroll-reveal max-w-3xl">
        <span class="block font-serif text-6xl md:text-8xl lg:text-9xl tracking-tight leading-[0.85] text-ip-navy">
          The gap between
        </span>
        <span class="block font-serif text-6xl md:text-8xl lg:text-9xl tracking-tight leading-[0.85] text-ip-navy/20 mt-1">
          plan &amp; reality.
        </span>
      </h1>
      <p class="text-ip-navy/50 text-lg max-w-xl mt-8 scroll-reveal leading-relaxed [hyphens:none]">
        Our blog, Between the Lines, examines the space between what organizations decide and what actually happens. Stay tuned for research, case studies, and points of view on execution, management, and the future of how work gets done.
      </p>
    </div>
  </section>

  <!-- Featured post -->
  {featured && (
    <section class="pb-16 md:pb-20 text-ip-navy" style="background-color: #F3F5F2;">
      <div class="container-ip max-w-5xl">
        <div class="md:border-t border-ip-navy/10 pt-10 md:pt-12 scroll-reveal">
          <a href={`/insight/${featured.slug.current}`} class="group block no-underline rounded-2xl -mx-6 px-6 py-6 hover:bg-white"
            style="transition: background-color var(--motion-duration-smooth) var(--motion-ease-out)">
            {featured.image && (
              <div id="featured-img-wrap" class="h-[75vh] md:h-auto md:aspect-[21/8] rounded-xl overflow-hidden mb-8 mt-6 md:mt-0"
                style="transition: margin var(--motion-duration-smooth) var(--motion-ease-out), border-radius var(--motion-duration-smooth) var(--motion-ease-out);">
                <img
                  src={urlFor(featured.image).width(1200).height(500).url()}
                  alt={featured.image.alt || featured.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                />
              </div>
            )}
            <div class="flex items-center gap-3 mb-4">
              {featured.category && (
                <span class="inline-block bg-ip-blue/10 text-ip-blue text-xs font-display px-3 py-1 rounded-full">{featured.category}</span>
              )}
              {featured.date && (
                <span class="text-ip-navy/30 text-xs">&middot;</span>
              )}
              {featured.date && (
                <time class="text-ip-navy/40 text-xs">
                  {new Date(featured.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              )}
            </div>
            <h2 class="font-display text-2xl md:text-4xl tracking-tight max-w-3xl mb-4 text-ip-navy group-hover:text-ip-navy-surface transition-colors">{featured.title}</h2>
            {featured.description && (
              <p class="text-ip-navy/60 text-base md:text-lg max-w-2xl leading-relaxed">{featured.description}</p>
            )}
            <div class="mt-6 inline-flex items-center gap-2 text-ip-blue text-sm font-display">
              Read article
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Remaining posts grid -->
  {remaining.length > 0 && (
    <section class="pb-20 md:pb-32 text-ip-navy" style="background-color: #F3F5F2;">
      <div class="container-ip max-w-5xl">
        <div class="border-t border-ip-navy/10 pt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
          {remaining.map((post: any) => (
            <a href={`/insight/${post.slug.current}`} class="group block no-underline scroll-reveal rounded-xl -mx-4 px-4 py-4 hover:bg-white"
              style="transition: background-color var(--motion-duration-smooth) var(--motion-ease-out)">
              {post.image && (
                <div class="aspect-video rounded-lg overflow-hidden mb-5">
                  <img
                    src={urlFor(post.image).width(600).height(340).url()}
                    alt={post.image.alt || post.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
              )}
              <div class="flex items-center gap-2 mb-2">
                {post.category && (
                  <span class="inline-block bg-ip-blue/10 text-ip-blue text-xs font-display px-3 py-1 rounded-full">{post.category}</span>
                )}
                {post.date && (
                  <span class="text-ip-navy/30 text-xs">&middot;</span>
                )}
                {post.date && (
                  <time class="text-ip-navy/40 text-xs">
                    {new Date(post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                )}
              </div>
              <h2 class="font-display text-2xl tracking-tight text-ip-navy group-hover:text-ip-navy-surface transition-colors mb-2 leading-[1.0]">{post.title}</h2>
              {post.description && (
                <p class="text-ip-navy/55 text-sm line-clamp-3 leading-relaxed">{post.description}</p>
              )}
              {post.authorName && (
                <div class="flex items-center gap-2 mt-4">
                  {post.authorPhoto ? (
                    <img src={urlFor(post.authorPhoto).width(24).height(24).url()} alt={post.authorName} class="w-5 h-5 rounded-full object-cover" />
                  ) : (
                    <div class="w-5 h-5 rounded-full bg-ip-navy/10 flex items-center justify-center text-ip-navy/40 text-[8px] font-display">
                      {post.authorName.split(' ').map((n: string) => n[0]).join('')}
                    </div>
                  )}
                  <span class="text-ip-navy/40 text-xs">{post.authorName}</span>
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {insights.length === 0 && (
    <section class="py-20 md:py-32 text-ip-navy" style="background-color: #F3F5F2;">
      <div class="container-ip text-center">
        <p class="text-ip-navy/50 text-lg">No insights published yet. Check back soon.</p>
      </div>
    </section>
  )}

  <!-- Email capture -->
  <section class="py-20 md:py-32 text-ip-navy border-t border-ip-navy/10" style="background-color: #F3F5F2;">
    <div class="container-ip max-w-2xl">
      <EmailCapture
        source="insight-listing"
        heading="Stay in the loop"
        description="Get insights on execution intelligence delivered to your inbox. No spam, one email per week."
        buttonText="Subscribe"
        theme="light"
      />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-32 bg-ip-navy">
    <div class="container-ip text-center">
      <p class="text-ip-white-muted text-lg mb-6">Want to see the coordination layer in action?</p>
      <a href="/demo" class="btn-primary">
        Book a demo
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  // Featured image: expand to full viewport width on mobile when 80% visible, reverse on exit
  if (window.innerWidth < 768) {
    const wrap = document.getElementById('featured-img-wrap');
    if (wrap) {
      const THRESHOLD = 0.85;
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const full = entry.intersectionRatio >= THRESHOLD;
            wrap.style.marginLeft   = full ? '-2rem' : '';
            wrap.style.marginRight  = full ? '-2rem' : '';
            wrap.style.borderRadius = full ? '0' : '';
          });
        },
        { threshold: [THRESHOLD - 0.01, THRESHOLD] }
      );
      observer.observe(wrap);
    }
  }
</script>

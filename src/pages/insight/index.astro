---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { sanityClient, urlFor } from '../../lib/sanity';

const insights = await sanityClient.fetch(`
  *[_type == "insight"] | order(date desc) {
    _id,
    title,
    slug,
    description,
    date,
    category,
    image,
    "authorName": author->name,
    "authorPhoto": author->photo
  }
`);

const featured = insights.length > 0 ? insights[0] : null;
const remaining = insights.length > 1 ? insights.slice(1) : [];
---

<BaseLayout title="Between the Lines — In Parallel" description="Articles and insights on execution intelligence, team management, and enterprise AI.">
  <!-- Hero header -->
  <section class="pt-32 pb-12 md:pt-44 md:pb-16 relative overflow-hidden">
    <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full bg-ip-lime/[0.02] blur-[120px] pointer-events-none"></div>
    <div class="container-ip text-center">
      <p class="section-eyebrow mb-4 scroll-reveal">Between the lines</p>
      <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl tracking-tight mb-6 scroll-reveal">Insights</h1>
      <p class="text-ip-white-muted text-lg max-w-2xl mx-auto scroll-reveal">
        Perspectives on execution intelligence, how teams actually work, and why the gap between your plan and reality keeps growing.
      </p>
    </div>
  </section>

  <!-- Featured post -->
  {featured && (
    <section class="pb-12 md:pb-20">
      <div class="container-ip max-w-5xl">
        <a href={`/insight/${featured.slug.current}`} class="group block no-underline scroll-reveal">
          <div class="relative rounded-2xl overflow-hidden border border-ip-border bg-ip-navy-surface card-elevated">
            {featured.image && (
              <div class="aspect-[21/9] md:aspect-[21/8]">
                <img
                  src={urlFor(featured.image).width(1200).height(500).url()}
                  alt={featured.image.alt || featured.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-ip-navy via-ip-navy/60 to-transparent"></div>
              </div>
            )}
            <div class={`${featured.image ? 'absolute bottom-0 left-0 right-0' : ''} p-8 md:p-12`}>
              <div class="flex items-center gap-3 mb-4">
                {featured.category && (
                  <span class="text-ip-lime text-xs font-display uppercase tracking-wider">{featured.category}</span>
                )}
                {featured.date && (
                  <span class="text-white/30 text-xs">&middot;</span>
                )}
                {featured.date && (
                  <time class="text-white/40 text-xs">
                    {new Date(featured.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                )}
              </div>
              <h2 class="font-serif text-3xl md:text-5xl tracking-tight leading-tight mb-4 text-white group-hover:text-ip-lime transition-colors">{featured.title}</h2>
              {featured.description && (
                <p class="text-white/60 text-base md:text-lg max-w-2xl leading-relaxed">{featured.description}</p>
              )}
              <div class="mt-6 inline-flex items-center gap-2 text-ip-lime text-sm font-display">
                Read article
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- Remaining posts grid -->
  {remaining.length > 0 && (
    <section class="pb-20 md:pb-32">
      <div class="container-ip max-w-5xl">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {remaining.map((post: any) => (
            <a href={`/insight/${post.slug.current}`} class="group block no-underline scroll-reveal">
              <div class="bg-ip-navy-surface border border-ip-border rounded-xl overflow-hidden card-elevated hover:border-ip-lime/20 transition-all h-full flex flex-col">
                {post.image && (
                  <div class="aspect-video relative overflow-hidden">
                    <img
                      src={urlFor(post.image).width(600).height(340).url()}
                      alt={post.image.alt || post.title}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-ip-navy-surface via-transparent to-transparent opacity-60"></div>
                  </div>
                )}
                <div class="p-6 flex flex-col flex-1">
                  <div class="flex items-center gap-3 mb-3">
                    {post.category && (
                      <span class="text-ip-lime/70 text-xs font-display uppercase tracking-wider">{post.category}</span>
                    )}
                  </div>
                  <h2 class="font-display text-base mb-2 text-white group-hover:text-ip-lime transition-colors leading-snug">{post.title}</h2>
                  {post.description && (
                    <p class="text-ip-white-muted text-sm line-clamp-2 leading-relaxed flex-1">{post.description}</p>
                  )}
                  <div class="flex items-center gap-3 mt-4 pt-4 border-t border-ip-border">
                    {post.authorName && (
                      <div class="flex items-center gap-2">
                        {post.authorPhoto ? (
                          <img src={urlFor(post.authorPhoto).width(24).height(24).url()} alt={post.authorName} class="w-5 h-5 rounded-full object-cover" />
                        ) : (
                          <div class="w-5 h-5 rounded-full bg-ip-lime/10 flex items-center justify-center text-ip-lime text-[8px] font-display">
                            {post.authorName.split(' ').map((n: string) => n[0]).join('')}
                          </div>
                        )}
                        <span class="text-white/40 text-xs">{post.authorName}</span>
                      </div>
                    )}
                    {post.date && (
                      <time class="text-white/30 text-xs ml-auto">
                        {new Date(post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                      </time>
                    )}
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {insights.length === 0 && (
    <section class="pb-32">
      <div class="container-ip text-center py-20">
        <p class="text-ip-white-muted text-lg">No insights published yet. Check back soon.</p>
      </div>
    </section>
  )}

  <!-- Email capture -->
  <section class="py-16 md:py-24">
    <div class="container-ip max-w-2xl">
      <EmailCapture
        source="insight-listing"
        heading="Stay in the loop"
        description="Get insights on execution intelligence delivered to your inbox. No spam, one email per week."
        buttonText="Subscribe"
        theme="dark"
      />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-ip-navy-light">
    <div class="container-ip text-center">
      <p class="text-ip-white-muted text-lg mb-6">Want to see the coordination layer in action?</p>
      <a href="/demo" class="btn-primary">
        Book a demo
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>

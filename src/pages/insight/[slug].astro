---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { sanityClient, urlFor } from '../../lib/sanity';
import { toHTML } from '@portabletext/to-html';

export const prerender = true;

export async function getStaticPaths() {
  const insights = await sanityClient.fetch(`
    *[_type == "insight"] { slug }
  `);
  return insights.map((post: any) => ({
    params: { slug: post.slug.current },
  }));
}

const { slug } = Astro.params;

const [post, relatedPosts] = await Promise.all([
  sanityClient.fetch(
    `*[_type == "insight" && slug.current == $slug][0] {
      _id,
      title,
      subtitle,
      slug,
      description,
      date,
      category,
      body,
      image,
      "authorName": author->name,
      "authorRole": author->role,
      "authorPhoto": author->photo,
      "authorEmail": author->email,
      "authorLinkedin": author->linkedin
    }`,
    { slug }
  ),
  sanityClient.fetch(
    `*[_type == "insight" && slug.current != $slug] | order(date desc) {
      _id,
      title,
      slug,
      description,
      date,
      category,
      image,
      "authorName": author->name,
      "authorPhoto": author->photo
    }`,
    { slug }
  ),
]);

if (!post) {
  return Astro.redirect('/404');
}

// ── Portable Text → HTML (with heading IDs for TOC) ──
let headingIndex = 0;
const tocItems: { id: string; text: string; level: number }[] = [];

function stripHtml(html: string): string {
  return html
    .replace(/<[^>]*>/g, '')
    .replace(/&#x27;/g, "'")
    .replace(/&#x2019;/g, "\u2019")
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#(\d+);/g, (_, n) => String.fromCharCode(Number(n)))
    .replace(/&#x([0-9a-fA-F]+);/g, (_, h) => String.fromCharCode(parseInt(h, 16)));
}

const portableTextComponents = {
  block: {
    h2: ({ children }: { children: string }) => {
      const id = `section-${headingIndex++}`;
      tocItems.push({ id, text: stripHtml(children), level: 2 });
      return `<h2 id="${id}">${children}</h2>`;
    },
    h3: ({ children }: { children: string }) => {
      const id = `section-${headingIndex++}`;
      tocItems.push({ id, text: stripHtml(children), level: 3 });
      return `<h3 id="${id}">${children}</h3>`;
    },
  },
  types: {
    image: ({ value }: { value: any }) => {
      const src = urlFor(value).width(800).url();
      const alt = value.alt || '';
      const caption = value.caption || '';
      const figcaption = caption ? `<figcaption>${caption}</figcaption>` : '';
      return `<figure><img src="${src}" alt="${alt}" />${figcaption}</figure>`;
    },
    youtube: ({ value }: { value: any }) => {
      const url = value.url || '';
      return `<div class="aspect-video my-8"><iframe src="${url}" class="w-full h-full rounded-lg" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>`;
    },
  },
};

const bodyHtml = post.body ? toHTML(post.body, { components: portableTextComponents }) : '';

const ogImage = post.image ? urlFor(post.image).width(1200).height(630).url() : undefined;
const authorPhotoUrl = post.authorPhoto ? urlFor(post.authorPhoto).width(96).height(96).url() : null;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.title,
    "description": post.description || '',
    ...(post.image && { "image": urlFor(post.image).width(1200).url() }),
    ...(post.date && { "datePublished": post.date }),
    ...(post.authorName && { "author": { "@type": "Person", "name": post.authorName } }),
    "publisher": {
      "@type": "Organization",
      "name": "In Parallel",
      "logo": { "@type": "ImageObject", "url": "https://www.in-parallel.com/favicon.png" }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://www.in-parallel.com/insight/${post.slug.current}`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.in-parallel.com" },
      { "@type": "ListItem", "position": 2, "name": "Insights", "item": "https://www.in-parallel.com/insight" },
      { "@type": "ListItem", "position": 3, "name": post.title }
    ]
  }
];
---

<BaseLayout
  title={`${post.title} - In Parallel`}
  description={post.description}
  ogType="article"
  publishedTime={post.date}
  ogImage={ogImage}
  jsonLd={jsonLd}
  navTheme="light"
>
  <article class="insight-article bg-white text-ip-navy">
    <!-- ── Header: breadcrumb + title + subtitle + cover image ── -->
    <header class="pt-32 pb-8 md:pt-44 md:pb-12">
      <div class="container-ip max-w-5xl">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-ip-navy/50 mb-10" aria-label="Breadcrumb">
          <a href="/insight" class="hover:text-ip-navy no-underline transition-colors">Insight</a>
          <span class="opacity-40">→</span>
          <span class="text-ip-navy/80 font-display truncate max-w-[400px]">{post.title}</span>
        </nav>

        {post.category && (
          <span class="inline-block bg-ip-blue/10 text-ip-blue text-xs font-display px-3 py-1 rounded-full mb-6">{post.category}</span>
        )}

        <h1 class="font-display text-3xl md:text-6xl lg:text-7xl tracking-tight leading-[1.05] mb-6 text-ip-navy">{post.title}</h1>

        {post.subtitle && (
          <p class="text-xl md:text-2xl text-ip-navy/70 leading-relaxed max-w-3xl">{post.subtitle}</p>
        )}
      </div>
    </header>

    <!-- ── Cover Image ── -->
    {post.image && (
      <div class="container-ip max-w-5xl mb-12">
        <div class="max-h-[680px] overflow-hidden rounded-xl">
          <img
            src={urlFor(post.image).width(1200).height(680).url()}
            alt={post.image.alt || post.title}
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    )}

    <!-- ── Two-column body: sidebar (sticky) + content ── -->
    <div class="container-ip max-w-5xl">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">

        <!-- Left sidebar (sticky) -->
        <aside class="lg:w-72 flex-shrink-0">
          <div class="lg:sticky lg:top-28 space-y-8 mb-[10em]">

            <!-- Published date -->
            {post.date && (
              <div class="flex items-baseline gap-4">
                <span class="text-sm text-ip-navy/50 font-display">Published</span>
                <time class="text-sm text-ip-navy">
                  {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
            )}

            <!-- Author card -->
            {post.authorName && (
              <div class="flex items-start gap-4">
                {authorPhotoUrl ? (
                  <img src={authorPhotoUrl} alt={post.authorName} class="w-12 h-12 rounded-full object-cover flex-shrink-0" />
                ) : (
                  <div class="w-12 h-12 rounded-full bg-ip-navy/10 flex items-center justify-center flex-shrink-0 text-ip-navy/40 font-display text-sm">
                    {post.authorName.split(' ').map((n: string) => n[0]).join('')}
                  </div>
                )}
                <div class="space-y-0.5">
                  <p class="font-display text-sm text-ip-navy">{post.authorName}</p>
                  {post.authorRole && (
                    <p class="text-sm text-ip-navy/50">{post.authorRole}</p>
                  )}
                  {post.authorEmail && (
                    <p class="text-sm text-ip-navy/50">{post.authorEmail}</p>
                  )}
                  {post.authorLinkedin && (
                    <a href={post.authorLinkedin} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-sm text-ip-navy/50 hover:text-ip-navy no-underline transition-colors">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                      LinkedIn
                    </a>
                  )}
                </div>
              </div>
            )}

            <!-- Table of Contents -->
            {tocItems.length > 0 && (
              <div>
                <p class="text-sm font-display text-ip-navy mb-3">Contents</p>
                <nav class="toc-nav space-y-1">
                  {tocItems.map((item) => (
                    <a
                      href={`#${item.id}`}
                      class:list={[
                        "block no-underline transition-colors leading-snug text-sm",
                        item.level === 2 ? "text-ip-navy/70 hover:text-ip-navy" : "text-ip-navy/50 hover:text-ip-navy/70 pl-3",
                      ]}
                    >
                      {item.text}
                    </a>
                  ))}
                </nav>
              </div>
            )}
          </div>
        </aside>

        <!-- Right: article body -->
        <div class="flex-1 min-w-0 pb-20 md:pb-32">
          <div class="insight-prose
            prose prose-lg max-w-2xl
            prose-headings:font-display prose-headings:font-normal prose-headings:tracking-tight prose-headings:text-ip-navy
            prose-h2:text-3xl prose-h2:md:text-3xl prose-h2:leading-none prose-h2:mt-14 prose-h2:mb-6
            prose-h3:text-2xl prose-h3:leading-[1.0] prose-h3:mt-10 prose-h3:mb-4
            prose-p:text-ip-navy/80 prose-p:leading-relaxed prose-p:text-lg
            prose-a:text-ip-blue prose-a:underline prose-a:decoration-ip-blue/30 hover:prose-a:decoration-ip-blue
            prose-strong:text-ip-navy prose-strong:font-display-bold
            prose-em:text-ip-navy/90
            prose-li:text-ip-navy/80 prose-li:text-lg
            prose-blockquote:border-ip-navy/20 prose-blockquote:text-ip-navy/70 prose-blockquote:not-italic
            prose-figure:my-10 prose-img:rounded-lg
            prose-hr:border-ip-navy/10
          " set:html={bodyHtml} />

          <!-- Email capture -->
          <div class="mt-16">
            <EmailCapture
              source="blog-article"
              heading="Get insights like this in your inbox"
              description="One email per week on execution intelligence, team coordination, and enterprise AI. No fluff."
              buttonText="Subscribe"
              theme="light"
            />
          </div>

          <!-- Bottom CTA -->
          <div class="mt-10 pt-10 border-t border-ip-navy/10 flex flex-col sm:flex-row items-center justify-between gap-6">
            <a href="/insight" class="text-ip-navy/50 hover:text-ip-navy text-sm no-underline transition-colors flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
              Back to all insights
            </a>
            <a href="/demo" class="btn-primary">
              Book a demo
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </article>

  <!-- ── Related articles ── -->
  {relatedPosts.length > 0 && (
    <section class="bg-ip-light-bg py-20 md:py-32 border-t border-ip-navy/10 text-ip-navy">
      <div class="container-ip max-w-5xl">
        <h2 class="font-display text-3xl md:text-6xl lg:text-7xl tracking-tight leading-[1.05] text-ip-navy mb-12">Related articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-10" id="related-grid">
          {relatedPosts.map((rel: any, i: number) => (
            <a
              href={`/insight/${rel.slug.current}`}
              class:list={["group block no-underline rounded-xl -mx-4 px-4 py-4 hover:bg-white", { hidden: i >= 10 }]}
              style="transition: background-color var(--motion-duration-smooth) var(--motion-ease-out)"
            >
              {rel.image && (
                <div class="aspect-video rounded-lg overflow-hidden mb-4">
                  <img
                    src={urlFor(rel.image).width(600).height(340).url()}
                    alt={rel.image.alt || rel.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
              )}
              <div class="flex items-center gap-2 mb-2">
                {rel.category && (
                  <span class="inline-block bg-ip-blue/10 text-ip-blue text-xs font-display px-3 py-1 rounded-full">{rel.category}</span>
                )}
                {rel.date && <span class="text-ip-navy/30 text-xs">&middot;</span>}
                {rel.date && (
                  <time class="text-ip-navy/40 text-xs">
                    {new Date(rel.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                )}
              </div>
              <h3 class="font-display text-xl tracking-tight text-ip-navy group-hover:text-ip-navy-surface transition-colors mb-2 leading-[1.0]">{rel.title}</h3>
              {rel.description && (
                <p class="text-ip-navy/55 text-sm line-clamp-2 leading-relaxed">{rel.description}</p>
              )}
            </a>
          ))}
        </div>
        {relatedPosts.length > 10 && (
          <div class="mt-10 text-center" id="load-more-wrap">
            <button
              id="load-more-btn"
              class="text-sm font-display text-ip-navy/50 hover:text-ip-navy transition-colors border border-ip-navy/15 hover:border-ip-navy/30 rounded-full px-6 py-2"
            >
              Load more
            </button>
          </div>
        )}
      </div>
    </section>
  )}

</BaseLayout>

<script>
  // Load more related articles
  const loadMoreBtn = document.getElementById('load-more-btn');
  const loadMoreWrap = document.getElementById('load-more-wrap');
  if (loadMoreBtn && loadMoreWrap) {
    loadMoreBtn.addEventListener('click', () => {
      const hidden = document.querySelectorAll('#related-grid a.hidden');
      hidden.forEach((el) => el.classList.remove('hidden'));
      loadMoreWrap.remove();
    });
  }
</script>

<script>
  // TOC active section highlighting
  const tocLinks = document.querySelectorAll('.toc-nav a');
  const headings = document.querySelectorAll('.insight-prose h2, .insight-prose h3');

  if (tocLinks.length > 0 && headings.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => link.classList.remove('active'));
            const activeLink = document.querySelector(`.toc-nav a[href="#${entry.target.id}"]`);
            if (activeLink) activeLink.classList.add('active');
          }
        });
      },
      { rootMargin: '-20% 0px -60% 0px' }
    );

    headings.forEach((h) => observer.observe(h));
  }
</script>

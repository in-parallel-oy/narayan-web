---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sanityClient, urlFor } from '../../lib/sanity';
import { toHTML } from '@portabletext/to-html';

export const prerender = true;

export async function getStaticPaths() {
  const insights = await sanityClient.fetch(`
    *[_type == "insight"] { slug }
  `);
  return insights.map((post: any) => ({
    params: { slug: post.slug.current },
  }));
}

const { slug } = Astro.params;
const post = await sanityClient.fetch(
  `*[_type == "insight" && slug.current == $slug][0] {
    _id,
    title,
    subtitle,
    slug,
    description,
    date,
    category,
    body,
    image,
    "authorName": author->name
  }`,
  { slug }
);

if (!post) {
  return Astro.redirect('/404');
}

const portableTextComponents = {
  types: {
    image: ({ value }: { value: any }) => {
      const src = urlFor(value).width(800).url();
      const alt = value.alt || '';
      const caption = value.caption || '';
      const figcaption = caption ? '<figcaption>' + caption + '</figcaption>' : '';
      return '<figure><img src="' + src + '" alt="' + alt + '" />' + figcaption + '</figure>';
    },
    youtube: ({ value }: { value: any }) => {
      const url = value.url || '';
      return '<div class="aspect-video my-8"><iframe src="' + url + '" class="w-full h-full rounded-lg" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>';
    },
  },
};

const bodyHtml = post.body ? toHTML(post.body, { components: portableTextComponents }) : '';

const ogImage = post.image ? urlFor(post.image).width(1200).height(630).url() : undefined;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.title,
    "description": post.description || '',
    ...(post.image && { "image": urlFor(post.image).width(1200).url() }),
    ...(post.date && { "datePublished": post.date }),
    ...(post.authorName && { "author": { "@type": "Person", "name": post.authorName } }),
    "publisher": {
      "@type": "Organization",
      "name": "In Parallel",
      "logo": { "@type": "ImageObject", "url": "https://www.in-parallel.com/favicon.png" }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://www.in-parallel.com/insight/${post.slug.current}`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.in-parallel.com" },
      { "@type": "ListItem", "position": 2, "name": "Insights", "item": "https://www.in-parallel.com/insight" },
      { "@type": "ListItem", "position": 3, "name": post.title }
    ]
  }
];
---

<BaseLayout
  title={`${post.title} - In Parallel`}
  description={post.description}
  ogType="article"
  publishedTime={post.date}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <article class="pt-32 pb-20 md:pt-44 md:pb-32">
    <div class="container-ip max-w-3xl">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-ip-white-muted mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white no-underline transition-colors">Home</a>
        <span class="opacity-40">/</span>
        <a href="/insight" class="hover:text-white no-underline transition-colors">Insights</a>
        <span class="opacity-40">/</span>
        <span class="text-white/60 truncate max-w-[200px]">{post.title}</span>
      </nav>

      {post.category && (
        <span class="text-ip-lime text-xs font-display uppercase tracking-wider">{post.category}</span>
      )}
      <h1 class="font-serif text-4xl md:text-6xl tracking-tight mt-2 mb-4">{post.title}</h1>
      {post.subtitle && (
        <p class="text-xl text-ip-white-muted mb-6">{post.subtitle}</p>
      )}
      <div class="flex items-center gap-4 text-ip-white-muted text-sm mb-12">
        {post.authorName && <span>{post.authorName}</span>}
        {post.date && (
          <time>
            {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        )}
      </div>

      {post.image && (
        <img src={urlFor(post.image).width(800).url()} alt={post.image.alt || post.title} class="w-full rounded-xl shadow-ip-card mb-12" />
      )}

      <div class="prose prose-invert prose-lg max-w-none
        prose-headings:font-display prose-headings:tracking-tight
        prose-a:text-ip-lime prose-a:no-underline hover:prose-a:underline
        prose-strong:text-white
      " set:html={bodyHtml} />

      <!-- Bottom CTA -->
      <div class="mt-16 pt-12 border-t border-ip-border flex flex-col sm:flex-row items-center justify-between gap-6">
        <a href="/insight" class="text-ip-white-muted hover:text-white text-sm no-underline transition-colors flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Back to all insights
        </a>
        <a href="/demo" class="btn-lime">
          Book a demo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

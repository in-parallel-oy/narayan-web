---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="White Papers - In Parallel" description="Research and thought leadership on execution intelligence.">
  <section class="pt-32 pb-20 md:pt-44 md:pb-32">
    <div class="container-ip">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">

        <!-- Left: heading + copy -->
        <div class="lg:w-[380px] flex-shrink-0">
          <p class="section-eyebrow mb-4">Want proof?</p>
          <h1 class="font-display text-4xl md:text-5xl tracking-tight mb-6">Read the research.</h1>
          <p class="text-ip-white-muted text-lg leading-relaxed">
            40% of manager time is spent on coordination overhead, not the actual work. We've built the research to prove it, and the product to fix it.
          </p>
        </div>

        <!-- Right: white papers widget -->
        <div class="flex-1 min-w-0">
          <div class="rounded-xl overflow-hidden border border-ip-border bg-ip-navy-surface">
            <iframe
              src="https://collaborate.in-parallel.com/whitepapers"
              class="w-full border-0"
              style="min-height: 700px;"
              title="Download In Parallel white papers"
              loading="lazy"
              allow="clipboard-write"
            ></iframe>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

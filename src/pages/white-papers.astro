---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="White Papers - In Parallel" description="Research and thought leadership on execution intelligence.">
  <section class="pt-32 pb-20 md:pt-44 md:pb-32">
    <div class="container-ip">
      <h1 class="font-serif text-5xl md:text-7xl tracking-tight mb-12">White papers</h1>

      <!-- White paper cards placeholder -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl">
        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6">
          <p class="text-ip-white-muted text-sm">White paper content will be migrated from Framer CMS.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

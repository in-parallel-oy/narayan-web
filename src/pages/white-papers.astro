---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';

const SUPABASE_URL = 'https://jkzjuxubbespjheduhfh.supabase.co';
const SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Impremp1eHViYmVzcGpoZWR1aGZoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Njc2MjU4MjQsImV4cCI6MjA4MzIwMTgyNH0.QIG3eQEOqqV_EgOPnC_jz_cnLseiDn4qf_0IupLRP9U';
const h = { apikey: SUPABASE_ANON, Authorization: `Bearer ${SUPABASE_ANON}` };

// Papers defined locally — thumbnails and titles live here.
// Only the PDF download URL is fetched from Supabase at build time.
const localPapers = [
  {
    title: 'The End of Management — as we know it',
    blurb: 'The current model of management is ending. This paper makes the case for why, what replaces it, and the four shifts that separate organizations that compound from those that stall.',
    buttonText: 'Download the white paper',
    thumbnail: '/images/whitepapers/end-of-management.png',
    documentId: '1007d1b8-296c-4515-b2b2-3d7df1466670',
  },
  {
    title: 'In Parallel — Company Overview',
    blurb: 'What In Parallel is, what we build, and why. Covers our product, our convictions, what customers experience, and where we\'re headed.',
    buttonText: 'Download the overview',
    thumbnail: '/images/whitepapers/company-overview.png',
    documentId: '279d1bc3-1363-4861-9072-f3935fed7355',
  },
  {
    title: 'The ROI of Better Management',
    blurb: 'Most organizations have €50–70M of recoverable value per 1,000 employees locked in coordination overhead. This one-pager shows where it lives and what Year-1 capture looks like.',
    buttonText: 'Download the one-pager',
    thumbnail: '/images/whitepapers/roi-of-better-management.png',
    documentId: '343e1340-499c-4de1-99b2-35ad053cb9b5',
  },
  {
    title: 'Security & Technical Overview',
    blurb: 'EU-only architecture, end-to-end encryption, ISO 27001 / SOC 2 Type II / ISO 42001 — and your data never trains our models. For security teams and procurement.',
    buttonText: 'Download the security overview',
    thumbnail: '/images/whitepapers/security-and-technology.png',
    documentId: '6a9d6c7c-4602-44bd-bdd8-f181879d8f04',
  },
];

// Fetch only file_url + file_size for download buttons
let docsData: any[] = [];
try {
  const ids = localPapers.map((p) => p.documentId).join(',');
  const res = await fetch(
    `${SUPABASE_URL}/rest/v1/documents?id=in.(${ids})&select=id,file_url,file_size`,
    { headers: h }
  );
  docsData = await res.json().catch(() => []);
} catch (e) {
  console.warn('White papers: Supabase fetch failed', e);
}

interface Paper {
  title: string;
  blurb: string;
  buttonText: string;
  thumbnail: string;
  fileUrl: string;
  fileSize: number;
}

const papers: Paper[] = localPapers.map((p) => {
  const doc = docsData.find((d) => d.id === p.documentId) ?? {};
  return {
    title: p.title,
    blurb: p.blurb,
    buttonText: p.buttonText,
    thumbnail: p.thumbnail,
    fileUrl: doc.file_url ?? '',
    fileSize: doc.file_size ?? 0,
  };
});

function formatSize(bytes: number): string {
  if (bytes >= 1024 * 1024) return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
  return `${Math.round(bytes / 1024)} KB`;
}
---

<BaseLayout title="White Papers - In Parallel" description="Research and thought leadership on execution intelligence.">
  <section class="pt-32 pb-20 md:pt-44 md:pb-32">
    <div class="container-ip">
      <!-- Heading + preface -->
      <div class="mb-20">
        <p class="section-eyebrow mb-4">Want proof?</p>
        <h1 class="font-display text-5xl md:text-7xl tracking-tight mb-6">Read the research.</h1>
        <p class="text-ip-white-muted text-lg leading-relaxed max-w-[65ch]">
          40% of manager time is spent on coordination overhead, not the actual work. We've built the research to prove it, and the product to fix it.
        </p>
      </div>

      <!-- Paper list -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 overflow-visible">
        {papers.map((paper) => (
          <div class="wp-card flex flex-col cursor-pointer">
            <!-- Content -->
            <div class="p-6 flex flex-col flex-1">
              <div class="w-2/3 mx-auto flex flex-col flex-1">
                <!-- Thumbnail — stacked document effect with hover overlay -->
                <div class="wp-thumb-wrap relative flex items-center justify-center mb-8">
                  <div class="relative w-1/2">
                    <img src={paper.thumbnail} aria-hidden="true" class="absolute inset-0 w-full h-full object-cover rounded wp-doc-back-1" />
                    <img src={paper.thumbnail} aria-hidden="true" class="absolute inset-0 w-full h-full object-cover rounded wp-doc-back-2" />
                    <img src={paper.thumbnail} aria-hidden="true" class="absolute inset-0 w-full h-full object-cover rounded wp-doc-back-3" />
                    <img src={paper.thumbnail} aria-hidden="true" class="absolute inset-0 w-full h-full object-cover rounded wp-doc-back-4" />
                    <img
                      src={paper.thumbnail}
                      alt={paper.title}
                      class="relative z-10 w-full h-auto block rounded shadow-lg wp-doc-main"
                      loading="lazy"
                    />
                  </div>
                  <!-- Desktop hover overlay button -->
                  <div class="wp-thumb-overlay hidden sm:flex absolute inset-0 items-center justify-center z-20">
                    <button
                      class="wp-download-btn btn-primary"
                      data-title={paper.title}
                      data-file-url={paper.fileUrl}
                    >
                      Download
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                    </button>
                  </div>
                </div>
                <h3 class="font-display text-base leading-snug mb-3">{paper.title}</h3>
                <p class="text-ip-white-muted text-sm leading-relaxed flex-1">
                  {paper.blurb}
                  {paper.fileSize > 0 && (
                    <span class="text-ip-white-muted/40"> — {formatSize(paper.fileSize)} · PDF</span>
                  )}
                </p>
              </div>
              <!-- Mobile button — visible on mobile, hidden on sm+ -->
              <div class="sm:hidden w-2/3 mx-auto flex justify-center mt-6">
                <button
                  class="wp-download-btn btn-primary"
                  data-title={paper.title}
                  data-file-url={paper.fileUrl}
                >
                  Download
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Email gate dialog -->
  <dialog id="wp-gate-dialog">
    <div class="wp-gate-inner">
      <button type="button" id="wp-gate-close" aria-label="Close" class="wp-gate-close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <h2 class="font-display text-3xl mb-4">Download your whitepaper</h2>
      <p class="text-ip-white-muted text-sm mb-8">Leave your email and we'll unlock the PDF instantly. We'll also send you the occasional update from In Parallel — no noise, unsubscribe any time.</p>

      <form id="wp-gate-form" novalidate>
        <input
          type="email"
          id="wp-gate-email"
          placeholder="you@company.com"
          autocomplete="email"
          required
          class="wp-gate-input"
        />
        <div id="wp-gate-error" class="wp-gate-msg wp-gate-msg--error hidden"></div>
        <div class="wp-gate-actions mt-4">
          <button type="submit" id="wp-gate-submit" class="btn-primary flex-1 justify-center">
            <span id="wp-gate-submit-text">Download PDF</span>
            <svg id="wp-gate-spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" class="opacity-25"/><path d="M4 12a8 8 0 018-8" stroke="currentColor" stroke-width="3" class="opacity-75"/></svg>
          </button>
          <button type="button" id="wp-gate-cancel" class="btn-secondary">Cancel</button>
        </div>
        <p class="text-xs text-white/25 mt-4">
          By submitting you agree to our <a href="/privacy-policy" class="underline hover:text-white/40">Privacy Policy</a>.
        </p>
      </form>
    </div>
  </dialog>
</BaseLayout>

<style>
  /* Card base + radial glow on hover */
  .wp-card {
    border-radius: 0.75rem;
    position: relative;
    min-height: 520px;
  }
  .wp-card::after {
    content: '';
    position: absolute;
    inset: -60% -40%;
    background: radial-gradient(ellipse at 50% 50%, rgba(40, 80, 120, 0.65) 0%, transparent 55%);
    opacity: 0;
    transition: opacity 0.4s;
    pointer-events: none;
    z-index: 0;
  }
  .wp-card:hover::after { opacity: 1; }
  .wp-card > * { position: relative; z-index: 1; }

  /* Fan animation layers */
  .wp-doc-back-1,
  .wp-doc-back-2,
  .wp-doc-back-3,
  .wp-doc-back-4 {
    transform-origin: center center;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
  }
  .wp-doc-back-1 { transform: rotate(-1deg); }
  .wp-doc-back-2 { transform: rotate(-2deg); transition-delay: 0.04s; }
  .wp-doc-back-3 { transform: rotate(-3deg); transition-delay: 0.08s; opacity: 0; }
  .wp-doc-back-4 { transform: rotate(-4deg); transition-delay: 0.12s; opacity: 0; }

  .wp-card:hover .wp-doc-back-1 { transform: rotate(-2deg); }
  .wp-card:hover .wp-doc-back-2 { transform: rotate(-4deg); }
  .wp-card:hover .wp-doc-back-3 { transform: rotate(-6deg); opacity: 1; }
  .wp-card:hover .wp-doc-back-4 { transform: rotate(-8deg); opacity: 1; }

  /* Main thumb — subtle border + scale on hover */
  .wp-doc-main {
    transform-origin: center center;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 1px solid rgba(255, 255, 255, 0.10);
  }
  .wp-card:hover .wp-doc-main { transform: scale(1.05); }

  /* Overlay button — fades in over thumbnail on desktop hover */
  .wp-thumb-overlay {
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }
  .wp-card:hover .wp-thumb-overlay {
    opacity: 1;
    pointer-events: auto;
  }

  #wp-gate-dialog {
    background: var(--color-ip-navy);
    border: none;
    border-radius: 0;
    padding: 0;
    width: min(90vw, 480px);
    color: white;
    margin: auto;
  }
  #wp-gate-dialog[open] {
    display: flex;
    flex-direction: column;
  }

  #wp-gate-dialog::backdrop {
    background: rgba(0, 19, 37, 0.25);
    backdrop-filter: blur(20px);
  }

  .wp-gate-inner {
    padding: 2.5rem;
    position: relative;
  }

  .wp-gate-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    padding: 0.25rem;
    line-height: 1;
    transition: color 0.2s;
  }
  .wp-gate-close:hover { color: white; }

  .wp-gate-input {
    width: 100%;
    background: var(--color-ip-navy);
    border: 1px solid var(--color-ip-border);
    border-radius: 0.5rem;
    padding: 0.625rem 1rem;
    font-size: 0.875rem;
    color: white;
    outline: none;
    margin-bottom: 0.75rem;
    box-sizing: border-box;
    transition: border-color 0.2s;
  }

  .wp-gate-input::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .wp-gate-input:focus {
    border-color: var(--color-ip-lime);
  }

  .wp-gate-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .wp-gate-msg {
    font-size: 0.8125rem;
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem;
    margin-bottom: 0.75rem;
  }

  .wp-gate-msg--error {
    background: rgba(239, 68, 68, 0.1);
    color: #f87171;
    border: 1px solid rgba(239, 68, 68, 0.2);
  }
</style>

<script is:inline>
  const WEBHOOK = 'https://jkzjuxubbespjheduhfh.supabase.co/functions/v1/public-lead-webhook';

  const dialog = document.getElementById('wp-gate-dialog');
  const form = document.getElementById('wp-gate-form');
  const emailInput = document.getElementById('wp-gate-email');
  const submitBtn = document.getElementById('wp-gate-submit');
  const submitText = document.getElementById('wp-gate-submit-text');
  const spinner = document.getElementById('wp-gate-spinner');
  const errorEl = document.getElementById('wp-gate-error');
  const cancelBtn = document.getElementById('wp-gate-cancel');

  // Open dialog on card button click
  document.querySelectorAll('.wp-download-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      dialog.dataset.title = btn.dataset.title;
      dialog.dataset.fileUrl = btn.dataset.fileUrl;
      emailInput.value = '';
      errorEl.classList.add('hidden');
      dialog.showModal();
      emailInput.focus();
    });
  });

  // Close on cancel or ×
  cancelBtn.addEventListener('click', () => dialog.close());
  document.getElementById('wp-gate-close').addEventListener('click', () => dialog.close());

  // Close on backdrop click (check if click landed outside the dialog box)
  dialog.addEventListener('click', (e) => {
    const rect = dialog.getBoundingClientRect();
    if (
      e.clientX < rect.left || e.clientX > rect.right ||
      e.clientY < rect.top  || e.clientY > rect.bottom
    ) dialog.close();
  });

  // Submit gate form
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();

    if (!email || !email.includes('@')) {
      errorEl.textContent = 'Please enter a valid email address.';
      errorEl.classList.remove('hidden');
      return;
    }

    errorEl.classList.add('hidden');
    submitBtn.disabled = true;
    submitText.textContent = '...';
    spinner.classList.remove('hidden');

    // Fire lead capture — don't block download on failure
    fetch(WEBHOOK, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        source: 'whitepaper',
        email,
        metadata: {
          paper: dialog.dataset.title,
          page: window.location.href,
          submitted_at: new Date().toISOString(),
        },
      }),
    }).catch(() => {});

    // Trigger download
    window.open(dialog.dataset.fileUrl, '_blank');
    dialog.close();

    submitBtn.disabled = false;
    submitText.textContent = 'Download PDF';
    spinner.classList.add('hidden');
  });
</script>

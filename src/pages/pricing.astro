---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pricing - In Parallel" description="Flexible pricing for teams of all sizes.">
  <section class="pt-32 pb-20 md:pt-44 md:pb-32">
    <div class="container-ip text-center">
      <h1 class="font-serif text-5xl md:text-7xl tracking-tight mb-8">Pricing</h1>
      <p class="text-ip-white-muted text-lg max-w-2xl mx-auto mb-16">
        Flexible plans that grow with your organization.
      </p>

      <!-- Pricing cards placeholder -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-8 text-left">
          <h3 class="font-display text-xl mb-2">Starter</h3>
          <p class="text-ip-white-muted text-sm mb-6">For small teams getting started</p>
          <a href="/demo" class="btn-outline w-full justify-center">Contact us</a>
        </div>
        <div class="bg-ip-navy-surface border border-ip-lime rounded-xl p-8 text-left relative">
          <span class="absolute -top-3 left-8 bg-ip-lime text-ip-navy text-xs font-display px-3 py-1 rounded-full">Most popular</span>
          <h3 class="font-display text-xl mb-2">Growth</h3>
          <p class="text-ip-white-muted text-sm mb-6">For scaling organizations</p>
          <a href="/demo" class="btn-lime w-full justify-center">Contact us</a>
        </div>
        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-8 text-left">
          <h3 class="font-display text-xl mb-2">Enterprise</h3>
          <p class="text-ip-white-muted text-sm mb-6">Custom deployment and support</p>
          <a href="/demo" class="btn-outline w-full justify-center">Contact us</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

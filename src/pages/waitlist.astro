---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Join the Waitlist — In Parallel" description="Get early access to the intelligent management system that turns your meetings into a living execution plan. No manual updates, no chasing people.">
  <section class="pt-32 pb-20 md:pt-44 md:pb-32 relative overflow-hidden">
    <!-- Atmospheric background -->
    <div class="absolute inset-0 bg-gradient-to-b from-ip-navy via-ip-navy-light/30 to-ip-navy pointer-events-none"></div>

    <div class="container-ip relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
        <!-- Left: Content -->
        <div class="scroll-reveal">
          <p class="text-ip-lime text-[30px] mb-4 font-display">Early access</p>
          <h1 class="font-serif text-5xl md:text-7xl tracking-tight leading-[1.05] mb-8">
            Get ahead of the coordination tax.
          </h1>
          <p class="text-white text-xl md:text-2xl leading-relaxed font-display mb-8">
            Turn your existing meeting and work routines into a learning loop &mdash; so plans stay true to reality, decisions get faster, and governance has less friction.
          </p>

          <div class="space-y-4 text-ip-white-muted text-base leading-relaxed">
            <p><strong class="text-white">What you&rsquo;ll get with early access:</strong></p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-ip-lime mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span>A shared, living operating picture that updates itself from your meetings</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-ip-lime mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span>Bidirectional sync with Jira, Asana, Monday, and more</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-ip-lime mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span>Priority onboarding with a dedicated success contact</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="scroll-reveal">
          <div class="bg-ip-navy-surface border border-ip-border rounded-2xl p-8 md:p-10 shadow-ip-card">
            <h2 class="font-display text-2xl mb-2">Join the waitlist</h2>
            <p class="text-ip-white-muted text-sm mb-8">We&rsquo;ll reach out when your spot opens up.</p>

            <form id="waitlist-form" class="space-y-5" novalidate>
              <!-- Email (required) -->
              <div>
                <label for="wl-email" class="block text-sm font-display mb-1.5">Work email <span class="text-red-400">*</span></label>
                <input
                  type="email"
                  id="wl-email"
                  name="email"
                  required
                  placeholder="you@company.com"
                  class="w-full bg-ip-navy border border-ip-border rounded-lg px-4 py-3 text-white text-sm placeholder:text-white/30 focus:outline-none focus:border-ip-lime/60 focus:ring-1 focus:ring-ip-lime/30 transition-colors"
                />
              </div>

              <!-- Name -->
              <div>
                <label for="wl-name" class="block text-sm font-display mb-1.5">Full name</label>
                <input
                  type="text"
                  id="wl-name"
                  name="name"
                  placeholder="Jane Smith"
                  class="w-full bg-ip-navy border border-ip-border rounded-lg px-4 py-3 text-white text-sm placeholder:text-white/30 focus:outline-none focus:border-ip-lime/60 focus:ring-1 focus:ring-ip-lime/30 transition-colors"
                />
              </div>

              <!-- Company -->
              <div>
                <label for="wl-company" class="block text-sm font-display mb-1.5">Company</label>
                <input
                  type="text"
                  id="wl-company"
                  name="company"
                  placeholder="Acme Inc"
                  class="w-full bg-ip-navy border border-ip-border rounded-lg px-4 py-3 text-white text-sm placeholder:text-white/30 focus:outline-none focus:border-ip-lime/60 focus:ring-1 focus:ring-ip-lime/30 transition-colors"
                />
              </div>

              <!-- Job title -->
              <div>
                <label for="wl-job-title" class="block text-sm font-display mb-1.5">Job title</label>
                <input
                  type="text"
                  id="wl-job-title"
                  name="job_title"
                  placeholder="VP of Operations"
                  class="w-full bg-ip-navy border border-ip-border rounded-lg px-4 py-3 text-white text-sm placeholder:text-white/30 focus:outline-none focus:border-ip-lime/60 focus:ring-1 focus:ring-ip-lime/30 transition-colors"
                />
              </div>

              <!-- Phone (optional) -->
              <div>
                <label for="wl-phone" class="block text-sm font-display mb-1.5">Phone <span class="text-white/30 text-xs">(optional)</span></label>
                <input
                  type="tel"
                  id="wl-phone"
                  name="phone"
                  placeholder="+358 40 123 4567"
                  class="w-full bg-ip-navy border border-ip-border rounded-lg px-4 py-3 text-white text-sm placeholder:text-white/30 focus:outline-none focus:border-ip-lime/60 focus:ring-1 focus:ring-ip-lime/30 transition-colors"
                />
              </div>

              <!-- Error / Success messages -->
              <div id="wl-message" class="hidden text-sm rounded-lg px-4 py-3"></div>

              <!-- Submit -->
              <button
                type="submit"
                id="wl-submit"
                class="btn-lime w-full justify-center text-base py-3.5"
              >
                <span id="wl-submit-text">Join the waitlist</span>
                <svg id="wl-submit-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                <svg id="wl-spinner" class="hidden animate-spin" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="opacity-25"/><path d="M4 12a8 8 0 018-8" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="opacity-75"/></svg>
              </button>

              <p class="text-white/30 text-xs text-center leading-relaxed">
                By joining, you agree to our <a href="/privacy-policy" class="underline hover:text-white/50">Privacy Policy</a>.
                We&rsquo;ll only contact you about In Parallel.
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof strip -->
  <section class="py-16 bg-ip-navy-light">
    <div class="container-ip text-center">
      <p class="text-ip-white-muted text-sm font-display mb-8">Trusted by teams at</p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16 opacity-40">
        <img src="/images/logos/OP-Financial-Group.svg" alt="OP Financial Group" class="h-8" loading="lazy" />
        <img src="/images/logos/Nokia.svg" alt="Nokia" class="h-6" loading="lazy" />
        <img src="/images/logos/Neste.svg" alt="Neste" class="h-7" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- What happens next -->
  <section class="py-20 md:py-32">
    <div class="container-ip max-w-4xl">
      <div class="text-center mb-16 scroll-reveal">
        <h2 class="font-display text-3xl md:text-5xl tracking-tight mb-4">What happens next?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 scroll-reveal">
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-ip-lime/10 border border-ip-lime/20 flex items-center justify-center mx-auto mb-4">
            <span class="font-display text-ip-lime text-sm">1</span>
          </div>
          <h3 class="font-display text-base mb-2">We confirm your spot</h3>
          <p class="text-ip-white-muted text-sm leading-relaxed">You&rsquo;ll get an email within 24 hours confirming your place on the list.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-ip-lime/10 border border-ip-lime/20 flex items-center justify-center mx-auto mb-4">
            <span class="font-display text-ip-lime text-sm">2</span>
          </div>
          <h3 class="font-display text-base mb-2">We schedule a walkthrough</h3>
          <p class="text-ip-white-muted text-sm leading-relaxed">A 30-minute session tailored to your context. Real workflows, not slides.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-ip-lime/10 border border-ip-lime/20 flex items-center justify-center mx-auto mb-4">
            <span class="font-display text-ip-lime text-sm">3</span>
          </div>
          <h3 class="font-display text-base mb-2">You get early access</h3>
          <p class="text-ip-white-muted text-sm leading-relaxed">Priority onboarding with a dedicated success contact to get you running fast.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const WEBHOOK_URL = 'https://jkzjuxubbespjheduhfh.supabase.co/functions/v1/public-lead-webhook';

  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const messageEl = document.getElementById('wl-message') as HTMLDivElement;
  const submitBtn = document.getElementById('wl-submit') as HTMLButtonElement;
  const submitText = document.getElementById('wl-submit-text') as HTMLSpanElement;
  const submitArrow = document.getElementById('wl-submit-arrow') as SVGElement;
  const spinner = document.getElementById('wl-spinner') as SVGElement;

  function getUtmParams(): Record<string, string> {
    const params = new URLSearchParams(window.location.search);
    const utm: Record<string, string> = {};
    for (const key of ['utm_source', 'utm_medium', 'utm_campaign']) {
      const val = params.get(key);
      if (val) utm[key] = val;
    }
    return utm;
  }

  function showMessage(text: string, type: 'success' | 'error') {
    messageEl.textContent = text;
    messageEl.className = type === 'success'
      ? 'text-sm rounded-lg px-4 py-3 bg-ip-lime/10 text-ip-lime border border-ip-lime/20'
      : 'text-sm rounded-lg px-4 py-3 bg-red-500/10 text-red-400 border border-red-500/20';
  }

  function setLoading(loading: boolean) {
    submitBtn.disabled = loading;
    submitText.textContent = loading ? 'Submitting...' : 'Join the waitlist';
    submitArrow.classList.toggle('hidden', loading);
    spinner.classList.toggle('hidden', !loading);
    submitBtn.classList.toggle('opacity-70', loading);
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    messageEl.className = 'hidden';

    const formData = new FormData(form);
    const email = (formData.get('email') as string || '').trim();

    if (!email || !email.includes('@')) {
      showMessage('Please enter a valid work email address.', 'error');
      return;
    }

    setLoading(true);

    const payload: Record<string, any> = {
      source: 'waitlist',
      email,
    };

    const name = (formData.get('name') as string || '').trim();
    const company = (formData.get('company') as string || '').trim();
    const jobTitle = (formData.get('job_title') as string || '').trim();
    const phone = (formData.get('phone') as string || '').trim();

    if (name) payload.name = name;
    if (company) payload.company = company;
    if (jobTitle) payload.job_title = jobTitle;
    if (phone) payload.phone = phone;

    // UTM params from URL
    const utmParams = getUtmParams();
    Object.assign(payload, utmParams);

    // Metadata
    payload.metadata = {
      page: window.location.href,
      submitted_at: new Date().toISOString(),
    };

    try {
      const response = await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (response.ok) {
        showMessage("You're on the list! We'll be in touch within 24 hours.", 'success');
        form.querySelectorAll('input').forEach((input) => ((input as HTMLInputElement).value = ''));
        submitBtn.style.display = 'none';
      } else {
        const errData = await response.json().catch(() => ({}));
        showMessage(errData.message || 'Something went wrong. Please try again.', 'error');
      }
    } catch {
      showMessage('Network error. Please check your connection and try again.', 'error');
    } finally {
      setLoading(false);
    }
  });
</script>

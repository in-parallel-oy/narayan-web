---
interface Props {
  current: string; // page slug: "clickup", "fellow", etc.
  theme?: 'dark' | 'light';
  compact?: boolean;
}

const { current, theme = 'dark', compact = false } = Astro.props;

const competitors = [
  { slug: "fellow",     name: "Fellow"       },
  { slug: "fireflies",  name: "Fireflies.ai" },
  { slug: "otter",      name: "Otter.ai"     },
  { slug: "fathom",     name: "Fathom"       },
  { slug: "tldv",       name: "tl;dv"        },
  { slug: "granola",    name: "Granola"      },
  { slug: "avoma",      name: "Avoma"        },
  { slug: "read-ai",    name: "Read AI"      },
  { slug: "spinach",    name: "Spinach"      },
  { slug: "atlassian",  name: "Atlassian"    },
  { slug: "clickup",    name: "ClickUp"      },
  { slug: "workboard",  name: "WorkBoard"    },
];

const idx  = competitors.findIndex(c => c.slug === current);
const prev = competitors[(idx - 1 + competitors.length) % competitors.length];
const next = competitors[(idx + 1) % competitors.length];

const link   = theme === 'light' ? 'text-ip-navy/50 hover:text-ip-navy' : 'text-ip-white-muted hover:text-white';
const dotOn  = theme === 'light' ? 'bg-ip-navy' : 'bg-white';
const dotOff = theme === 'light' ? 'bg-ip-navy/20 hover:bg-ip-navy/50' : 'bg-ip-white-muted/40 hover:bg-ip-white-muted';
---

{compact ? (
  <div class="compare-nav relative flex items-center justify-between mt-8 pt-8" data-prev={`/compare/${prev.slug}`} data-next={`/compare/${next.slug}`}>
    <a href={`/compare/${prev.slug}`} class={`flex items-center gap-4 transition-colors group ${link}`}>
      <span class="font-display text-lg leading-none transition-transform duration-200 group-hover:-translate-x-1">&#x2190;</span>
      <p class="font-display text-sm underline-offset-4 group-hover:underline">{prev.name}</p>
    </a>
    <div class="absolute left-1/2 -translate-x-1/2 flex items-center gap-2">
      {competitors.map((c) => (
        <a href={`/compare/${c.slug}`} aria-label={c.name}
          class={`block h-2 rounded-full transition-all duration-300 ${c.slug === current ? `w-6 ${dotOn}` : `w-2 ${dotOff}`}`}
        />
      ))}
    </div>
    <a href={`/compare/${next.slug}`} class={`flex items-center gap-4 transition-colors group text-right ${link}`}>
      <p class="font-display text-sm underline-offset-4 group-hover:underline">{next.name}</p>
      <span class="font-display text-lg leading-none transition-transform duration-200 group-hover:translate-x-1">&#x2192;</span>
    </a>
  </div>
) : (
  <nav class="compare-nav py-16 md:py-20" data-prev={`/compare/${prev.slug}`} data-next={`/compare/${next.slug}`}>
    <div class="container-ip">
      <div class="relative flex items-center justify-between">
        <a href={`/compare/${prev.slug}`} class={`flex items-center gap-4 transition-colors group ${link}`}>
          <span class="font-display text-lg leading-none transition-transform duration-200 group-hover:-translate-x-1">&#x2190;</span>
          <p class="font-display text-sm underline-offset-4 group-hover:underline">{prev.name}</p>
        </a>
        <div class="absolute left-1/2 -translate-x-1/2 flex items-center gap-2">
          {competitors.map((c) => (
            <a href={`/compare/${c.slug}`} aria-label={c.name}
              class={`block h-2 rounded-full transition-all duration-300 ${c.slug === current ? `w-6 ${dotOn}` : `w-2 ${dotOff}`}`}
            />
          ))}
        </div>
        <a href={`/compare/${next.slug}`} class={`flex items-center gap-4 transition-colors group text-right ${link}`}>
          <p class="font-display text-sm underline-offset-4 group-hover:underline">{next.name}</p>
          <span class="font-display text-lg leading-none transition-transform duration-200 group-hover:translate-x-1">&#x2192;</span>
        </a>
      </div>
    </div>
  </nav>
)}

<script>
  function initCompareNavKeys() {
    const nav = document.querySelector('.compare-nav') as HTMLElement | null;
    if (!nav) return;

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
      if (e.key === 'ArrowLeft') {
        const prev = nav.dataset.prev;
        if (prev) window.location.href = prev;
      } else if (e.key === 'ArrowRight') {
        const next = nav.dataset.next;
        if (next) window.location.href = next;
      }
    });
  }

  initCompareNavKeys();
  document.addEventListener('astro:after-swap', initCompareNavKeys);
</script>

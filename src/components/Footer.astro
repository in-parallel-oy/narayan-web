---
const navLinks = [
  { label: 'Our product', href: '/#product' },
  { label: 'The vision', href: '/vision' },
  { label: 'White papers', href: '/white-papers' },
  { label: 'Our team & the why', href: '/about-us' },
  { label: 'Between the lines', href: '/insight' },
];

const solutionLinks = [
  { label: 'For COOs', href: '/use-case/coo' },
  { label: 'For Program Managers', href: '/use-case/program-manager' },
  { label: 'For Project Managers', href: '/use-case/project-manager' },
  { label: 'For Engineering Leaders', href: '/use-case/engineering-leader' },
  { label: 'For Team Leads', href: '/use-case/team-lead' },
  { label: 'For Account Executives', href: '/use-case/account-executive' },
  { label: 'For Strategy & PMO', href: '/use-case/strategy' },
];

const compareLinks = [
  { label: 'vs Fellow', href: '/compare/fellow' },
  { label: 'vs Fireflies', href: '/compare/fireflies' },
  { label: 'vs Atlassian', href: '/compare/atlassian' },
  { label: 'vs ClickUp', href: '/compare/clickup' },
  { label: 'vs WorkBoard', href: '/compare/workboard' },
  { label: 'vs Read.ai', href: '/compare/read-ai' },
  { label: 'vs Spinach', href: '/compare/spinach' },
];

const legalLinks = [
  { label: 'Privacy', href: '/privacy-policy' },
  { label: 'Terms of Use', href: '/terms-of-use' },
  { label: 'Cookie Policy', href: '/cookie-policy' },
];
---

<footer class="bg-ip-navy-light border-t border-ip-border">
  <div class="container-ip py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-10">
      <!-- Logo -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center text-white no-underline mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 110 15" class="h-4 w-auto" fill="currentColor" aria-label="In Parallel">
            <path d="M3.005 14.727H0V.026h7.46v10.333C7.46 12.772 5.465 14.728 3.005 14.728z"/>
            <path d="M18.999 14.727H8.656V.026h15.045v10.09c0 2.547-2.105 4.612-4.702 4.612z"/>
            <path d="M27.45 0h2.596v14.727H27.45z"/>
            <path d="M32.031 4.123h2.488v1.599c.729-1.199 2.124-1.872 3.582-1.872 2.424 0 3.861 1.536 3.861 4.229v6.648h-2.488V8.373c0-1.599-.901-2.482-2.274-2.482-1.523 0-2.681 1.22-2.681 2.861v5.975h-2.488z"/>
            <path d="M45.828 0h6.757c2.874 0 4.955 1.788 4.955 4.691s-2.081 4.671-4.955 4.671h-4.161v5.365h-2.596zm6.308 7.258c1.695 0 2.724-1.01 2.724-2.567s-1.029-2.587-2.724-2.587h-3.711v5.154z"/>
            <path d="M57.936 11.929c0-2.483 2.188-3.072 4.011-3.367l2.081-.294c.794-.126.987-.526.987-1.01 0-.862-.601-1.557-1.93-1.557s-2.124.589-2.274 1.746h-2.488c.3-2.356 2.209-3.597 4.783-3.597 2.917 0 4.376 1.367 4.376 3.934v4.544c0 .295.215.484.515.484h.579v1.915h-1.588c-1.093 0-1.78-.526-1.78-1.347v-.231c-.944 1.346-2.36 1.851-3.775 1.851-2.124 0-3.497-1.22-3.497-3.071zm4.312 1.22c1.716 0 2.767-1.389 2.767-3.135v-.568c-.322.168-.622.231-.987.316l-1.608.273c-1.352.232-1.952.736-1.952 1.641s.707 1.473 1.78 1.473z"/>
            <path d="M69.693 4.123h2.488v1.81c.622-1.284 1.631-1.81 3.003-1.81h.579v2.315h-.836c-1.845 0-2.746 1.136-2.746 3.155v5.134h-2.488z"/>
            <path d="M76.228 11.929c0-2.483 2.189-3.072 4.012-3.367l2.08-.294c.794-.126.987-.526.987-1.01 0-.862-.6-1.557-1.931-1.557-1.329 0-2.123.589-2.273 1.746h-2.488c.3-2.356 2.209-3.597 4.783-3.597 2.917 0 4.376 1.367 4.376 3.934v4.544c0 .295.215.484.515.484h.579v1.915h-1.587c-1.094 0-1.781-.526-1.781-1.347v-.231c-.944 1.346-2.359 1.851-3.775 1.851-2.124 0-3.497-1.22-3.497-3.071zm4.312 1.22c1.716 0 2.767-1.389 2.767-3.135v-.568c-.321.168-.622.231-.987.316l-1.608.273c-1.352.232-1.953.736-1.953 1.641s.709 1.473 1.781 1.473z"/>
            <path d="M88.046 0h2.489v14.727h-2.489z"/>
            <path d="M92.434 0h2.488v14.727h-2.488z"/>
            <path d="M96.095 9.425c0-3.177 2.038-5.575 5.255-5.575 2.832 0 5.148 1.599 4.977 6.185h-7.743c.149 1.746.986 3.051 2.788 3.051 1.223 0 2.038-.589 2.381-1.683h2.445c-.343 2.019-2.016 3.597-4.848 3.597-3.217 0-5.255-2.377-5.255-5.575zm7.788-1.031c-.128-1.851-1.029-2.651-2.531-2.651-1.652 0-2.488 1.157-2.724 2.651z"/>
            <path d="M107.512 0H110v14.727h-2.488z"/>
          </svg>
        </a>
      </div>

      <!-- Navigate -->
      <div>
        <h4 class="font-display text-sm mb-4">Navigate</h4>
        <ul class="space-y-2">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-ip-white-muted hover:text-white text-sm no-underline transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Solutions -->
      <div>
        <h4 class="font-display text-sm mb-4"><a href="/use-case" class="text-white no-underline hover:text-ip-lime transition-colors">Use cases</a></h4>
        <ul class="space-y-2 mb-6">
          {solutionLinks.map((link) => (
            <li>
              <a href={link.href} class="text-ip-white-muted hover:text-white text-sm no-underline transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <h4 class="font-display text-sm mb-4"><a href="/compare" class="text-white no-underline hover:text-ip-lime transition-colors">Compare</a></h4>
        <ul class="space-y-2">
          {compareLinks.map((link) => (
            <li>
              <a href={link.href} class="text-ip-white-muted hover:text-white text-sm no-underline transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Address + Contact + Legal -->
      <div class="col-span-2 md:col-span-2">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
          <div>
            <h4 class="font-display text-sm mb-4">Address</h4>
            <address class="text-ip-white-muted text-sm not-italic leading-relaxed">
              In Parallel Oy<br />
              Salomonkatu 17 B 4. Krs<br />
              Autotalo, 00100<br />
              Helsinki, Finland
            </address>
          </div>
          <div>
            <h4 class="font-display text-sm mb-4">Contact Us</h4>
            <div class="space-y-2 mb-6">
              <a href="https://linkedin.com/company/in-parallel" target="_blank" rel="noopener" class="flex items-center gap-2 text-ip-white-muted hover:text-white text-sm no-underline transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
              <a href="mailto:hello@in-parallel.com" class="flex items-center gap-2 text-ip-white-muted hover:text-white text-sm no-underline transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                Email
              </a>
            </div>

            <h4 class="font-display text-sm mb-4">Legal</h4>
            <ul class="space-y-2">
              {legalLinks.map((link) => (
                <li>
                  <a href={link.href} class="text-ip-white-muted hover:text-white text-sm no-underline transition-colors">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Compliance badges + copyright -->
    <div class="mt-12 pt-8 border-t border-ip-border flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-4 opacity-60">
        <img src="/images/trust/badge-1.png" alt="ISO 27001" width="40" height="40" class="w-10 h-auto" />
        <img src="/images/trust/badge-2.png" alt="ISO 42001" width="40" height="40" class="w-10 h-auto" />
        <img src="/images/trust/badge-3.png" alt="SOC 2 Type II" width="40" height="40" class="w-10 h-auto" />
        <img src="/images/trust/badge-4.png" alt="GDPR" width="80" height="24" class="h-6 w-auto" />
        <img src="/images/trust/badge-5.png" alt="DPIA" width="40" height="40" class="w-10 h-auto" />
      </div>
      <p class="text-xs text-ip-white-muted">
        &copy; {new Date().getFullYear()} In Parallel Oy. All rights reserved.
      </p>
    </div>
  </div>
</footer>

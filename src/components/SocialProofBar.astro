---
---

<section class="relative z-10 min-h-[50vh] flex items-center py-36 md:py-56 bg-ip-navy">
  <div class="container-ip">
    <!-- Mobile: stacked. Desktop: single row with divider between groups -->
    <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:gap-0">

      <!-- Backed by -->
      <div class="flex items-center justify-center gap-x-6 sm:gap-x-10 md:pr-12">
        <p class="text-sm text-ip-white-muted/50 whitespace-nowrap">Backed by</p>
        <img src="/images/trust/lifeline-ventures.svg" alt="Lifeline Ventures" class="h-9 sm:h-[58px] w-auto opacity-70" />
        <img src="/images/trust/notion-capital-white.png" alt="Notion Capital" class="w-[80px] sm:w-[115px] h-auto opacity-70" />
      </div>

      <!-- Divider -->
      <div class="hidden md:block w-px h-12 bg-white/10 flex-shrink-0" aria-hidden="true"></div>

      <!-- Complies to -->
      <div class="flex items-center justify-center gap-x-4 sm:gap-x-8 md:pl-12">
        <p class="text-sm text-ip-white-muted/50 whitespace-nowrap">Complies to</p>
        <img src="/images/trust/badge-1.png" alt="ISO 27001" class="h-12 sm:h-[72px] w-auto opacity-70" />
        <img src="/images/trust/badge-2.png" alt="ISO 42001" class="h-12 sm:h-20 w-auto opacity-70" />
        <img src="/images/trust/SVG/SOC2.svg" alt="SOC 2 Type II" class="h-12 sm:h-20 w-auto opacity-70" />
        <img src="/images/trust/SVG/GDPR.svg" alt="GDPR" class="h-12 sm:h-20 w-auto opacity-70" />
      </div>

    </div>
  </div>
</section>

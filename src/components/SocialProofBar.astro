---
---

<section class="relative z-10 min-h-[50vh] flex items-center py-36 md:py-56 bg-ip-navy">
  <div class="container-ip">
    <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-4">

      <!-- Backed by + first logo (tight pair) -->
      <div class="flex items-center gap-x-6 shrink-0">
        <p class="text-sm text-ip-white-muted/50 whitespace-nowrap">Backed by</p>
        <img src="/images/trust/lifeline-ventures.svg" alt="Lifeline Ventures" class="h-[58px] w-auto opacity-70" />
      </div>

      <img src="/images/trust/notion-capital-white.png" alt="Notion Capital" class="w-[115px] h-auto opacity-70 shrink-0" />

      <!-- Divider -->
      <div class="hidden md:block w-px h-12 bg-white/10 shrink-0" aria-hidden="true"></div>

      <!-- Complies to + first badge (tight pair) -->
      <div class="flex items-center gap-x-6 shrink-0">
        <p class="text-sm text-ip-white-muted/50 whitespace-nowrap">Complies to</p>
        <img src="/images/trust/badge-1.png" alt="ISO 27001" class="h-[72px] w-auto opacity-70" />
      </div>

      <img src="/images/trust/badge-2.png" alt="ISO 42001" class="h-20 w-auto opacity-70 shrink-0" />
      <img src="/images/trust/SVG/SOC2.svg" alt="SOC 2 Type II" class="h-20 w-auto opacity-70 shrink-0" />
      <img src="/images/trust/SVG/GDPR.svg" alt="GDPR" class="h-20 w-auto opacity-70 shrink-0" />

    </div>
  </div>
</section>

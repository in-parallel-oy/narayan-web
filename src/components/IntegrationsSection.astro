---
const integrations = [
  { name: 'Microsoft 365 Copilot', description: 'Connect all your work items on Microsoft 365.', icon: 'M365' },
  { name: 'Microsoft Teams', description: 'Transcribe your calls and chats.', icon: 'Teams' },
  { name: 'Microsoft Sharepoint', description: 'Easily attach files to tasks to keep teams and work connected.', icon: 'SP' },
  { name: 'Microsoft PowerBI', description: 'Access your existing business intelligence and analytics.', icon: 'PBI' },
  { name: 'Microsoft Outlook', description: 'Sync your task and project deadlines to your Outlook calendar.', icon: 'OL' },
  { name: 'Slack', description: 'Get updates, create and delegate tasks without leaving Slack.', icon: 'Slack' },
  { name: 'Google Workspace', description: 'Connect your Google apps for seamless workflow.', icon: 'GWS' },
  { name: 'Linear', description: 'Connect your modern software development.', icon: 'Linear' },
  { name: 'HubSpot', description: 'Connect your CRM and marketing intelligence.', icon: 'HS' },
  { name: 'Salesforce', description: 'Connect your CRM and marketing intelligence.', icon: 'SF' },
  { name: 'Asana', description: 'Connect your system for modern software development.', icon: 'Asana' },
  { name: 'Jira', description: 'Sync with your existing issue tracking and project management.', icon: 'Jira' },
];
---

<section id="integrations" class="py-20 md:py-32">
  <div class="container-ip">
    <div class="text-center mb-16">
      <p class="text-ip-white-muted text-base mb-4 font-display">We connect to your existing stack</p>
      <h2 class="font-display text-4xl md:text-6xl lg:text-7xl tracking-tight mb-6">
        No migrations. Just connection.
      </h2>
      <p class="text-ip-white-muted text-lg">Don't see yours? We'll add it or map a CSV.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {integrations.map((item) => (
        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 hover:border-ip-white-muted/30 transition-colors">
          <div class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center text-sm font-display mb-3">
            {item.icon.substring(0, 2)}
          </div>
          <h3 class="font-display text-base mb-1">{item.name}</h3>
          <p class="text-ip-white-muted text-sm">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

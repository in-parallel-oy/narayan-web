---
const integrations = [
  { name: 'Microsoft 365 Copilot', description: 'Connect all your work items on Microsoft 365.', icon: '/images/integrations/microsoft-365.png' },
  { name: 'Microsoft Teams', description: 'Transcribe your calls and chats.', icon: '/images/integrations/microsoft-teams.png' },
  { name: 'Microsoft Sharepoint', description: 'Easily attach files to tasks to keep teams and work connected.', icon: '/images/integrations/microsoft-sharepoint.png' },
  { name: 'Microsoft PowerBI', description: 'Access your existing business intelligence and analytics.', icon: '/images/integrations/microsoft-powerbi.png' },
  { name: 'Microsoft Outlook', description: 'Sync your task and project deadlines to your Outlook calendar.', icon: '/images/integrations/microsoft-outlook.png' },
  { name: 'Slack', description: 'Get updates, create and delegate tasks without leaving Slack.', icon: '/images/integrations/slack.png' },
  { name: 'Google Workspace', description: 'Connect all your work items on Google Workspace.', icon: '/images/integrations/google-workspace.png' },
  { name: 'Google Calendar', description: 'Sync your task and project deadlines to your work calendar.', icon: '/images/integrations/google-calendar.png' },
  { name: 'Google Meet', description: 'Transcribe your calls and chats.', icon: '/images/integrations/google-meet.png' },
  { name: 'Linear', description: 'Connect your system for modern software development.', icon: '/images/integrations/linear.png' },
  { name: 'Atlassian Jira', description: 'Connect your system for modern software development.', icon: '/images/integrations/jira.png' },
  { name: 'Hubspot', description: 'Connect your CRM and marketing intelligence.', icon: '/images/integrations/hubspot.png' },
  { name: 'Salesforce', description: 'Connect your CRM and marketing intelligence.', icon: '/images/integrations/salesforce.png' },
  { name: 'Asana', description: 'Connect your system for modern software development.', icon: '/images/integrations/asana.png' },
];
---

<section id="integrations" class="py-20 md:py-32 bg-ip-navy-light relative overflow-hidden">
  <div class="absolute inset-0 bg-accent-glow opacity-30 pointer-events-none" aria-hidden="true"></div>
  <div class="container-ip relative">
    <div class="text-center mb-16">
      <p class="section-eyebrow mb-4">Connect to your existing stack</p>
      <h2 class="font-display text-3xl md:text-6xl lg:text-7xl tracking-tight mb-6">
        Works with what you already use.
      </h2>
      <p class="text-ip-white-muted text-lg">Don't see yours? We'll add it.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {integrations.map((item) => (
        <div class="bg-ip-navy-surface border border-ip-border rounded-xl p-6 card-elevated hover:border-ip-white-muted/30 transition-colors">
          <img src={item.icon} alt={item.name} width="40" height="40" class="w-10 h-10 rounded-lg mb-3" />
          <h3 class="font-display text-base mb-1">{item.name}</h3>
          <p class="text-ip-white-muted text-sm">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

---
const stats = [
  {
    value: '25%',
    description: 'faster blocker resolution — problems surface in meetings and get routed to the right person automatically.',
  },
  {
    value: '30%',
    description: 'less time on reporting — status updates and dashboards write themselves after each meeting.',
  },
  {
    value: '65%',
    description: 'more cross-team learnings shared — what one team learns flows to others without extra meetings.',
  },
];

---

<!-- Measurable impact stats -->
<section class="py-20 md:py-32 bg-white">
  <div class="container-ip">
    <div class="text-center mb-12 scroll-reveal">
      <p class="text-ip-navy/60 text-[30px] mb-4 font-display">Measurable impact</p>
      <h2 class="font-display text-4xl md:text-6xl tracking-tight text-ip-navy">
        Results that grow over time
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-5xl mx-auto mb-20">
      {stats.map((stat) => (
        <div class="bg-ip-light-periwinkle/50 border border-ip-navy/10 rounded-xl p-8 scroll-reveal">
          <p class="font-serif text-5xl md:text-6xl tracking-tight text-ip-navy mb-4">{stat.value}</p>
          <p class="text-ip-navy/80 text-sm leading-relaxed">{stat.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

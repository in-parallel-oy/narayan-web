---
interface Props {
  current: string; // page slug: "coo", "program-manager", etc.
  theme?: 'dark' | 'light';
  compact?: boolean;
}

const { current, theme = 'dark', compact = false } = Astro.props;

const roles = [
  { slug: "coo",                  name: "COO & operations leaders"  },
  { slug: "program-manager",      name: "Program managers"          },
  { slug: "project-manager",      name: "Project managers"          },
  { slug: "engineering-leader",   name: "Engineering leaders"       },
  { slug: "team-lead",            name: "Team leads"                },
  { slug: "account-executive",    name: "Account executives"        },
  { slug: "strategy",             name: "Strategy & PMO"            },
];

const idx  = roles.findIndex(r => r.slug === current);
const prev = roles[(idx - 1 + roles.length) % roles.length];
const next = roles[(idx + 1) % roles.length];

const link   = theme === 'light' ? 'text-ip-navy/50 hover:text-ip-navy' : 'text-ip-white-muted hover:text-white';
const dotOn  = theme === 'light' ? 'bg-ip-navy' : 'bg-white';
const dotOff = theme === 'light' ? 'bg-ip-navy/20 hover:bg-ip-navy/50' : 'bg-ip-white-muted/40 hover:bg-ip-white-muted';
---

{compact ? (
  <div class="usecase-nav relative flex items-center justify-between mt-8 pt-8" data-prev={`/use-case/${prev.slug}`} data-next={`/use-case/${next.slug}`}>
    <a href={`/use-case/${prev.slug}`} class={`flex items-center gap-4 transition-colors group ${link}`}>
      <span class="font-display text-lg leading-none transition-transform duration-200 group-hover:-translate-x-1">&#x2190;</span>
      <p class="font-display text-sm underline-offset-4 group-hover:underline">{prev.name}</p>
    </a>
    <div class="absolute left-1/2 -translate-x-1/2 flex items-center gap-2">
      {roles.map((role) => (
        <a href={`/use-case/${role.slug}`} aria-label={role.name}
          class={`block h-2 rounded-full transition-all duration-300 ${role.slug === current ? `w-6 ${dotOn}` : `w-2 ${dotOff}`}`}
        />
      ))}
    </div>
    <a href={`/use-case/${next.slug}`} class={`flex items-center gap-4 transition-colors group text-right ${link}`}>
      <p class="font-display text-sm underline-offset-4 group-hover:underline">{next.name}</p>
      <span class="font-display text-lg leading-none transition-transform duration-200 group-hover:translate-x-1">&#x2192;</span>
    </a>
  </div>
) : (
  <nav class="usecase-nav py-16 md:py-20" data-prev={`/use-case/${prev.slug}`} data-next={`/use-case/${next.slug}`}>
    <div class="container-ip">
      <div class="relative flex items-center justify-between">
        <a href={`/use-case/${prev.slug}`} class={`flex items-center gap-4 transition-colors group ${link}`}>
          <span class="font-display text-lg leading-none transition-transform duration-200 group-hover:-translate-x-1">&#x2190;</span>
          <p class="font-display text-sm underline-offset-4 group-hover:underline">{prev.name}</p>
        </a>
        <div class="absolute left-1/2 -translate-x-1/2 flex items-center gap-2">
          {roles.map((role) => (
            <a href={`/use-case/${role.slug}`} aria-label={role.name}
              class={`block h-2 rounded-full transition-all duration-300 ${role.slug === current ? `w-6 ${dotOn}` : `w-2 ${dotOff}`}`}
            />
          ))}
        </div>
        <a href={`/use-case/${next.slug}`} class={`flex items-center gap-4 transition-colors group text-right ${link}`}>
          <p class="font-display text-sm underline-offset-4 group-hover:underline">{next.name}</p>
          <span class="font-display text-lg leading-none transition-transform duration-200 group-hover:translate-x-1">&#x2192;</span>
        </a>
      </div>
    </div>
  </nav>
)}

<script>
  function initUseCaseNavKeys() {
    const nav = document.querySelector('.usecase-nav') as HTMLElement | null;
    if (!nav) return;

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
      if (e.key === 'ArrowLeft') {
        const prev = nav.dataset.prev;
        if (prev) window.location.href = prev;
      } else if (e.key === 'ArrowRight') {
        const next = nav.dataset.next;
        if (next) window.location.href = next;
      }
    });
  }

  initUseCaseNavKeys();
  document.addEventListener('astro:after-swap', initUseCaseNavKeys);
</script>

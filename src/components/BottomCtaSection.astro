<section class="relative overflow-hidden min-h-[95vh] flex items-center py-20 md:py-32 bg-ip-navy-light">
  <div class="container-ip text-center relative z-10">
    <h2 class="font-serif text-4xl md:text-6xl lg:text-7xl tracking-tight mb-6">
      See it for yourself.
    </h2>
    <p class="text-ip-white-muted text-lg max-w-2xl mx-auto mb-10">
      30-minute demo. We'll show you how your meetings become a living plan.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/demo" class="btn-primary">
        Book a demo
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- Screenshot: top 25% visible, flush to section bottom -->
  <div class="absolute bottom-0 inset-x-0">
    <div class="container-ip overflow-hidden" style="aspect-ratio: 6.13;">
      <img src="/images/hero/hero-main.png" alt="In Parallel product dashboard" width="1200" height="783" class="w-full block rounded-t-xl" data-parallax="0.1" style="will-change: transform;" />
    </div>
  </div>
</section>

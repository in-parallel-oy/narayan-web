<section class="py-20 md:py-32 bg-ip-light-blue">
  <div class="container-ip">
    <div class="text-center mb-12 scroll-reveal-fade">
      <p class="text-ip-navy/60 text-[30px] mb-4 font-display">Want proof?</p>
      <h2 class="font-display text-4xl md:text-6xl tracking-tight text-ip-navy">
        Read the research.
      </h2>
    </div>

    <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16 max-w-4xl mx-auto">
      <!-- White paper preview image -->
      <div class="w-full md:w-1/2 flex-shrink-0">
        <img
          src="/images/sections/whitepapers-preview.png"
          alt="The ROI of better management — In Parallel white paper"
          width="512"
          height="640"
          class="w-full h-auto"
        />
      </div>

      <!-- Text + CTA -->
      <div class="w-full md:w-1/2">
        <p class="text-ip-navy/70 text-lg leading-relaxed mb-4">
          40% of manager time goes to coordination — not the actual work. We've done the research to prove it, and built the product to fix it.
        </p>
        <p class="text-ip-navy/70 text-lg leading-relaxed mb-8">
          Sign up and we'll send the white papers directly to your inbox.
        </p>
        <a href="/white-papers" class="btn-primary">
          Get the white papers
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>

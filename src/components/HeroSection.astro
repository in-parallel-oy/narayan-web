---
interface Props {
  eyebrow?: string;
  title: string;
  titleHighlight?: string;
  description: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  image?: { src: string; alt: string };
}

const { eyebrow, title, titleHighlight, description, primaryCta, secondaryCta, image } = Astro.props;
---

<section class="min-h-screen relative overflow-hidden">
  <!-- Radial glow behind hero -->
  <div class="absolute inset-0 bg-ip-glow pointer-events-none" aria-hidden="true"></div>
  <div class="container-ip text-center relative pt-40 pb-20 md:pt-56 lg:pt-64">
    {eyebrow && (
      <p class="text-ip-white-muted text-base md:text-lg mb-6 font-display">{eyebrow}</p>
    )}
    <h1 class="font-serif text-5xl md:text-7xl lg:text-[110px] leading-[1.1] tracking-tight mb-8">
      {title}
      {titleHighlight && (
        <span class="block font-bold">{titleHighlight}</span>
      )}
    </h1>
    <p class="text-ip-white-muted text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
      {description}
    </p>
    {(primaryCta || secondaryCta) && (
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        {primaryCta && (
          <a href={primaryCta.href} class="btn-outline">
            {primaryCta.label}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
          </a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn-lime">
            {secondaryCta.label}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        )}
      </div>
    )}
  </div>
</section>

{image && (
  <div class="container-ip relative mt-4">
    <img src={image.src} alt={image.alt} width="1200" height="783" class="w-full rounded-xl shadow-ip-card border border-ip-border" />
  </div>
)}

---
interface Props {
  eyebrow?: string;
  eyebrowSub?: string;
  title: string;
  titleLine2?: string;
  titleHighlight?: string;
  rotatingWords?: string[];
  subtitle?: string;
  bridgeLines?: string[];
  description: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  image?: { src: string; alt: string };
  videoUrl?: string;
}

const { eyebrow, eyebrowSub, title, titleLine2, titleHighlight, rotatingWords, subtitle, bridgeLines, description, primaryCta, secondaryCta, image, videoUrl } = Astro.props;
---

<div class="relative">
  <!-- Radial glow behind hero — starts below heading, extends through product image into ValueProp -->
  <div class="absolute inset-x-0 top-[30%] -bottom-96 bg-accent-glow pointer-events-none" aria-hidden="true"></div>

  <section class="relative overflow-hidden">
    <div class="container-ip text-center relative pt-32 pb-12 md:pt-48 lg:pt-52">
      {eyebrow && (
        <p class="section-eyebrow mb-6">{eyebrow}</p>
      )}
      <h1 class="font-serif text-5xl md:text-8xl lg:text-headline-xl leading-[0.945] tracking-tight mb-6">
        {rotatingWords && rotatingWords.length > 0 ? (
          <>
            <span class="block">
              <span set:html={title} />
            </span>
            <span class="hero-heading-row block">
              <span class="word-rotator" aria-label={rotatingWords.join(', ')}>
                <span class="word-track">
                  {rotatingWords.map(word => <span class="rotator-word">{word}</span>)}
                  <span class="rotator-word">{rotatingWords[0]}</span>
                </span>
              </span>
              {titleLine2 && <span>{titleLine2}</span>}
            </span>
            {titleHighlight && (
              <span class="block">{titleHighlight}</span>
            )}
          </>
        ) : (
          <>
            <span set:html={title} />
            {titleHighlight ? (
              <span class="block font-bold">{titleHighlight}</span>
            ) : null}
          </>
        )}
      </h1>

      {subtitle && (
        <p class="text-white/90 text-lg md:text-2xl max-w-2xl mx-auto mb-6 font-display leading-snug">
          {subtitle}
        </p>
      )}

      {bridgeLines && bridgeLines.length > 0 && (
        <div class="max-w-xl mx-auto mb-8">
          {bridgeLines.map(line => (
            <p class="text-ip-white-muted text-base md:text-lg leading-relaxed mb-3" set:html={line} />
          ))}
        </div>
      )}

      {!bridgeLines && description && (
        <p class="text-ip-white-muted text-base md:text-lg max-w-xl mx-auto mb-8 leading-relaxed hyphens-none" set:html={description}>
        </p>
      )}

      {(primaryCta || secondaryCta) && (
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          {primaryCta && (videoUrl ? (
            <button id="hero-video-btn" class="btn-secondary" type="button">
              {primaryCta.label}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
            </button>
          ) : (
            <a href={primaryCta.href} class="btn-secondary">
              {primaryCta.label}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
            </a>
          ))}
          {secondaryCta && (
            <a href={secondaryCta.href} class="btn-primary">
              {secondaryCta.label}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          )}
        </div>
      )}
    </div>
  </section>

  {image && (
    <div class="container-ip relative mt-12 scroll-reveal-hero">
      <div class="relative rounded-xl card-elevated border border-ip-border overflow-hidden" data-parallax="0.1" style="will-change: transform;">
        <img src={image.src} alt={image.alt} width="1200" height="783" class="w-full block" />
      </div>
    </div>
  )}
</div>

{videoUrl && (
  <>
    <!-- Fullscreen video modal -->
    <dialog id="hero-video-modal" style="padding:0;border:0;background:transparent;max-width:100vw;max-height:100vh;width:100vw;height:100vh;">
      <div class="modal-backdrop" style="position:fixed;inset:0;background:rgba(0,0,0,0.92);display:flex;align-items:center;justify-content:center;">
        <button id="hero-video-close" aria-label="Close video" style="position:absolute;top:1.25rem;right:1.25rem;background:rgba(255,255,255,0.1);border:0;border-radius:9999px;width:2.5rem;height:2.5rem;cursor:pointer;display:flex;align-items:center;justify-content:center;color:white;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
        <div id="hero-video-frame" style="width:min(90vw,1400px);aspect-ratio:16/9;"></div>
      </div>
    </dialog>
    <span id="hero-video-src" data-url={videoUrl} hidden></span>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('hero-video-btn');
        const modal = document.getElementById('hero-video-modal');
        const closeBtn = document.getElementById('hero-video-close');
        const frameDiv = document.getElementById('hero-video-frame');
        const videoUrl = document.getElementById('hero-video-src')?.dataset.url;
        if (!btn || !modal || !frameDiv || !videoUrl) return;

        function openModal() {
          const iframe = document.createElement('iframe');
          iframe.src = videoUrl + (videoUrl.includes('?') ? '&' : '?') + 'autoplay=1&quality=1080p';
          iframe.style.cssText = 'width:100%;height:100%;border:0;border-radius:0.75rem;';
          iframe.allow = 'autoplay; fullscreen';
          frameDiv.appendChild(iframe);
          modal.showModal();
          document.body.style.overflow = 'hidden';
        }

        function closeModal() {
          modal.close();
          frameDiv.innerHTML = '';
          document.body.style.overflow = '';
        }

        btn.addEventListener('click', openModal);
        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => { if (e.target === modal || e.target.classList.contains('modal-backdrop')) closeModal(); });
        modal.addEventListener('cancel', closeModal);
      });
    </script>
  </>
)}

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const rotator = document.querySelector('.word-rotator');
    if (!rotator) return;
    const track = rotator.querySelector('.word-track');
    if (!track) return;
    const allWords = [...rotator.querySelectorAll('.rotator-word')];
    const wordCount = allWords.length - 1; // last is duplicate of first
    if (wordCount < 2) return;

    const h1 = rotator.closest('h1');

    // Measure each word's true text width using an off-screen probe
    function measureWidths() {
      const h1Style = h1 ? getComputedStyle(h1) : null;
      const probe = document.createElement('span');
      probe.style.cssText = 'position:absolute;visibility:hidden;white-space:nowrap;pointer-events:none;';
      probe.style.fontFamily = 'var(--font-display)';
      probe.style.fontWeight = '500';
      if (h1Style) {
        probe.style.fontSize = (parseFloat(h1Style.fontSize) * 1.08) + 'px';
        probe.style.letterSpacing = h1Style.letterSpacing;
      }
      document.body.appendChild(probe);
      const result = allWords.slice(0, wordCount).map(w => {
        probe.textContent = w.textContent;
        return Math.round(probe.getBoundingClientRect().width);
      });
      document.body.removeChild(probe);
      return result;
    }

    let widths = measureWidths();
    let idx = 0;

    // Set initial width and hand control to JS
    rotator.style.width = widths[0] + 'px';
    track.classList.add('js-controlled');
    track.style.transform = 'translateY(0)';

    const HOLD_TIME = 2000;
    const TRANSITION_MS = 550;
    const totalItems = wordCount + 1;

    setInterval(() => {
      idx++;
      const yPct = (idx * 100) / totalItems;
      track.style.transform = 'translateY(-' + yPct + '%)';

      if (idx >= wordCount) {
        // Transitioning to the duplicate first word
        rotator.style.width = widths[0] + 'px';
        setTimeout(() => {
          track.style.transition = 'none';
          track.style.transform = 'translateY(0)';
          idx = 0;
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              track.style.transition = '';
            });
          });
        }, TRANSITION_MS);
      } else {
        rotator.style.width = widths[idx] + 'px';
      }
    }, HOLD_TIME);

    // Re-measure on resize so widths stay correct across breakpoints
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        widths = measureWidths();
        const currentIdx = idx % wordCount;
        // Update without transition to snap immediately
        const prev = rotator.style.transition;
        rotator.style.transition = 'none';
        rotator.style.width = widths[currentIdx] + 'px';
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            rotator.style.transition = prev;
          });
        });
      }, 100);
    });
  });
</script>

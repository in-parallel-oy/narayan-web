---
interface Props {
  theme?: 'dark' | 'light';
}

const { theme = 'dark' } = Astro.props;

const navItems = [
  { label: 'Our product', href: '/#product' },
  { label: 'How it works', href: '/how-it-works' },
  { label: 'Resources', href: '/white-papers' },
  { label: 'About us', href: '/about-us' },
];
---

<header id="site-nav" data-nav-theme={theme} class="fixed top-0 left-0 right-0 z-50 h-20 flex items-center">
  <div class="w-full px-4 sm:px-8 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="nav-logo relative flex items-center no-underline overflow-visible">
      <svg id="nav-logo-static" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 110 15" class="h-4 w-auto transition-opacity duration-700" fill="currentColor" aria-label="In Parallel">
        <path d="M3.005 14.727H0V.026h7.46v10.333C7.46 12.772 5.465 14.728 3.005 14.728z"/>
        <path d="M18.999 14.727H8.656V.026h15.045v10.09c0 2.547-2.105 4.612-4.702 4.612z"/>
        <path d="M27.45 0h2.596v14.727H27.45z"/>
        <path d="M32.031 4.123h2.488v1.599c.729-1.199 2.124-1.872 3.582-1.872 2.424 0 3.861 1.536 3.861 4.229v6.648h-2.488V8.373c0-1.599-.901-2.482-2.274-2.482-1.523 0-2.681 1.22-2.681 2.861v5.975h-2.488z"/>
        <path d="M45.828 0h6.757c2.874 0 4.955 1.788 4.955 4.691s-2.081 4.671-4.955 4.671h-4.161v5.365h-2.596zm6.308 7.258c1.695 0 2.724-1.01 2.724-2.567s-1.029-2.587-2.724-2.587h-3.711v5.154z"/>
        <path d="M57.936 11.929c0-2.483 2.188-3.072 4.011-3.367l2.081-.294c.794-.126.987-.526.987-1.01 0-.862-.601-1.557-1.93-1.557s-2.124.589-2.274 1.746h-2.488c.3-2.356 2.209-3.597 4.783-3.597 2.917 0 4.376 1.367 4.376 3.934v4.544c0 .295.215.484.515.484h.579v1.915h-1.588c-1.093 0-1.78-.526-1.78-1.347v-.231c-.944 1.346-2.36 1.851-3.775 1.851-2.124 0-3.497-1.22-3.497-3.071zm4.312 1.22c1.716 0 2.767-1.389 2.767-3.135v-.568c-.322.168-.622.231-.987.316l-1.608.273c-1.352.232-1.952.736-1.952 1.641s.707 1.473 1.78 1.473z"/>
        <path d="M69.693 4.123h2.488v1.81c.622-1.284 1.631-1.81 3.003-1.81h.579v2.315h-.836c-1.845 0-2.746 1.136-2.746 3.155v5.134h-2.488z"/>
        <path d="M76.228 11.929c0-2.483 2.189-3.072 4.012-3.367l2.08-.294c.794-.126.987-.526.987-1.01 0-.862-.6-1.557-1.931-1.557-1.329 0-2.123.589-2.273 1.746h-2.488c.3-2.356 2.209-3.597 4.783-3.597 2.917 0 4.376 1.367 4.376 3.934v4.544c0 .295.215.484.515.484h.579v1.915h-1.587c-1.094 0-1.781-.526-1.781-1.347v-.231c-.944 1.346-2.359 1.851-3.775 1.851-2.124 0-3.497-1.22-3.497-3.071zm4.312 1.22c1.716 0 2.767-1.389 2.767-3.135v-.568c-.321.168-.622.231-.987.316l-1.608.273c-1.352.232-1.953.736-1.953 1.641s.709 1.473 1.781 1.473z"/>
        <path d="M88.046 0h2.489v14.727h-2.489z"/>
        <path d="M92.434 0h2.488v14.727h-2.488z"/>
        <path d="M96.095 9.425c0-3.177 2.038-5.575 5.255-5.575 2.832 0 5.148 1.599 4.977 6.185h-7.743c.149 1.746.986 3.051 2.788 3.051 1.223 0 2.038-.589 2.381-1.683h2.445c-.343 2.019-2.016 3.597-4.848 3.597-3.217 0-5.255-2.377-5.255-5.575zm7.788-1.031c-.128-1.851-1.029-2.651-2.531-2.651-1.652 0-2.488 1.157-2.724 2.651z"/>
        <path d="M107.512 0H110v14.727h-2.488z"/>
      </svg>
      <canvas
        id="nav-logo-anim"
        width="1700"
        height="340"
        class="absolute top-1/2 -translate-y-1/2 left-0 opacity-0 transition-opacity duration-700 pointer-events-none"
        style="height: 1.5rem; width: 7.48rem;"
        aria-hidden="true"
      ></canvas>
    </a>

    <!-- Desktop Nav (centered pill) -->
    <nav class="nav-pill hidden md:flex items-center absolute left-1/2 -translate-x-1/2 gap-8 lg:gap-[60px] rounded-full px-10 lg:px-12 py-3">
      {navItems.map((item) => (
        <a href={item.href} class="nav-link text-base no-underline font-display whitespace-pre">
          {item.label}
        </a>
      ))}
    </nav>

    <!-- CTA (right-aligned) -->
    <a href="/demo" class="hidden md:inline-flex btn-primary">
      Book a demo
    </a>

    <!-- Mobile Menu Toggle -->
    <button id="mobile-menu-btn" class="nav-mobile-btn md:hidden p-2 relative z-[60]" aria-label="Open menu">
      <!-- Hamburger icon -->
      <svg id="icon-hamburger" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <!-- Close icon -->
      <svg id="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
        <line x1="4" y1="4" x2="20" y2="20"/>
        <line x1="20" y1="4" x2="4" y2="20"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Nav — full-screen overlay -->
  <div id="mobile-menu" class="nav-mobile-panel hidden md:hidden fixed inset-0 z-50 flex flex-col items-center justify-center gap-10">
    <nav class="flex flex-col items-center gap-6">
      {navItems.map((item) => (
        <a href={item.href} class="nav-mobile-link text-3xl no-underline font-display">
          {item.label}
        </a>
      ))}
    </nav>
    <a href="/demo" class="btn-primary">
      Book a demo
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconHamburger = document.getElementById('icon-hamburger');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    iconHamburger?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  // Close on nav link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconHamburger?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      document.body.style.overflow = '';
    });
  });
</script>

<script>
// Idle logo easter egg — after 10s of inactivity, swap to the animated logo
(function idleLogoEasterEgg() {
  const IDLE_MS   = 10_000;
  const FIRST     = 2000;
  const COUNT     = 279;
  const FPS       = 24;
  const BASE      = '/images/logo sequence/Logo animate ';

  const staticLogo = document.getElementById('nav-logo-static') as SVGElement | null;
  const canvas     = document.getElementById('nav-logo-anim') as HTMLCanvasElement | null;
  if (!staticLogo || !canvas) return;
  const ctx = canvas.getContext('2d')!;

  // Respect reduced motion
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  /* ── Frame pool ──────────────────────────────────────────────── */
  const pool: Array<HTMLImageElement | null> = new Array(COUNT).fill(null);
  let loaded = 0;
  let ready  = false;

  function loadFrame(i: number): Promise<void> {
    return new Promise(resolve => {
      if (pool[i]) { resolve(); return; }
      const img = new Image();
      img.onload = () => { pool[i] = img; loaded++; if (loaded >= COUNT) ready = true; resolve(); };
      img.onerror = () => { pool[i] = new Image(); resolve(); };
      img.src = BASE + (FIRST + i) + '.png';
    });
  }

  // Lazy-load: start after 3s to not compete with page load
  setTimeout(() => {
    for (let i = 0; i < COUNT; i++) loadFrame(i);
  }, 3_000);

  /* ── Drawing ─────────────────────────────────────────────────── */
  function paint(frame: number) {
    const img = pool[frame];
    if (!img?.complete) return;
    ctx.clearRect(0, 0, canvas!.width, canvas!.height);
    // Center the 1700×300 frame in the 1700×340 canvas — 20px offset gives descender room
    ctx.drawImage(img, 0, 20);
  }

  /* ── Playback ────────────────────────────────────────────────── */
  let animId   = 0;
  let playing  = false;
  let forward  = true;
  let frame    = 0;

  function startPlayback() {
    if (playing || !ready) return;
    // Don't run on light backgrounds — animation frames are white on transparent
    const nav = document.getElementById('site-nav');
    if (nav?.dataset.navTheme === 'light') return;
    playing = true;
    forward = true;
    frame   = 0;

    // Crossfade: show canvas, hide SVG
    staticLogo!.style.opacity = '0';
    canvas!.style.opacity = '1';
    canvas!.classList.remove('pointer-events-none');

    paint(0);
    let last = performance.now();

    function tick(now: number) {
      if (!playing) return;
      if (now - last >= 1000 / FPS) {
        last = now;
        paint(frame);
        if (forward) {
          frame++;
          if (frame >= COUNT - 1) { frame = COUNT - 1; forward = false; }
        } else {
          frame--;
          if (frame <= 0) { frame = 0; forward = true; }
        }
      }
      animId = requestAnimationFrame(tick);
    }

    animId = requestAnimationFrame(tick);
  }

  function stopPlayback() {
    if (!playing) return;
    playing = false;
    cancelAnimationFrame(animId);

    // Crossfade: show SVG, hide canvas
    staticLogo!.style.opacity = '1';
    canvas!.style.opacity = '0';
    canvas!.classList.add('pointer-events-none');
  }

  /* ── Idle detection ──────────────────────────────────────────── */
  let idleTimer = 0;

  function resetIdle() {
    clearTimeout(idleTimer);
    stopPlayback();
    idleTimer = window.setTimeout(startPlayback, IDLE_MS);
  }

  const events = ['mousemove', 'mousedown', 'keydown', 'touchstart', 'scroll'];
  events.forEach(e => window.addEventListener(e, resetIdle, { passive: true }));

  // Start the idle timer
  idleTimer = window.setTimeout(startPlayback, IDLE_MS);
})();
</script>

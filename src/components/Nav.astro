---
const navItems = [
  { label: 'Our product', href: '/#product' },
  { label: 'How it works', href: '/#how-it-works' },
  { label: 'Resources', href: '/white-papers' },
  { label: 'About us', href: '/about-us' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 h-20 flex items-center">
  <div class="w-full px-8 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-white no-underline">
      <svg xmlns=%22http://www.w3.org/2000/svg%22 xmlns:xlink=%22http://www.w3.org/1999/xlink%22 viewBox=%220 0 110 15%22><g><path d=%22M 0 15 L 0 0 L 110 0 L 110 15 Z%22 fill=%22transparent%22></path><path d=%22M 27.45 0 L 30.046 0 L 30.046 14.727 L 27.45 14.727 Z%22 fill=%22rgb(255,255,255)%22></path><path d=%22M 32.031 4.123 L 34.519 4.123 L 34.519 5.722 C 35.248 4.523 36.643 3.85 38.101 3.85 C 40.525 3.85 41.962 5.386 41.962 8.079 L 41.962 14.727 L 39.474 14.727 L 39.474 8.373 C 39.474 6.774 38.573 5.891 37.2 5.891 C 35.677 5.891 34.519 7.111 34.519 8.752 L 34.519 14.727 L 32.031 14.727 Z%22 fill=%22rgb(255,255,255)%22></path><path d=%22M 45.828 0 L 52.585 0 C 55.459 0 57.54 1.788 57.54 4.691 C 57.54 7.595 55.459 9.362 52.585 9.362 L 48.424 9.362 L 48.424 14.727 L 45.828 14.727 Z M 52.136 7.258 C 53.831 7.258 54.86 6.248 54.86 4.691 C 54.86 3.135 53.831 2.104 52.136 2.104 L 48.425 2.104 L 48.425 7.258 Z%22 fill=%22rgb(255,255,255)%22></path><path d=%22M 57.936 11.929 C 57.936 9.446 60.124 8.857 61.947 8.562 L 64.028 8.268 C 64.822 8.142 65.015 7.742 65.015 7.258 C 65.015 6.396 64.414 5.701 63.085 5.701 C 61.755 5.701 60.961 6.29 60.811 7.447 L 58.323 7.447 C 58.623 5.091 60.532 3.85 63.106 3.85 C 66.023 3.85 67.482 5.217 67.482 7.784 L 67.482 12.328 C 67.482 12.623 67.697 12.812 67.997 12.812 L 68.576 12.812 L 68.576 14.727 L 66.988 14.727 C 65.895 14.727 65.208 14.201 65.208 13.38 L 65.208 13.149 C 64.264 14.495 62.848 15 61.433 15 C 59.309 15 57.936 13.78 57.936 11.929 Z M 62.248 13.149 C 63.964 13.149 65.015 11.76 65.015 10.014 L 65.015 9.446 C 64.693 9.614 64.393 9.677 64.028 9.762 L 62.42 10.035 C 61.068 10.267 60.468 10.771 60.468 11.676 C 60.468 12.581 61.175 13.149 62.248 13.149 Z%22 fill=%22rgb(255,255,255)%22></path><path d=%22M 69.693 4.123 L 72.181 4.123 L 72.181 5.933 C 72.803 4.649 73.812 4.123 75.184 4.123 L 75.763 4.123 L 75.763 6.438 L 74.927 6.438 C 73.082 6.438 72.181 7.574 72.181 9.593 L 72.181 14.727 L 69.693 14.727 Z%22 fill=%22rgb(255,255,255)%22></path><path d=%22M 76.228 11.929 C 76.228 9.446 78.417 8.857 80.24 8.562 L 82.32 8.268 C 83.114 8.142 83.307 7.742 83.307 7.258 C 83.307 6.396 82.707 5.701 81.376 5.701 C 80.047 5.701 79.253 6.29 79.103 7.447 L 76.615 7.447 C 76.915 5.091 78.824 3.85 81.398 3.85 C 84.315 3.85 85.774 5.217 85.774 7.784 L 85.774 12.328 C 85.774 12.623 85.989 12.812 86.289 12.812 L 86.868 12.812 L 86.868 14.727 L 85.281 14.727 C 84.187 14.727 83.5 14.201 83.5 13.38 L 83.5 13.149 C 82.556 14.495 81.141 15 79.725 15 C 77.601 15 76.228 13.78 76.228 11.929 Z M 80.54 13.149 C 82.256 13.149 83.307 11.76 83.307 10.014 L 83.307 9.446 C 82.986 9.614 82.685 9.677 82.32 9.762 L 80.712 10.035 C 79.36 10.267 78.759 10.771 78.759 11.676 C 78.759 12.581 79.468 13.149 80.54 13.149 Z%22 fill=%22rgb(255,255,255)%22></path><path d=%22M 88.046 0 L 90.535 0 L 90.535 14.727 L 88.046 14.727 Z%22 fill=%22rgb(255,255,255)%22></path><path d=%22M 92.434 0 L 94.922 0 L 94.922 14.727 L 92.434 14.727 Z%22 fill=%22rgb(255,255,255)%22></path><path d=%22M 96.095 9.425 C 96.095 6.248 98.133 3.85 101.35 3.85 C 104.182 3.85 106.498 5.449 106.327 10.035 L 98.584 10.035 C 98.733 11.781 99.57 13.086 101.372 13.086 C 102.595 13.086 103.41 12.497 103.753 11.403 L 106.198 11.403 C 105.855 13.422 104.182 15 101.35 15 C 98.133 15 96.095 12.623 96.095 9.425 Z M 103.883 8.394 C 103.755 6.543 102.854 5.743 101.352 5.743 C 99.7 5.743 98.864 6.9 98.628 8.394 Z%22 fill=%22rgb(255,255,255)%22></path><path d=%22M 107.512 0 L 110 0 L 110 14.727 L 107.512 14.727 Z%22 fill=%22rgb(255,255,255)%22></path><path d=%22M 18.999 14.727 L 8.656 14.727 L 8.656 0.026 L 23.701 0.026 L 23.701 10.116 C 23.701 12.663 21.596 14.728 18.999 14.728 Z%22 fill=%22rgb(255,255,255)%22></path><path d=%22M 3.005 14.727 L 0 14.727 L 0 0.026 L 7.46 0.026 L 7.46 10.359 C 7.46 12.772 5.465 14.728 3.005 14.728 Z%22 fill=%22rgb(255,255,255)%22></path></g></svg>
        <rect width="8" height="20" fill="#85ff3b"/>
        <rect x="10" width="8" height="20" fill="white"/>
        <rect x="20" width="8" height="20" fill="white" opacity="0.5"/>
      </svg>
      <span class="font-display text-lg tracking-tight">In Parallel</span>
    </a>

    <!-- Desktop Nav (centered pill) -->
    <nav class="hidden md:flex items-center absolute left-1/2 -translate-x-1/2 gap-[60px] bg-white/5 border border-white/10 rounded-full px-12 py-3">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-base text-white/90 hover:text-white transition-colors no-underline font-display whitespace-pre"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- CTA (right-aligned) -->
    <a href="/demo" class="hidden md:inline-flex btn-outline text-sm">
      Book a demo
    </a>

    <!-- Mobile Menu Toggle -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-white p-2"
      aria-label="Open menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden absolute top-20 left-0 right-0 bg-ip-navy border-t border-dashed border-ip-border">
    <div class="container-ip py-4 flex flex-col gap-3">
      {navItems.map((item) => (
        <a href={item.href} class="text-white/90 hover:text-white py-2 no-underline font-display">
          {item.label}
        </a>
      ))}
      <a href="/demo" class="btn-outline text-sm text-center mt-2">
        Book a demo
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>

---
const moments = [
  {
    phase: 'Weekly',
    title: 'Weekly brief',
    description: 'Start every week with a clear picture. What changed since last week, what\'s at risk, where you stand against the plan — delivered before your first meeting.',
    details: ['Priority changes surfaced', 'Stalled commitments flagged', 'Risk posture summary'],
    badge: 'Living Plan',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  },
  {
    phase: 'Before',
    title: 'Pre-meeting preparation',
    description: 'Walk in prepared. See what was decided last time, what\'s unresolved, and what needs a decision today — automatically compiled from previous meetings.',
    details: ['Open decisions from last session', 'Commitments due for review', 'Context from related meetings'],
    badge: 'Living Plan',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>`,
  },
  {
    phase: 'During',
    title: 'Capture decisions & actions',
    description: 'No one takes notes. In Parallel joins silently and captures every decision, action item, ownership assignment, and commitment as it happens.',
    details: ['Speaker-attributed transcription', 'Decisions & risks extracted live', 'Ownership automatically assigned'],
    badge: 'Free',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0-11V3m0 0a2 2 0 012 2v4a2 2 0 01-4 0V5a2 2 0 012-2z"/></svg>`,
  },
  {
    phase: 'After',
    title: 'Automated reporting',
    description: 'The moment the meeting ends, structured summaries go out, connected tools update, and the plan adjusts. Nothing for you to do.',
    details: ['Summary distributed automatically', 'Slack, email & dashboard updates', 'Plan updated with new signals'],
    badge: 'Living Plan',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M9 5l7 7-7 7"/><path d="M4 12h16"/></svg>`,
  },
  {
    phase: 'After',
    title: 'Update tools & dashboards',
    description: 'Decisions and actions flow straight into your existing tools. OKRs update, tasks get created, project status adjusts — no manual entry, no copy-paste.',
    details: ['OKR progress updated automatically', 'Tasks created in Jira, Linear, Asana', 'Project status synced in real-time'],
    badge: 'Living Plan',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M4 6h16M4 12h16M4 18h16"/><path d="M20 6l-4 4m4-4l4 4M20 12l-4 4m4-4l4 4" stroke-width="0"/><circle cx="20" cy="6" r="2"/><circle cx="20" cy="12" r="2"/><circle cx="20" cy="18" r="2"/></svg>`,
  },
  {
    phase: 'Continuous',
    title: 'Replanning & risk analysis',
    description: 'Between meetings, priorities recalculate. Drift gets flagged. Forgotten commitments surface. The plan stays alive without anyone maintaining it.',
    details: ['Priority recalculation in real-time', 'Drift detection vs. baseline plan', 'Commitment follow-through tracking'],
    badge: 'Living Plan',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
  },
];
---

<section class="py-20 md:py-32 bg-white text-ip-navy">
  <div class="container-ip">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="section-eyebrow section-eyebrow--navy mb-4">Make every meeting count</p>
      <h2 class="font-serif text-6xl md:text-8xl lg:text-[9rem] tracking-tight leading-[0.85] mb-6 text-ip-navy">
        Make plans keep up.
      </h2>
      <p class="text-ip-navy/60 text-lg max-w-[52ch] mx-auto">
        Every meeting follows a rhythm. In Parallel works across every phase — so your plan always reflects reality.
      </p>
    </div>

    <!-- Moments: top row of 3 -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
      {moments.slice(0, 3).map((moment) => (
        <div class="relative border border-ip-navy/10 rounded-xl p-8 bg-white hover:border-ip-navy/20 transition-colors">
          {/* Badge */}
          {moment.badge === 'Free' && (
            <span class="absolute top-4 right-4 bg-ip-lime text-ip-navy text-xs font-display px-3 py-1 rounded-full">
              Free
            </span>
          )}
          {moment.badge === 'Living Plan' && (
            <span class="absolute top-4 right-4 bg-ip-blue/10 text-ip-blue text-xs font-display px-3 py-1 rounded-full">
              Living Plan
            </span>
          )}

          {/* Icon */}
          <div class="text-ip-navy/30 mb-4" set:html={moment.icon} />

          {/* Phase label */}
          <p class="font-display text-xs uppercase tracking-widest text-ip-navy/40 mb-2">
            {moment.phase}
          </p>

          {/* Title */}
          <h3 class="font-display text-xl leading-snug mb-3 text-ip-navy">
            {moment.title}
          </h3>

          {/* Description */}
          <p class="text-ip-navy/60 text-sm leading-relaxed mb-4">
            {moment.description}
          </p>

          {/* Detail list */}
          <ul class="space-y-1.5">
            {moment.details.map((detail) => (
              <li class="flex items-start gap-2 text-ip-navy/50 text-xs">
                <svg class="w-3 h-3 text-ip-blue mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
                {detail}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom row of 3 -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      {moments.slice(3).map((moment) => (
        <div class="relative border border-ip-navy/10 rounded-xl p-8 bg-white hover:border-ip-navy/20 transition-colors">
          {/* Badge */}
          {moment.badge === 'Free' && (
            <span class="absolute top-4 right-4 bg-ip-lime text-ip-navy text-xs font-display px-3 py-1 rounded-full">
              Free
            </span>
          )}
          {moment.badge === 'Living Plan' && (
            <span class="absolute top-4 right-4 bg-ip-blue/10 text-ip-blue text-xs font-display px-3 py-1 rounded-full">
              Living Plan
            </span>
          )}

          {/* Icon */}
          <div class="text-ip-navy/30 mb-4" set:html={moment.icon} />

          {/* Phase label */}
          <p class="font-display text-xs uppercase tracking-widest text-ip-navy/40 mb-2">
            {moment.phase}
          </p>

          {/* Title */}
          <h3 class="font-display text-xl leading-snug mb-3 text-ip-navy">
            {moment.title}
          </h3>

          {/* Description */}
          <p class="text-ip-navy/60 text-sm leading-relaxed mb-4">
            {moment.description}
          </p>

          {/* Detail list */}
          <ul class="space-y-1.5">
            {moment.details.map((detail) => (
              <li class="flex items-start gap-2 text-ip-navy/50 text-xs">
                <svg class="w-3 h-3 text-ip-blue mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
                {detail}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a href="/how-it-works" class="btn-secondary btn-secondary--navy">
        See the full workflow
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .btn-secondary--navy {
    --btn-color: var(--color-ip-navy);
    border-color: var(--color-ip-navy);
    color: var(--color-ip-navy);
  }
  .btn-secondary--navy:hover {
    background: var(--color-ip-navy);
    color: white;
  }
</style>

---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PostHog from '../components/PostHog.astro';
import ExitIntentPopup from '../components/ExitIntentPopup.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  publishedTime?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  navTheme?: 'dark' | 'light';
}

const {
  title,
  description = 'The AI notetaker that writes your plan. In Parallel joins your meetings, captures every decision and commitment, and turns them into a living execution plan — automatically. Start free.',
  ogImage = '/images/og-default.png',
  ogType = 'website',
  publishedTime,
  jsonLd,
  navTheme = 'dark',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="In Parallel" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>

    {jsonLdArray.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <PostHog />

    <!-- LinkedIn Insight Tag -->
    <script is:inline>
      _linkedin_partner_id = "516302043";
      window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
      window._linkedin_data_partner_ids.push(_linkedin_partner_id);
    </script>
    <script is:inline>
      (function(l) {
        if (!l){window.lintrk = function(a,b){window.lintrk.q.push([a,b])};
        window.lintrk.q=[]}
        var s = document.getElementsByTagName("script")[0];
        var b = document.createElement("script");
        b.type = "text/javascript";b.async = true;
        b.src = "https://snap.licdn.com/li.lmp.js?pId=" + _linkedin_partner_id;
        s.parentNode.insertBefore(b, s);
      })(window.lintrk);
    </script>
    <noscript>
      <img height="1" width="1" style="display:none;" alt="" src="https://px.ads.linkedin.com/collect/?pid=516302043&fmt=gif" />
    </noscript>
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav theme={navTheme} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <ExitIntentPopup />
    <!-- PostHog custom event tracking -->
    <script>
      // ── Nav theme detection ──
      (function () {
        const nav = document.getElementById('site-nav');
        if (!nav) return;

        function isLightColor(color: string): boolean {
          const m = color.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/);
          if (!m) return false;
          const r = +m[1], g = +m[2], b = +m[3];
          return (r * 0.299 + g * 0.587 + b * 0.114) > 150;
        }

        function getBgColor(el: Element | null): string {
          while (el && el !== document.body) {
            const bg = window.getComputedStyle(el as HTMLElement).backgroundColor;
            if (bg && bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent') return bg;
            el = el.parentElement;
          }
          return window.getComputedStyle(document.body).backgroundColor;
        }

        function update() {
          const checkY = window.scrollY + 81;
          const sections = document.querySelectorAll('main section');
          let theme = (nav as HTMLElement).dataset.navTheme || 'dark';

          for (const section of sections) {
            const top = section.getBoundingClientRect().top + window.scrollY;
            const bot = top + (section as HTMLElement).offsetHeight;
            if (checkY >= top && checkY < bot) {
              theme = isLightColor(getBgColor(section)) ? 'light' : 'dark';
              break;
            }
          }

          (nav as HTMLElement).dataset.navTheme = theme;
        }

        update();
        window.addEventListener('scroll', update, { passive: true });
      })();
    </script>

    <script>
      // ── CTA click tracking ──
      document.addEventListener('click', (e) => {
        const el = (e.target as HTMLElement).closest('a, button');
        if (!el || typeof window === 'undefined' || !(window as any).posthog) return;

        const href = el.getAttribute('href') || '';
        const text = el.textContent?.trim().slice(0, 60) || '';
        const page = window.location.pathname;

        // Demo CTA
        if (href.includes('/demo') || el.classList.contains('btn-primary')) {
          (window as any).posthog.capture('cta_clicked', { cta: 'book_demo', text, page, href });
        }
        // Pricing link
        else if (href.includes('/pricing')) {
          (window as any).posthog.capture('cta_clicked', { cta: 'pricing', text, page, href });
        }
        // External links
        else if (href.startsWith('http') && !href.includes('in-parallel.com')) {
          (window as any).posthog.capture('outbound_click', { text, page, href });
        }
        // Any other nav/CTA buttons
        else if (el.classList.contains('btn-secondary') || el.classList.contains('btn-primary')) {
          (window as any).posthog.capture('cta_clicked', { cta: 'secondary', text, page, href });
        }
      });

      // ── Scroll depth tracking ──
      const scrollMilestones = [25, 50, 75, 100];
      const firedMilestones = new Set<number>();
      window.addEventListener('scroll', () => {
        if (typeof window === 'undefined' || !(window as any).posthog) return;
        const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
        if (scrollHeight <= 0) return;
        const pct = Math.round((window.scrollY / scrollHeight) * 100);
        for (const m of scrollMilestones) {
          if (pct >= m && !firedMilestones.has(m)) {
            firedMilestones.add(m);
            (window as any).posthog.capture('scroll_depth', { depth: m, page: window.location.pathname });
          }
        }
      }, { passive: true });
    </script>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );

      document.querySelectorAll(
        '.scroll-reveal, .scroll-reveal-hero, .scroll-reveal-scale, .scroll-reveal-fade, .stat-grow'
      ).forEach((el) => observer.observe(el));

      // Section shrink on scroll
      const shrinkEl = document.querySelector('.shrink-section');
      if (shrinkEl) {
        const wrapper = shrinkEl.closest('.shrink-scroll-wrapper');
        if (wrapper) {
          const update = () => {
            const wrapperRect = wrapper.getBoundingClientRect();
            const progress = Math.max(0, Math.min(1,
              1 - (wrapperRect.bottom - window.innerHeight) / 200
            ));
            const scale = 1 - (progress * 0.05);
            const radius = progress * 24;
            shrinkEl.style.transform = `scale(${scale})`;
            shrinkEl.style.borderRadius = `${radius}px`;
          };
          window.addEventListener('scroll', update, { passive: true });
          update();
        }
      }

      // Section grow on scroll (reverse of shrink) — triggers on reveal
      const growEl = document.querySelector('.grow-section');
      if (growEl) {
        const update = () => {
          const rect = growEl.getBoundingClientRect();
          const progress = Math.max(0, Math.min(1, (window.innerHeight - rect.top) / 300));
          const scale = 0.95 + (progress * 0.05);
          const radius = 24 - (progress * 24);
          growEl.style.transform = `scale(${scale})`;
          growEl.style.borderRadius = `${radius}px`;
        };
        window.addEventListener('scroll', update, { passive: true });
        update();
      }

      // ── Parallax ──
      (function () {
        const els = document.querySelectorAll('[data-parallax]');
        if (!els.length) return;
        let rafId: number;
        function tick() {
          const wh = window.innerHeight;
          els.forEach((el) => {
            const speed = parseFloat((el as HTMLElement).dataset.parallax || '0.2');
            const rect = el.getBoundingClientRect();
            const centerOffset = rect.top + rect.height / 2 - wh / 2;
            (el as HTMLElement).style.transform = `translateY(${(-centerOffset * speed).toFixed(2)}px)`;
          });
        }
        function onScroll() {
          cancelAnimationFrame(rafId);
          rafId = requestAnimationFrame(tick);
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        tick();
      })();
    </script>
  </body>
</html>

#!/bin/sh
# .githooks/pre-commit
#
# Auto-generates OG images (1200×630 screenshots) for any changed Astro pages
# and stages them alongside the commit.
#
# One-time setup:
#   git config core.hooksPath .githooks
#   npx playwright install chromium

# Find changed static page files (skip dynamic routes)
PAGES=$(git diff --cached --name-only \
  | grep "^src/pages/.*\.astro$" \
  | grep -v '\[' \
  | tr '\n' ' ')

if [ -z "$PAGES" ]; then
  exit 0
fi

echo "[og] Generating OG images..."
node scripts/generate-og.mjs $PAGES

# Stage any generated/updated OG images — never block the commit on failure
if [ -d "public/images/og" ]; then
  git add public/images/og/ 2>/dev/null || true
fi

exit 0
